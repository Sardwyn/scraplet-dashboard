<!DOCTYPE html>
<html>
  <head>
    <title>Kick Event Discovery</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-gray-950 text-white font-sans px-8 py-10">
    <div class="flex items-center justify-between mb-10">
      <div>
        <h1 class="text-4xl font-bold">Kick Event Discovery</h1>
        <p class="text-gray-400 mt-2">
          Events received from Kick that Scraplet does not explicitly handle yet.
        </p>
      </div>

      <a
        href="/dashboard"
        class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded shadow transition"
      >
        Back to Dashboard
      </a>
    </div>

    <% if (!events.length) { %>
      <p class="text-gray-500">No unhandled Kick events discovered yet.</p>
    <% } else { %>
      <div class="space-y-4">
        <% events.forEach(ev => { %>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-mono text-lg text-indigo-300">
                  <%= ev.event_type %>
                </p>
                <p class="text-xs text-gray-400 mt-1">
                  Version <%= ev.event_version || '—' %> · Seen <%= ev.seen_count %> times
                </p>
                <p class="text-xs text-gray-500 mt-1">
                  First: <%= ev.first_seen_at.toLocaleString() %> ·
                  Last: <%= ev.last_seen_at.toLocaleString() %>
                </p>
              </div>

              <button
                class="toggle-payload bg-indigo-600 hover:bg-indigo-500 px-3 py-1 rounded text-sm"
              >
                View payload
              </button>
            </div>

            <pre
              class="payload hidden mt-4 bg-black/70 border border-gray-800 rounded p-4 text-xs text-green-300 overflow-x-auto"
            ><%= JSON.stringify(ev.payload, null, 2) %></pre>
          </div>
        <% }); %>
      </div>
    <% } %>

    <script>
      document.querySelectorAll(".toggle-payload").forEach(btn => {
        btn.addEventListener("click", () => {
          const pre = btn.closest("div").parentElement.querySelector(".payload");
          pre.classList.toggle("hidden");
        });
      });
    </script>
  </body>
</html>
