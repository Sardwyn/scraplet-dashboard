<header class="bg-gray-900 border-b border-gray-800 text-gray-200">
  <div class="w-full px-6 py-4 flex flex-wrap items-center justify-between gap-4">
    <a href="/dashboard" class="text-2xl font-bold text-indigo-400 tracking-wide">
      Scraplet<span class="text-indigo-200">Dashboard</span>
    </a>

    <nav class="flex flex-wrap items-center gap-5 text-sm">
      <a href="/dashboard" class="text-gray-300 hover:text-indigo-300">Overview</a>
      <a href="/dashboard/scrapbot" class="text-gray-300 hover:text-indigo-300">Scrapbot</a>
      <a href="/dashboard/widgets" class="text-gray-300 hover:text-indigo-300">Widgets</a>
      <a href="/dashboard/overlays" class="text-gray-300 hover:text-indigo-300">Overlays</a>
      <a href="/dashboard/email" class="text-gray-300 hover:text-indigo-300">Email</a>

      <span class="mx-1 text-gray-700">|</span>

      <a href="/dashboard/stats" class="text-gray-400 hover:text-indigo-300">Stats</a>
      <a href="/dashboard/metrics" class="text-gray-400 hover:text-indigo-300">Metrics</a>

      <% if (user?.isAdmin) { %>
        <span class="mx-1 text-gray-700">|</span>
        <a href="/admin" class="text-gray-400 hover:text-indigo-300">Admin</a>
      <% } %>
    </nav>

    <div class="flex items-center gap-3 text-sm">
      <a href="/dashboard/casino"
         class="px-3 py-1.5 rounded bg-gray-800 hover:bg-gray-700 text-gray-200 text-xs font-semibold shadow-sm">
        Labs
      </a>

      <span class="text-gray-400 hidden sm:inline">Hi, <%= user?.username || 'Creator' %></span>

      <form action="/auth/logout" method="POST">
        <button type="submit"
          class="px-3 py-1.5 rounded bg-red-600 hover:bg-red-700 text-white text-xs font-semibold">
          Logout
        </button>
      </form>
    </div>
  </div>
</header>
