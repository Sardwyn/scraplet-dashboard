<div class="pc-panel">
    <div class="pc-panel-hd flex items-center justify-between">
        <div class="flex items-center gap-3">
            <!-- Icon (placeholder style matching dashboard) -->
            <div class="pc-icon-box text-xs font-bold">Tik</div>
            <h3 class="font-bold text-gray-100 uppercase tracking-wider text-xs">TikTok</h3>
        </div>

        <% if (tiktok && tiktok.enabled && tiktok.unique_id) { %>
            <span class="pc-chip bg-emerald-400/10 text-emerald-400">
                <span class="w-2 h-2 rounded-full bg-emerald-400 inline-block mr-1"></span>
                ACTIVE
            </span>
            <% } else { %>
                <span class="pc-chip bg-gray-700 text-gray-400">
                    OFF
                </span>
                <% } %>
    </div>

    <div class="pc-panel-bd">
        <form action="/dashboard/tiktok/save" method="POST" class="space-y-4">
            <div>
                <label class="block text-xs uppercase tracking-wider text-gray-500 mb-1">Unique ID (@username)</label>
                <div class="relative">
                    <input type="text" name="unique_id" value="<%= tiktok ? tiktok.unique_id : '' %>"
                        class="pc-input w-full pl-8 font-mono" placeholder="username" required>
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">@</span>
                </div>
                <p class="text-xs text-gray-500 mt-1">Enter your TikTok username (no @).</p>
            </div>

            <div class="flex items-center gap-2 p-3 rounded bg-gray-800/50 border border-gray-700">
                <input type="checkbox" name="enabled" id="tt_en"
                    class="w-4 h-4 rounded border-gray-600 bg-gray-700 text-indigo-500 focus:ring-indigo-500 focus:ring-offset-gray-900"
                    <%=(tiktok && tiktok.enabled) ? 'checked' : '' %>
                >
                <label for="tt_en" class="text-sm text-gray-300 font-medium select-none cursor-pointer">Enable
                    Ingest</label>
            </div>

            <button type="submit" class="pc-btn pc-btn--primary w-full">
                Save & Connect
            </button>
        </form>
    </div>
</div>