<% const _profile=(typeof profile !=="undefined" && profile) ? profile : {}; const _layout=(typeof layout !=="undefined"
  ) ? layout : null; const _sectionVisibility=(typeof sectionVisibility !=="undefined" && sectionVisibility) ?
  sectionVisibility : {}; const _customButtons=(typeof customButtons !=="undefined" && Array.isArray(customButtons)) ?
  customButtons : []; const _appearance=(typeof appearance !=="undefined" && appearance) ? appearance : {}; const
  _stats=(typeof stats !=="undefined" && stats) ? stats : {}; const _marketability=(typeof marketability !=="undefined"
  ) ? marketability : null; // Canonical public profile URL const
  publicUrl=`https://scraplet.store/s/${_profile.username || "" }`; %>

  <!DOCTYPE html>
  <html lang="en">

  <head>
    <meta charset="UTF-8" />
    <title>
      <%= _profile.display_name || _profile.username || "Profile" %> — Scraplet
    </title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://js.stripe.com/v3/"></script>
    <script>window.STRIPE_PUBLISHABLE_KEY = "<%= process.env.STRIPE_PUBLISHABLE_KEY || '' %>";</script>
    <link rel="stylesheet" href="/dashboard/css/profile-card.css?v=1" />

    <style>
      @media (max-width: 768px) {
        .profile-qr {
          display: none !important;
        }
      }

      .profile-qr {
        position: fixed;
        bottom: 18px;
        right: 18px;
        z-index: 9999;
        user-select: none;
      }

      .profile-qr-toggle {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, .18);
        background: rgba(15, 23, 42, .78);
        backdrop-filter: blur(10px);
        color: rgba(255, 255, 255, .92);
        font-weight: 700;
        font-size: 12px;
        letter-spacing: 0.12em;
        cursor: pointer;
        box-shadow: 0 10px 28px rgba(0, 0, 0, .35);
        transition: transform .12s ease, border-color .12s ease, background .12s ease;
      }

      .profile-qr-toggle:hover {
        transform: translateY(-1px);
        border-color: rgba(255, 255, 255, .28);
        background: rgba(15, 23, 42, .88);
      }

      .profile-qr-panel {
        position: absolute;
        right: 0;
        bottom: 54px;
        width: 220px;
        padding: 12px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, .16);
        background: rgba(2, 6, 23, .92);
        backdrop-filter: blur(12px);
        box-shadow: 0 16px 40px rgba(0, 0, 0, .45);
      }

      .profile-qr-panel.hidden {
        display: none;
      }

      .profile-qr-img {
        display: block;
        width: 196px;
        height: 196px;
        margin: 0 auto;
        background: #fff;
        border-radius: 10px;
      }

      .profile-qr-caption {
        margin-top: 8px;
        font-size: 12px;
        text-align: center;
        color: rgba(255, 255, 255, .68);
      }

      .profile-qr-caption a {
        color: rgba(125, 211, 252, .95);
        text-decoration: none;
      }

      .profile-qr-caption a:hover {
        text-decoration: underline;
      }
    </style>
  </head>

  <%
    const _canvasBg = _appearance.canvasBg || '';
    const _canvasVideo = _appearance.canvasVideo || '';
    const _qrEnabled = _appearance.qrEnabled !== false;
    const _bodyStyle = _canvasBg ? 'style="background:' + _canvasBg + '"' : '';
  %>
  <body class="min-h-screen text-white" <%- _bodyStyle %>>
    <% if (_canvasVideo) {
      // Detect YouTube URLs and convert to embed format
      const _ytMatch = _canvasVideo.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
      const _ytId = _ytMatch ? _ytMatch[1] : null;
    %>
    <% if (_ytId) { %>
      <!-- YouTube background via iframe -->
      <div style="position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;">
        <iframe
          src="https://www.youtube.com/embed/<%= _ytId %>?autoplay=1&mute=1&loop=1&playlist=<%= _ytId %>&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
          style="position:absolute;top:50%;left:50%;width:177.78vh;height:100vh;min-width:100%;min-height:56.25vw;transform:translate(-50%,-50%);border:none;"
          allow="autoplay; encrypted-media"
          allowfullscreen
        ></iframe>
      </div>
    <% } else { %>
      <!-- Direct video file background -->
      <video autoplay muted loop playsinline
             style="position:fixed;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;pointer-events:none;">
        <source src="<%= _canvasVideo %>" />
      </video>
    <% } %>
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:1;pointer-events:none;"></div>
    <% } %>

    <main class="min-h-screen flex items-center justify-center p-6" style="position:relative;z-index:2;">
      <div class="w-full max-w-2xl">
        <%- include("partials/profile-card", { profile: _profile, layout: _layout, sectionVisibility:
          _sectionVisibility, customButtons: _customButtons, appearance: _appearance, stats: _stats, marketability:
          _marketability }) %>
      </div>
    </main>

    <% if (_profile && _profile.username && _qrEnabled) { %>
      <div class="profile-qr" data-profile-qr>
        <button class="profile-qr-toggle" type="button" aria-label="Show QR">
          QR
        </button>

        <div class="profile-qr-panel hidden" aria-hidden="true">
          <img class="profile-qr-img" alt="Profile QR code"
            src="https://api.qrserver.com/v1/create-qr-code/?size=196x196&data=<%= encodeURIComponent(publicUrl) %>" />
          <div class="profile-qr-caption">
            Scan to open profile<br />
            <a href="<%= publicUrl %>" target="_blank" rel="noopener">Open link</a>
          </div>
        </div>
      </div>
      <% } %>

        <script>
          (function () {
            var root = document.querySelector("[data-profile-qr]");
            if (!root) return;

            var btn = root.querySelector(".profile-qr-toggle");
            var panel = root.querySelector(".profile-qr-panel");
            if (!btn || !panel) return;

            btn.addEventListener("click", function () {
              panel.classList.toggle("hidden");
              panel.setAttribute(
                "aria-hidden",
                panel.classList.contains("hidden") ? "true" : "false"
              );
            });

            document.addEventListener("click", function (e) {
              if (!root.contains(e.target)) {
                panel.classList.add("hidden");
                panel.setAttribute("aria-hidden", "true");
              }
            });
          })();
        </script>
    <script src="/static/js/tts-panel.js"></script>
  </body>

  </html>