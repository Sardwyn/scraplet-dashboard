<title>Profile Editor</title>

<!-- 🔗 Canonical profile card CSS (same as public profile) -->
<link rel="stylesheet" href="/dashboard/profile-assets/css/profile-card.css?v=1">


<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>



<style>
  /* ===========
   * Editor shell
   * =========== */
.pe-links-item-dragging {
  opacity: 0.8;
  background: rgba(15, 23, 42, 0.9);
}


  .pe-page-root {
    min-height: calc(100vh - 64px);
    padding: 2rem 2.5rem 3rem;
    background: radial-gradient(circle at 0% 0%, #020617 0, #020617 55%);
    color: #e5e7eb;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text",
      "Segoe UI", sans-serif;
  }

  .pe-page-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.2fr);
    gap: 2.5rem;
    align-items: flex-start;
  }

  @media (max-width: 960px) {
    .pe-page-root {
      padding: 1.5rem 1.25rem 2rem;
    }
    .pe-page-inner {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .pe-preview-column {
    display: flex;
    justify-content: center;
  }

  .pe-preview-phone-frame {
    width: 100%;
    max-width: 420px;
    padding: 2.5rem 1.5rem 2.75rem;
    border-radius: 40px;
    background: radial-gradient(circle at 0 0, #020617 0, #000 70%);
    box-shadow:
      0 40px 90px rgba(0, 0, 0, 0.9),
      0 0 0 1px rgba(15, 23, 42, 0.9);
  }

  .pe-profile-preview {
    filter: drop-shadow(0 32px 80px rgba(15, 23, 42, 0.95));
  }

  .pe-preview-caption {
    margin-top: 1rem;
    font-size: 0.78rem;
    color: #9ca3af;
    text-align: center;
  }

  .pe-editor-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Panels */
  .pe-panel {
    background: radial-gradient(circle at 0 0, #020617 0, #020617 60%);
    border-radius: 1.25rem;
    border: 1px solid rgba(15, 23, 42, 0.9);
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.8),
      0 0 0 1px rgba(30, 64, 175, 0.4);
    padding: 1.35rem 1.4rem 1.4rem;
  }

  .pe-panel-header {
    margin-bottom: 1rem;
  }

  .pe-panel-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.15rem;
  }

  .pe-panel-subtitle {
    margin: 0;
    font-size: 0.8rem;
    color: #9ca3af;
  }

  /* Forms */
  .pe-form-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.8rem 1rem;
    font-size: 0.84rem;
  }

  .pe-form-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .pe-form-field-full {
    grid-column: 1 / -1;
  }

  .pe-label {
    font-size: 0.8rem;
    font-weight: 500;
  }

  .pe-help {
    margin: 0;
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .pe-input,
  .pe-textarea,
  .pe-input-file {
    width: 100%;
    border-radius: 0.6rem;
    border: 1px solid rgba(51, 65, 85, 0.9);
    background: rgba(15, 23, 42, 0.9);
    color: #e5e7eb;
    padding: 0.5rem 0.6rem;
    font-size: 0.8rem;
    outline: none;
  }

  .pe-input:focus,
  .pe-textarea:focus {
    border-color: rgba(56, 189, 248, 0.9);
    box-shadow: 0 0 0 1px rgba(56, 189, 248, 0.6);
  }

  .pe-textarea {
    resize: vertical;
    min-height: 70px;
  }

  .pe-file-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  /* Buttons */
  .pe-btn {
    border-radius: 999px;
    border: 1px solid transparent;
    font-size: 0.8rem;
    padding: 0.45rem 0.9rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    white-space: nowrap;
  }

  .pe-btn-primary {
    background: radial-gradient(circle at 0 0, #38bdf8 0, #0ea5e9 40%, #1d4ed8 100%);
    border-color: rgba(56, 189, 248, 0.9);
    color: #0b1120;
    font-weight: 500;
  }

  .pe-btn-secondary {
    background: rgba(15, 23, 42, 0.95);
    border-color: rgba(148, 163, 184, 0.7);
    color: #e5e7eb;
  }

  .pe-btn-danger {
    background: rgba(127, 29, 29, 0.95);
    border-color: rgba(239, 68, 68, 0.9);
    color: #fee2e2;
  }

  .pe-btn:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .pe-status-text {
    margin-top: 0.3rem;
    font-size: 0.72rem;
    color: #9ca3af;
  }

  .pe-status-error {
    color: #fecaca;
  }

  /* Add button row */
  .pe-add-button-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pe-add-button-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.6fr);
    gap: 0.5rem;
  }

  .pe-add-button-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Existing buttons list */
  .pe-links-list {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .pe-links-list-item {
    border-radius: 0.9rem;
    border: 1px solid rgba(30, 64, 175, 0.65);
    background: radial-gradient(circle at 0 0, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.92));
    padding: 0.6rem 0.7rem 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .pe-links-item-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: #9ca3af;
  }

  .pe-links-item-handle {
    cursor: grab;
    font-size: 0.9rem;
  }

  .pe-links-item-body {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.6fr);
    gap: 0.4rem;
  }

  .pe-links-item-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .pe-links-item-actions {
    display: flex;
    gap: 0.4rem;
  }

  .pe-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: #e5e7eb;
  }

  .pe-toggle input {
    accent-color: #38bdf8;
  }

  .pe-empty {
    font-size: 0.8rem;
    color: #6b7280;
  }

  /* Layout chips */
  .pe-layout-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1rem;
  }

  @media (max-width: 960px) {
    .pe-layout-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .pe-layout-heading {
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #9ca3af;
    margin: 0 0 0.35rem;
  }

  .pe-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .pe-chip {
    border-radius: 999px;
    border: 1px solid rgba(51, 65, 85, 0.9);
    background: rgba(15, 23, 42, 0.95);
    padding: 0.3rem 0.7rem;
    font-size: 0.75rem;
    color: #e5e7eb;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
  }

  .pe-chip-active {
    border-color: rgba(56, 189, 248, 0.9);
    background: radial-gradient(circle at 0 0, rgba(56, 189, 248, 0.22), rgba(15, 23, 42, 0.98));
  }

  .pe-chip-status {
    font-size: 0.7rem;
    color: #9ca3af;
  }

  .pe-link {
    color: #38bdf8;
    text-decoration: none;
    font-size: 0.78rem;
  }

  .pe-link:hover {
    text-decoration: underline;
  }

  /* Theme picker */
  .pe-theme-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .pe-theme-swatch {
    border-radius: 0.9rem;
    border: 1px solid rgba(51, 65, 85, 0.9);
    background: radial-gradient(circle at 0 0, #020617 0, #020617 70%);
    padding: 0.6rem 0.8rem;
    font-size: 0.78rem;
    color: #e5e7eb;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 140px;
    justify-content: flex-start;
  }

  .pe-theme-swatch-pill {
    width: 34px;
    height: 22px;
    border-radius: 999px;
    background: radial-gradient(circle at 0 0, #0f172a 0, #020617 80%);
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.9);
    border: 1px solid rgba(56, 189, 248, 0.7);
  }

  .pe-theme-swatch-label-main {
    font-weight: 500;
  }

  .pe-theme-swatch-label-sub {
    font-size: 0.7rem;
    color: #9ca3af;
  }

  .pe-theme-swatch-active {
    border-color: rgba(56, 189, 248, 0.9);
    box-shadow:
      0 14px 38px rgba(0, 0, 0, 0.9),
      0 0 0 1px rgba(37, 99, 235, 0.8);
  }

</style>

<div
  class="pe-page-root"
  data-theme="<%= (appearance && appearance.theme) || 'midnight' %>"
>
  <div class="pe-page-inner">
    <!-- LEFT: Live preview -->
    <section class="pe-preview-column">
      <div class="pe-preview-phone-frame">
        <div class="pe-profile-preview">
          <%- include('partials/profile-card', {
            profile,
            customButtons,
            appearance,
            layout,
            sectionVisibility,
            stats,
            marketability
          }) %>
        </div>
        <p class="pe-preview-caption">
          This preview uses the exact same card partial as your public profile.
        </p>
      </div>
    </section>

    <!-- RIGHT: Editor controls -->
    <section class="pe-editor-column">
      <!-- PROFILE BASICS -->
      <div class="pe-panel">
        <div class="pe-panel-header">
          <h2 class="pe-panel-title">Profile basics</h2>
          <p class="pe-panel-subtitle">
            Display name and short intro that appear at the top of your card.
          </p>
        </div>

        <form id="pe-basic-form" class="pe-form-grid">
          <!-- Display name -->
          <div class="pe-form-field">
            <label class="pe-label" for="display_name">Display name</label>
            <input
              id="display_name"
              name="display_name"
              type="text"
              maxlength="80"
              class="pe-input"
              value="<%= profile?.display_name || '' %>"
              placeholder="Usually your channel or brand."
            />
          </div>

          <!-- Header image uploader -->
          <div class="pe-form-field">
            <label class="pe-label" for="header_image">Header image</label>
            <p class="pe-help">
              This image fills the top of your profile card.
            </p>
            <div class="pe-file-row">
              <input
                id="header_image"
                name="header_image"
                type="file"
                accept="image/*"
                class="pe-input-file"
              />
              <button
                type="button"
                id="pe-upload-header-btn"
                class="pe-btn pe-btn-secondary"
              >
                Upload header image
              </button>
            </div>
            <% if (profile?.cover_image_url) { %>
              <p class="pe-help" style="margin-top:0.3rem;">
                Current image:
                <a
                  href="<%= profile.cover_image_url %>"
                  target="_blank"
                  class="pe-link"
                >
                  View
                </a>
              </p>
            <% } %>
          </div>

          <!-- Bio -->
          <div class="pe-form-field pe-form-field-full">
            <label class="pe-label" for="bio">Bio</label>
            <textarea
              id="bio"
              name="bio"
              rows="3"
              maxlength="280"
              class="pe-textarea"
              placeholder="One or two lines. Keep it tight."
            ><%= profile?.bio || '' %></textarea>
          </div>

          <p id="pe-basic-status" class="pe-status-text">Idle</p>
        </form>
      </div>

      <!-- BUTTONS & LINKS -->
      <div class="pe-panel">
        <div class="pe-panel-header">
          <h2 class="pe-panel-title">Buttons &amp; links</h2>
          <p class="pe-panel-subtitle">
            Add custom buttons for channels, merch, tip jars and anything else.
          </p>
        </div>

        <!-- Add new button -->
        <div class="pe-add-button-row">
          <div class="pe-form-field">
            <label class="pe-label" for="new_button_label">Add a new button</label>
            <p class="pe-help">
              Short label ("YouTube", "Merch store") and a full URL.
            </p>
            <div class="pe-add-button-grid">
              <input
                id="new_button_label"
                type="text"
                class="pe-input"
                placeholder="Button label"
              />
              <input
                id="new_button_url"
                type="text"
                class="pe-input"
                placeholder="https://example.com/"
              />
            </div>
          </div>
          <div class="pe-add-button-actions">
            <button
              id="pe-add-button"
              type="button"
              class="pe-btn pe-btn-primary"
            >
              + Add button
            </button>
            <p id="pe-add-status" class="pe-status-text" style="margin-top:0.3rem;"></p>
          </div>
        </div>

        <!-- Existing buttons list -->
        <div id="pe-links-list" class="pe-links-list">
          <% if (customButtons && customButtons.length) { %>
            <% customButtons.forEach(function(btn) { %>
              <div
                class="pe-links-list-item"
                data-id="<%= btn.id %>"
                data-initial-label="<%- btn.label %>"
                data-initial-url="<%- btn.url %>"
              >
                <div class="pe-links-item-header">
                  <span class="pe-links-item-handle">☰</span>
                  <span class="pe-links-item-label">Label</span>
                </div>
                <div class="pe-links-item-body">
                  <input
                    type="text"
                    class="pe-input pe-link-label"
                    value="<%- btn.label %>"
                  />
                  <input
                    type="text"
                    class="pe-input pe-link-url"
                    value="<%- btn.url %>"
                  />
                </div>
                <div class="pe-links-item-footer">
                  <label class="pe-toggle">
                    <input
                      type="checkbox"
                      class="pe-link-visible"
                      <%= btn.visible !== false ? 'checked' : '' %>
                    />
                    <span>Visible</span>
                  </label>
                  <div class="pe-links-item-actions">
                    <button
                      type="button"
                      class="pe-btn pe-btn-secondary pe-link-save"
                    >
                      Save
                    </button>
                    <button
                      type="button"
                      class="pe-btn pe-btn-danger pe-link-delete"
                    >
                      Remove
                    </button>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="pe-empty">
              No buttons yet. Add your first one above.
            </p>
          <% } %>
        </div>
      </div>

      <!-- APPEARANCE / THEME -->
      <div class="pe-panel">
        <div class="pe-panel-header">
          <h2 class="pe-panel-title">Appearance</h2>
          <p class="pe-panel-subtitle">
            Pick a base theme for your card. This updates your public profile immediately.
          </p>
        </div>

        <div class="pe-theme-grid">
          <button
            type="button"
            class="pe-theme-swatch"
            data-theme="midnight"
          >
            <div class="pe-theme-swatch-pill"></div>
            <div>
              <div class="pe-theme-swatch-label-main">Midnight</div>
              <div class="pe-theme-swatch-label-sub">Deep blue, subtle glow</div>
            </div>
          </button>

          <button
            type="button"
            class="pe-theme-swatch"
            data-theme="neon"
          >
            <div class="pe-theme-swatch-pill"></div>
            <div>
              <div class="pe-theme-swatch-label-main">Neon HUD</div>
              <div class="pe-theme-swatch-label-sub">Punchier cyber glow</div>
            </div>
          </button>
        </div>

        <p id="pe-theme-status" class="pe-status-text"></p>
      </div>

      <!-- LAYOUT TOGGLES -->
      <div class="pe-panel">
        <div class="pe-panel-header">
          <h2 class="pe-panel-title">Layout</h2>
          <p class="pe-panel-subtitle">
            Toggle sections on or off. This updates your public profile immediately.
          </p>
        </div>

        <div class="pe-layout-grid">
          <div class="pe-layout-group">
            <h3 class="pe-layout-heading">Core</h3>
            <div class="pe-chip-row">
              <button
                type="button"
                class="pe-chip pe-chip-toggle"
                data-section="avatar"
                data-visible="<%= (sectionVisibility && sectionVisibility.avatar !== false) ? 'true' : 'false' %>"
              >
                <span>Avatar</span>
                <span class="pe-chip-status"></span>
              </button>
              <button
                type="button"
                class="pe-chip pe-chip-toggle"
                data-section="bio"
                data-visible="<%= (sectionVisibility && sectionVisibility.bio !== false) ? 'true' : 'false' %>"
              >
                <span>Bio</span>
                <span class="pe-chip-status"></span>
              </button>
              <button
                type="button"
                class="pe-chip pe-chip-toggle"
                data-section="socialLinks"
                data-visible="<%= (sectionVisibility && sectionVisibility.socialLinks !== false) ? 'true' : 'false' %>"
              >
                <span>Social links</span>
                <span class="pe-chip-status"></span>
              </button>
            </div>
          </div>

          <div class="pe-layout-group">
            <h3 class="pe-layout-heading">Extras</h3>
            <div class="pe-chip-row">
              <button
                type="button"
                class="pe-chip pe-chip-toggle"
                data-section="stats"
                data-visible="<%= (sectionVisibility && sectionVisibility.stats !== false) ? 'true' : 'false' %>"
              >
                <span>Stats</span>
                <span class="pe-chip-status"></span>
              </button>
              <button
                type="button"
                class="pe-chip pe-chip-toggle"
                data-section="featuredWidget"
                data-visible="<%= (sectionVisibility && sectionVisibility.featuredWidget !== false) ? 'true' : 'false' %>"
              >
                <span>Featured widget</span>
                <span class="pe-chip-status"></span>
              </button>
              <button
                type="button"
                class="pe-chip pe-chip-toggle"
                data-section="sponsorBanner"
                data-visible="<%= (sectionVisibility && sectionVisibility.sponsorBanner !== false) ? 'true' : 'false' %>"
              >
                <span>Sponsor banner</span>
                <span class="pe-chip-status"></span>
              </button>
              <button
                type="button"
                class="pe-chip pe-chip-toggle"
                data-section="customHtml"
                data-visible="<%= (sectionVisibility && sectionVisibility.customHtml !== false) ? 'true' : 'false' %>"
              >
                <span>Custom HTML</span>
                <span class="pe-chip-status"></span>
              </button>
            </div>
          </div>
        </div>

        <p id="pe-layout-status" class="pe-status-text"></p>
      </div>
    </section>
  </div>
</div>

<script>
  (function () {
    const rootEl = document.querySelector('.pe-page-root');
    const initialTheme = rootEl?.dataset.theme || 'midnight';

    const basicForm = document.getElementById('pe-basic-form');
    const basicStatus = document.getElementById('pe-basic-status');
    const previewRoot = document.querySelector('.pe-profile-preview');

    function setBasicStatus(msg, isError) {
      if (!basicStatus) return;
      basicStatus.textContent = msg;
      basicStatus.classList.toggle('pe-status-error', !!isError);
    }

    function debounce(fn, delay) {
      let t;
      return function (...args) {
        clearTimeout(t);
        t = setTimeout(() => fn.apply(this, args), delay);
      };
    }

        async function saveBasics() {
      if (!basicForm) return;

      const formData = new FormData(basicForm);
      const payload = {
        display_name: formData.get('display_name') || '',
        bio: formData.get('bio') || ''
      };

      setBasicStatus('Saving...');

      try {
        const res = await fetch('/dashboard/api/profile/basic', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify(payload)
        });

        const data = await res.json().catch(() => null);
        if (!data || !data.ok) {
          setBasicStatus((data && data.error) || 'Failed to save', true);
        } else {
          setBasicStatus('Saved');
          syncPreviewBasics();
        }
      } catch (err) {
        console.error('Failed to save basics', err);
        setBasicStatus('Error saving', true);
      }
    }


    function syncPreviewBasics() {
      if (!previewRoot) return;
      const dn = document.getElementById('display_name');
      const bio = document.getElementById('bio');

      const nameEl = previewRoot.querySelector('.pc-display-name');
      const bioEl = previewRoot.querySelector('.pc-bio');

      if (nameEl && dn) {
        nameEl.textContent = dn.value || 'Your name';
      }
      if (bioEl && bio) {
        const val = (bio.value || '').trim();
        if (val) {
          bioEl.textContent = val;
          bioEl.style.display = '';
        } else {
          bioEl.textContent = '';
          bioEl.style.display = 'none';
        }
      }
    }

    if (basicForm) {
      const debounced = debounce(saveBasics, 500);
      basicForm.addEventListener('input', () => {
        setBasicStatus('Pending save...');
        debounced();
      });
    }

    // ----- CUSTOM BUTTONS -----
    const listEl = document.getElementById('pe-links-list');
    const addBtn = document.getElementById('pe-add-button');
    const addLabel = document.getElementById('new_button_label');
    const addUrl = document.getElementById('new_button_url');
    const addStatus = document.getElementById('pe-add-status');

    function setAddStatus(msg, isError) {
      if (!addStatus) return;
      addStatus.textContent = msg || '';
      addStatus.classList.toggle('pe-status-error', !!isError);
    }

    function createButtonItem(btn) {
      const wrapper = document.createElement('div');
      wrapper.className = 'pe-links-list-item';
      wrapper.dataset.id = btn.id;
      wrapper.dataset.initialLabel = btn.label;
      wrapper.dataset.initialUrl = btn.url;

      wrapper.innerHTML = `
        <div class="pe-links-item-header">
          <span class="pe-links-item-handle">☰</span>
          <span class="pe-links-item-label">Label</span>
        </div>
        <div class="pe-links-item-body">
          <input type="text" class="pe-input pe-link-label" value="${btn.label}">
          <input type="text" class="pe-input pe-link-url" value="${btn.url}">
        </div>
        <div class="pe-links-item-footer">
          <label class="pe-toggle">
            <input type="checkbox" class="pe-link-visible" ${btn.visible !== false ? 'checked' : ''}>
            <span>Visible</span>
          </label>
          <div class="pe-links-item-actions">
            <button type="button" class="pe-btn pe-btn-secondary pe-link-save">Save</button>
            <button type="button" class="pe-btn pe-btn-danger pe-link-delete">Remove</button>
          </div>
        </div>
      `;
      return wrapper;
    }

    async function saveButton(li) {
      const id = li.dataset.id;
      const labelInput = li.querySelector('.pe-link-label');
      const urlInput = li.querySelector('.pe-link-url');
      const visibleInput = li.querySelector('.pe-link-visible');

      const label = (labelInput.value || '').trim();
      const url = (urlInput.value || '').trim();
      const visible = !!visibleInput.checked;

      if (!label || !url) {
        alert('Label and URL are required');
        return;
      }

      const btn = li.querySelector('.pe-btn.pe-link-save');
      if (btn) btn.disabled = true;

      try {
        const res = await fetch(`/dashboard/api/profile/buttons/${id}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ label, url, visible })
        });
        const data = await res.json();
        if (!data.ok) {
          alert(data.error || 'Failed to save button');
        } else {
          li.dataset.initialLabel = label;
          li.dataset.initialUrl = url;
          syncPreviewFromList();
        }
      } catch (err) {
        console.error('Failed to save button', err);
        alert('Error saving button');
      } finally {
        if (btn) btn.disabled = false;
      }
    }

    async function deleteButton(li) {
      const id = li.dataset.id;
      if (!confirm('Remove this button?')) return;

      try {
        const res = await fetch(`/dashboard/api/profile/buttons/${id}`, {
          method: 'DELETE',
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        const data = await res.json();
        if (!data.ok) {
          alert(data.error || 'Failed to delete button');
        } else {
          li.remove();
          syncPreviewFromList();
        }
      } catch (err) {
        console.error('Failed to delete button', err);
        alert('Error deleting button');
      }
    }

    function syncPreviewFromList() {
      if (!previewRoot || !listEl) return;

      const container = previewRoot.querySelector('.pc-buttons');
      if (!container) return;

      const btnEls = container.querySelectorAll('a.pc-button');
      btnEls.forEach((el) => el.remove());

      const dataEls = listEl.querySelectorAll('.pe-links-list-item');

      if (!dataEls.length) {
        container.innerHTML = '<p class="text-xs text-slate-400 text-center">No links yet.</p>';
        return;
      }

      container.innerHTML = '';

      dataEls.forEach((li) => {
        const labelInput = li.querySelector('.pe-link-label');
        const urlInput = li.querySelector('.pe-link-url');
        const visibleInput = li.querySelector('.pe-link-visible');

        if (!visibleInput.checked) return;

        const a = document.createElement('a');
        a.href = (urlInput.value || '').trim();
        a.target = '_blank';
        a.className = 'pc-button pc-button--shape-pill pc-button--size-md';
        a.textContent = (labelInput.value || '').trim() || 'Link';

        container.appendChild(a);
      });
    }

    if (listEl) {
      listEl.addEventListener('click', (e) => {
        const target = e.target;
        const li = target.closest('.pe-links-list-item');
        if (!li) return;

        if (target.classList.contains('pe-link-save')) {
          saveButton(li);
        } else if (target.classList.contains('pe-link-delete')) {
          deleteButton(li);
        }
      });

      listEl.addEventListener('change', (e) => {
        const target = e.target;
        if (
          target.classList.contains('pe-link-visible') ||
          target.classList.contains('pe-link-label') ||
          target.classList.contains('pe-link-url')
        ) {
          syncPreviewFromList();
        }
      });
    }

    if (addBtn && addLabel && addUrl) {
      addBtn.addEventListener('click', async () => {
        const label = (addLabel.value || '').trim();
        const url = (addUrl.value || '').trim();

        if (!label || !url) {
          setAddStatus('Label and URL are required', true);
          return;
        }

        setAddStatus('Adding...');

        try {
          const res = await fetch('/dashboard/api/profile/buttons', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ label, url })
          });
          const data = await res.json();
          if (!data.ok) {
            setAddStatus(data.error || 'Failed to add button', true);
          } else if (data.button) {
            setAddStatus('');
            addLabel.value = '';
            addUrl.value = '';

            if (listEl) {
              if (listEl.querySelector('.pe-empty')) {
                listEl.innerHTML = '';
              }
              const item = createButtonItem(data.button);
              listEl.appendChild(item);
              syncPreviewFromList();
            }
          } else if (Array.isArray(data.buttons)) {
            // fallback if API returns full list instead of single button
            setAddStatus('');
            addLabel.value = '';
            addUrl.value = '';
            listEl.innerHTML = '';
            data.buttons.forEach((btn) => {
              const item = createButtonItem(btn);
              listEl.appendChild(item);
            });
            syncPreviewFromList();
          }
        } catch (err) {
          console.error('Failed to add button', err);
          setAddStatus('Error adding button', true);
        }
      });
    }

  async function saveOrder(order) {
  try {
    const res = await fetch('/dashboard/api/profile/buttons/reorder', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ order })
    });

    if (!res.ok) {
      setAddStatus('Failed to reorder (HTTP ' + res.status + ')', true);
      return;
    }

    const data = await res.json().catch(() => null);
    if (!data || data.ok !== true) {
      setAddStatus((data && data.error) || 'Failed to reorder', true);
      return;
    }

    // data.buttons is the updated list from server – you can re-render from that if you want
    setAddStatus('Order saved');
  } catch (err) {
    console.error('saveOrder error:', err);
    setAddStatus('Error saving order', true);
  }
}


function initSortable() {
  if (!window.Sortable || !listEl) return;

  new Sortable(listEl, {
    animation: 150,
    handle: '.pe-links-item-handle',
    ghostClass: 'pe-links-item-dragging',
    onEnd: async function () {
      const order = Array.from(listEl.querySelectorAll('.pe-links-list-item'))
        .map((li) => li.dataset.id)
        .filter(Boolean);

      if (!order.length) return;

      setAddStatus('Reordering…');
      await saveOrder(order);
      syncPreviewFromList();
    }
  });
}




    // ----- LAYOUT TOGGLES -----
    const layoutStatus = document.getElementById('pe-layout-status');
    const layoutChips = document.querySelectorAll('.pe-chip-toggle');

    function setLayoutStatus(msg, isError) {
      if (!layoutStatus) return;
      layoutStatus.textContent = msg || '';
      layoutStatus.classList.toggle('pe-status-error', !!isError);
    }

async function saveLayout() {
  const sections = [];
  layoutChips.forEach((chip) => {
    const type = chip.dataset.section;
    const visible = chip.dataset.visible !== 'false';
    sections.push({ type, visible });
  });

  setLayoutStatus('Saving...');

  try {
    const res = await fetch('/dashboard/api/profile/layout', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      // ⬇️ THIS LINE
      body: JSON.stringify({ layout: { sections } })
    });
    const data = await res.json();
    if (!data.ok) {
      setLayoutStatus(data.error || 'Failed to save layout', true);
    } else {
      setLayoutStatus('Layout saved');
    }
  } catch (err) {
    console.error('Failed to save layout', err);
    setLayoutStatus('Error saving layout', true);
  }
}

    function syncPreviewLayout() {
      if (!previewRoot) return;
      const card = previewRoot.querySelector('.pc-card-root');
      if (!card) return;

      // Build a simple visibility map from the chips
      const vis = {};
      layoutChips.forEach((chip) => {
        const type = chip.dataset.section;
        const visible = chip.dataset.visible !== 'false';
        if (type) vis[type] = visible;
      });

      const map = {
        avatar: ['.pc-identity'],
        bio: ['.pc-bio'],
        socialLinks: ['.pc-social-row'],
        stats: ['.pc-stats-row'],
        // featuredWidget / sponsorBanner / customHtml can be wired later
      };

      Object.entries(map).forEach(([type, selectors]) => {
        const v = vis[type] !== false;
        selectors.forEach((sel) => {
          card.querySelectorAll(sel).forEach((el) => {
            el.style.display = v ? '' : 'none';
          });
        });
      });
    }



    layoutChips.forEach((chip) => {
      const status = chip.querySelector('.pe-chip-status');
      const visible = chip.dataset.visible !== 'false';
      if (status) status.textContent = visible ? 'Visible' : 'Hidden';
      chip.classList.toggle('pe-chip-active', visible);

            chip.addEventListener('click', () => {
        const nowVisible = chip.dataset.visible !== 'false' ? false : true;
        chip.dataset.visible = nowVisible ? 'true' : 'false';
        if (status) status.textContent = nowVisible ? 'Visible' : 'Hidden';
        chip.classList.toggle('pe-chip-active', nowVisible);

        // Update preview instantly
        syncPreviewLayout();

        // Persist to server
        saveLayout();
      });

    });

    // ----- HEADER IMAGE UPLOAD (matches /cover route) -----
    const headerInput = document.getElementById('header_image');
    const headerBtn = document.getElementById('pe-upload-header-btn');

    if (headerBtn && headerInput) {
      headerBtn.addEventListener('click', async () => {
        if (!headerInput.files || !headerInput.files.length) {
          alert('Pick an image first.');
          return;
        }

        const file = headerInput.files[0];
        const formData = new FormData();
        // field name must match multer.single('cover')
        formData.append('cover', file);

        try {
          const res = await fetch('/dashboard/api/profile/cover', {
            method: 'POST',
            body: formData
          });
          const data = await res.json();
          if (!data.ok) {
            alert(data.error || 'Failed to upload header image');
            return;
          }

          if (previewRoot) {
            let img = previewRoot.querySelector('.pc-hero-media');
            if (!img) {
              const hero = previewRoot.querySelector('.pc-hero');
              if (hero) {
                img = document.createElement('img');
                img.className = 'pc-hero-media';
                img.alt = '';
                hero.insertBefore(img, hero.firstChild);
              }
            }
            if (img && data.cover_image_url) {
              img.src = data.cover_image_url;
            }
          }
        } catch (err) {
          console.error('Failed to upload header image', err);
          alert('Error uploading header image');
        }
      });
    }

    // ----- THEME PICKER -----
    const themeStatus = document.getElementById('pe-theme-status');
    const themeButtons = document.querySelectorAll('.pe-theme-swatch');

    function setThemeStatus(msg, isError) {
      if (!themeStatus) return;
      themeStatus.textContent = msg || '';
      themeStatus.classList.toggle('pe-status-error', !!isError);
    }

    function applyThemeToPreview(theme) {
      if (!previewRoot) return;
      const card = previewRoot.querySelector('.pc-card-root');
      if (!card) return;

      // Match the classes used by the card partial + CSS
      card.classList.remove('pc-theme-midnight', 'pc-theme-neon');

      const safe = theme === 'neon' ? 'neon' : 'midnight';
      card.classList.add('pc-theme-' + safe);

      if (rootEl) {
        rootEl.dataset.theme = safe;
      }
    }




    async function saveTheme(theme) {
      const safe = theme === 'neon' ? 'neon' : 'midnight';
      setThemeStatus('Saving...');

      try {
        const res = await fetch('/dashboard/api/profile/appearance', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ theme: safe })
        });
        const data = await res.json();
        if (!data.ok) {
          setThemeStatus(data.error || 'Failed to save theme', true);
        } else {
          setThemeStatus('Theme saved');
          applyThemeToPreview(safe);
        }
      } catch (err) {
        console.error('Failed to save theme', err);
        setThemeStatus('Error saving theme', true);
      }
    }

    // initialise theme buttons
    themeButtons.forEach((btn) => {
      const theme = btn.dataset.theme;
      if (!theme) return;

      if (theme === (initialTheme || 'midnight')) {
        btn.classList.add('pe-theme-swatch-active');
      }

      btn.addEventListener('click', () => {
        themeButtons.forEach(b => b.classList.remove('pe-theme-swatch-active'));
        btn.classList.add('pe-theme-swatch-active');
        saveTheme(theme);
      });
    });

        // Make sure preview reflects initial theme on load
    applyThemeToPreview(initialTheme || 'midnight');

    // Enable drag & drop reordering for buttons
    initSortable();

    // Initial sync
    syncPreviewBasics();
    syncPreviewFromList();
    syncPreviewLayout();
  })();
</script>

