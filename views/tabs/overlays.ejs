<div class="pc-page">
  <!-- Header Panel -->
  <div class="pc-panel mb-6">
    <div class="pc-panel-bd flex justify-between items-center">
      <div>
        <h2 class="text-xl font-bold text-white">Overlays</h2>
        <p class="pc-text-muted mt-1 text-sm">Manage your browser source overlays</p>
      </div>
      <a href="/dashboard/overlays/new" class="pc-btn pc-btn--primary">
        New Overlay
      </a>
    </div>
  </div>

  <!-- Overlays List -->
  <div class="pc-panel mb-6">
    <div class="pc-panel-hd">
      <div>
        <div class="pc-panel-title">Your Overlays</div>
      </div>
    </div>
    <div class="pc-panel-bd">
      <% if (overlays.length> 0) { %>
        <div class="pc-oled overflow-hidden">
          <table class="w-full text-left text-xs">
            <thead>
              <tr class="bg-white/5 text-white/40 border-b border-white/5">
                <th class="p-3">Name</th>
                <th class="p-3">Slug</th>
                <th class="p-3">Public URL</th>
                <th class="p-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <% overlays.forEach(function(ov) { %>
                <tr class="hover:bg-white/5 group">
                  <td class="p-3 font-bold text-white">
                    <%= ov.name %>
                  </td>
                  <td class="p-3 font-mono text-cyan-300">
                    <%= ov.slug %>
                  </td>
                  <td class="p-3 text-white/50 font-mono text-[10px]">
                    /o/<%= ov.public_id %>
                  </td>
                  <td class="p-3 text-right space-x-2">
                    <a href="/dashboard/overlays/<%= ov.id %>/edit"
                      class="pc-btn pc-btn--ghost h-7 px-2 text-[10px]">Edit</a>
                    <a href="/o/<%= ov.public_id %>" target="_blank"
                      class="pc-btn pc-btn--ghost h-7 px-2 text-[10px]">Preview</a>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
          <div class="text-center py-8">
            <div class="pc-text-muted">No overlays found. Create one above!</div>
          </div>
          <% } %>
    </div>
  </div>

  <!-- Templates List -->
  <div class="pc-panel">
    <div class="pc-panel-hd">
      <div>
        <div class="pc-panel-title">Lower Third Templates</div>
        <div class="pc-panel-sub">Saved designs for your broadcast</div>
      </div>
    </div>

    <div class="pc-panel-bd">
      <% if (locals.templates && templates.length> 0) { %>
        <div class="pc-oled overflow-hidden">
          <table class="w-full text-left text-xs">
            <thead>
              <tr class="bg-white/5 text-white/40 border-b border-white/5">
                <th class="p-3">Name</th>
                <th class="p-3">Created</th>
                <th class="p-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <% templates.forEach(function(tmpl) { %>
                <tr class="hover:bg-white/5" id="template-row-<%= tmpl.id %>">
                  <td class="p-3 font-bold text-white">
                    <%= tmpl.name %>
                  </td>
                  <td class="p-3 text-white/50">
                    <%= new Date(tmpl.created_at).toLocaleDateString() %>
                  </td>
                  <td class="p-3 text-right space-x-2">
                    <button onclick="deleteTemplate('<%= tmpl.id %>')"
                      class="pc-btn pc-btn--ghost text-red-300 hover:text-red-200 h-7 px-2 text-[10px]">Delete</button>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
          <div class="text-center py-8">
            <div class="pc-text-muted">No templates found. Open an overlay editor to save one!</div>
          </div>
          <% } %>
    </div>
  </div>
</div>

<script>
  async function deleteTemplate(id) {
    if (!confirm("Are you sure you want to delete this template?")) return;

    try {
      const res = await fetch(`/dashboard/api/lower-third-templates/${id}`, {
        method: "DELETE"
      });

      if (res.ok) {
        const row = document.getElementById(`template-row-${id}`);
        if (row) row.remove();
      } else {
        const data = await res.json().catch(() => ({}));
        alert(data.error || "Failed to delete template");
      }
    } catch (err) {
      console.error(err);
      alert("Error deleting template");
    }
  }
</script>