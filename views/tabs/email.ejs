<%
  const overview =
    (typeof emailOverview !== 'undefined' && emailOverview) ? emailOverview : {};

  const tmplCounts =
    (typeof emailTemplateCounts !== 'undefined' && emailTemplateCounts) ? emailTemplateCounts : {};

  const campCounts =
    (typeof emailCampaignCounts !== 'undefined' && emailCampaignCounts) ? emailCampaignCounts : {};

  const isProSafe = (typeof isPro !== 'undefined' && !!isPro);
  const userSafe = (typeof user !== 'undefined' && user) ? user : null;

  const emailSettingsSafe =
    (typeof emailSettings !== 'undefined' && emailSettings) ? emailSettings : null;

  const emailCampaignsSafe =
    (typeof emailCampaigns !== 'undefined' && Array.isArray(emailCampaigns)) ? emailCampaigns : [];

  const systemTemplatesSafe =
    (typeof systemTemplates !== 'undefined' && Array.isArray(systemTemplates)) ? systemTemplates : [];

  const userTemplatesSafe =
    (typeof userTemplates !== 'undefined' && Array.isArray(userTemplates)) ? userTemplates : [];

  const emailSubscribersSafe =
    (typeof emailSubscribers !== 'undefined' && Array.isArray(emailSubscribers)) ? emailSubscribers : [];

  const subscribersStatusSafe =
    (typeof subscribersStatus === 'string' && subscribersStatus) ? subscribersStatus : 'active';

  const subscribersSearchSafe =
    (typeof subscribersSearch === 'string') ? subscribersSearch : '';

  const fmtInt = (v) => {
    const n = Number(v ?? 0);
    return Number.isFinite(n) ? n.toLocaleString() : '0';
  };

  function fmtDate(d) {
    if (!d) return '—';
    try {
      const date = new Date(d);
      if (isNaN(date.getTime())) return '—';
      return date.toLocaleString('en-GB', { hour12: false });
    } catch (e) {
      return String(d);
    }
  }

  function fmtShort(d) {
    if (!d) return '—';
    try {
      const date = new Date(d);
      if (isNaN(date.getTime())) return '—';
      return date.toLocaleDateString('en-GB');
    } catch (e) {
      return '—';
    }
  }
%>

<div id="email-root" class="w-full px-6 py-8" data-is-pro="<%= isProSafe ? 'true' : 'false' %>">

  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold">Email</h1>
      <p class="text-sm text-gray-400 mt-1">
        Subscribers, go-live automation, templates, and campaigns.
      </p>
    </div>

    <div class="flex items-center gap-3 text-sm">
      <div class="text-xs text-gray-500 text-right">
        <div>
          Logged in as <span class="text-gray-200 font-semibold"><%= userSafe?.username || '—' %></span>
        </div>
        <div class="mt-1">
          <% if (isProSafe) { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-300 border border-emerald-500/40">Pro</span>
          <% } else { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-800 text-gray-300 border border-gray-700">Free</span>
          <% } %>
        </div>
      </div>

      <a href="/dashboard/email" class="border border-gray-800 bg-gray-950 hover:bg-gray-800 rounded px-4 py-2 text-sm shadow">
        Refresh
      </a>
    </div>
  </div>

  <section class="mt-6 border border-gray-800 rounded-2xl bg-gray-900 shadow p-5">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="border border-gray-800 rounded-xl bg-gray-950/40 p-4">
        <div class="text-xs uppercase tracking-wide text-gray-500">Total contacts</div>
        <div class="mt-2 text-2xl font-semibold text-white"><%= fmtInt(overview.totalSubscribers) %></div>
      </div>

      <div class="border border-gray-800 rounded-xl bg-gray-950/40 p-4">
        <div class="text-xs uppercase tracking-wide text-gray-500">Active contacts</div>
        <div class="mt-2 text-2xl font-semibold text-white"><%= fmtInt(overview.activeSubscribers) %></div>
      </div>

      <div class="border border-gray-800 rounded-xl bg-gray-950/40 p-4">
        <div class="text-xs uppercase tracking-wide text-gray-500">Last email sent</div>
        <div class="mt-3 text-sm text-gray-200"><%= fmtDate(overview.lastSendAt) %></div>
      </div>

      <div class="border border-gray-800 rounded-xl bg-gray-950/40 p-4">
        <div class="text-xs uppercase tracking-wide text-gray-500">Go-live emails this month</div>
        <div class="mt-2 text-2xl font-semibold text-white"><%= fmtInt(overview.goLiveThisMonth) %></div>
      </div>
    </div>
  </section>

  <!-- Tabs bar (matches dashboard-email.js class toggles) -->
  <div class="mt-6 border-b border-gray-800 flex items-center gap-6">
    <button type="button"
      class="py-3 -mb-px border-b-2 border-emerald-500 text-emerald-300 font-medium"
      data-email-tab="overview"
      aria-selected="true">Overview</button>

    <button type="button"
      class="py-3 -mb-px border-b-2 border-transparent text-gray-400 hover:text-gray-200"
      data-email-tab="templates"
      aria-selected="false">Templates</button>

    <button type="button"
      class="py-3 -mb-px border-b-2 border-transparent text-gray-400 hover:text-gray-200"
      data-email-tab="campaigns"
      aria-selected="false">Campaigns</button>

    <button type="button"
      class="py-3 -mb-px border-b-2 border-transparent text-gray-400 hover:text-gray-200"
      data-email-tab="subscribers"
      aria-selected="false">Subscribers</button>
  </div>

  <!-- OVERVIEW -->
  <section class="mt-6" data-email-panel="overview">
    <div class="border border-gray-800 rounded-2xl bg-gray-900 shadow p-5">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold">Go-live email</h2>
          <p class="text-sm text-gray-400 mt-1">
            Automatically email your list when you go live on Kick.
          </p>
        </div>

        <button type="submit" form="go-live-settings-form"
          class="bg-blue-600 hover:bg-blue-700 text-white rounded px-4 py-2 text-sm shadow">
          Save
        </button>
      </div>

      <div class="mt-4 border border-gray-800 rounded-xl bg-gray-950/40 p-4">
        <form id="go-live-settings-form" method="POST" action="/dashboard/api/email/settings" class="flex flex-col gap-2">
          <label class="flex items-center gap-3 text-sm text-gray-200 cursor-pointer select-none">
            <input type="checkbox" name="go_live_email_kick_enabled" value="1" class="h-5 w-5"
              <%= emailSettingsSafe?.go_live_email_kick_enabled ? 'checked' : '' %> />
            <span>Email my list when I go live on Kick</span>
          </label>

          <div class="text-xs text-gray-500">
            Last go-live email: <span class="text-gray-300"><%= fmtDate(emailSettingsSafe?.last_go_live_email_at) %></span>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- TEMPLATES -->
  <section class="mt-6" data-email-panel="templates" hidden>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="border border-gray-800 rounded-2xl bg-gray-900 shadow p-5">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-bold">System templates</h2>
          <div class="text-xs text-gray-500"><%= fmtInt(tmplCounts.systemTemplates || 0) %></div>
        </div>

        <div class="mt-4 border border-gray-800 rounded-xl bg-gray-950/40 overflow-hidden">
          <div class="px-4 py-3 border-b border-gray-800 text-xs uppercase tracking-wide text-gray-500">Templates</div>
          <div class="divide-y divide-gray-800">
            <% if (!systemTemplatesSafe.length) { %>
              <div class="px-4 py-4 text-sm text-gray-500">No system templates.</div>
            <% } else { %>
              <% systemTemplatesSafe.forEach((t) => { %>
                <div class="px-4 py-3 flex items-center justify-between">
                  <div>
                    <div class="text-sm font-medium text-gray-100"><%= t.name %></div>
                    <div class="text-xs text-gray-500"><%= t.kind %> • Updated <%= fmtShort(t.updated_at || t.created_at) %></div>
                  </div>
                  <button class="border border-gray-800 bg-gray-950 hover:bg-gray-800 rounded px-3 py-1.5 text-xs shadow"
                    data-template-view="true" data-template-id="<%= t.id %>">
                    View
                  </button>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      </div>

      <div class="border border-gray-800 rounded-2xl bg-gray-900 shadow p-5">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-bold">Your templates</h2>
          <div class="text-xs text-gray-500"><%= fmtInt(tmplCounts.userTemplates || 0) %></div>
        </div>

        <% if (!isProSafe) { %>
          <div class="mt-3 text-sm text-amber-300">Custom templates are Pro-only.</div>
        <% } %>

        <div class="mt-4 border border-gray-800 rounded-xl bg-gray-950/40 overflow-hidden">
          <div class="px-4 py-3 border-b border-gray-800 text-xs uppercase tracking-wide text-gray-500">Templates</div>
          <div class="divide-y divide-gray-800">
            <% if (!userTemplatesSafe.length) { %>
              <div class="px-4 py-4 text-sm text-gray-500">No custom templates yet.</div>
            <% } else { %>
              <% userTemplatesSafe.forEach((t) => { %>
                <div class="px-4 py-3 flex items-center justify-between">
                  <div>
                    <div class="text-sm font-medium text-gray-100"><%= t.name %></div>
                    <div class="text-xs text-gray-500"><%= t.kind %> • Updated <%= fmtShort(t.updated_at || t.created_at) %></div>
                  </div>
                  <button class="border border-gray-800 bg-gray-950 hover:bg-gray-800 rounded px-3 py-1.5 text-xs shadow"
                    data-template-view="true" data-template-id="<%= t.id %>">
                    View
                  </button>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CAMPAIGNS -->
  <section class="mt-6" data-email-panel="campaigns" hidden>
    <%
      const campaigns = emailCampaignsSafe;
    %>

    <div class="border border-gray-800 rounded-2xl bg-gray-900 shadow p-5">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-xl font-bold">Campaigns</h2>
          <p class="text-sm text-gray-400 mt-1">One-off blasts to your list (Pro).</p>
        </div>
        <div class="text-xs text-gray-500">
          <span class="text-gray-200 font-semibold"><%= fmtInt(campCounts.totalCampaigns || 0) %></span> total
        </div>
      </div>

      <div class="mt-4 border border-gray-800 rounded-xl bg-gray-950/40 overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-800 text-xs uppercase tracking-wide text-gray-500">Recent campaigns</div>
        <div class="divide-y divide-gray-800">
          <% if (!campaigns.length) { %>
            <div class="px-4 py-4 text-sm text-gray-500">No campaigns yet.</div>
          <% } else { %>
            <% campaigns.forEach((c) => { %>
              <div class="px-4 py-3 flex items-center justify-between">
                <div>
                  <div class="text-sm font-medium text-gray-100"><%= c.name %></div>
                  <div class="text-xs text-gray-500">Status: <%= c.status %> • Created <%= fmtShort(c.created_at) %></div>
                </div>
                <div class="text-xs text-gray-500">
                  Recipients: <span class="text-gray-200"><%= fmtInt(c.total_recipients || 0) %></span>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- SUBSCRIBERS -->
  <section class="mt-6" data-email-panel="subscribers" hidden>
    <div class="border border-gray-800 rounded-2xl bg-gray-900 shadow p-5">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold">Subscribers</h2>
          <p class="text-sm text-gray-400 mt-1">Showing up to 500 most recent.</p>
        </div>

        <a
          href="/dashboard/api/email/subscribers/export"
          class="border border-gray-800 bg-gray-950 hover:bg-gray-800 rounded px-4 py-2 text-sm shadow"
          data-pro-only="true"
        >
          Export CSV
          <% if (!isProSafe) { %><span class="ml-1 text-[10px] uppercase tracking-wide">Pro</span><% } %>
        </a>
      </div>

      <div class="mt-4 border border-gray-800 rounded-xl bg-gray-950/40 overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-800 text-xs uppercase tracking-wide text-gray-500">List</div>
        <div class="divide-y divide-gray-800">
          <% if (!emailSubscribersSafe.length) { %>
            <div class="px-4 py-4 text-sm text-gray-500">No subscribers yet.</div>
          <% } else { %>
            <% emailSubscribersSafe.forEach((s) => { %>
              <div class="px-4 py-3 flex items-center justify-between">
                <div class="text-sm text-gray-100"><%= s.email %></div>
                <div class="text-xs text-gray-500">
                  <%= s.unsubscribed ? 'Unsubscribed' : 'Active' %> • <%= fmtShort(s.created_at) %>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- Template modal (expected by dashboard-email.js) -->
  <div id="template-modal" class="hidden fixed inset-0 z-50" aria-hidden="true">
    <div id="template-modal-backdrop" class="absolute inset-0 bg-black/70"></div>
    <div class="relative mx-auto mt-16 w-[min(900px,95vw)] border border-gray-800 bg-gray-900 rounded-2xl shadow-lg overflow-hidden">
      <div class="flex items-center justify-between px-4 py-3 border-b border-gray-800">
        <div>
          <div id="template-modal-title" class="text-sm font-semibold text-white">Template</div>
          <div id="template-modal-meta" class="text-xs text-gray-500">—</div>
        </div>
        <button id="template-modal-close" class="border border-gray-800 bg-gray-950 hover:bg-gray-800 rounded px-3 py-1.5 text-xs shadow">Close</button>
      </div>

      <div class="p-4 space-y-3">
        <div class="border border-gray-800 rounded-xl bg-gray-950/40 p-3">
          <div class="text-[11px] uppercase tracking-wide text-gray-500">Subject</div>
          <div id="template-modal-subject" class="mt-1 text-sm text-gray-100">—</div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          <div class="border border-gray-800 rounded-xl bg-gray-950/40 p-3">
            <div class="text-[11px] uppercase tracking-wide text-gray-500">HTML</div>
            <pre id="template-modal-html" class="mt-2 text-xs text-gray-200 whitespace-pre-wrap break-words">—</pre>
          </div>

          <div class="border border-gray-800 rounded-xl bg-gray-950/40 p-3">
            <div class="text-[11px] uppercase tracking-wide text-gray-500">Text</div>
            <pre id="template-modal-text" class="mt-2 text-xs text-gray-200 whitespace-pre-wrap break-words">—</pre>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<script src="/js/dashboard-email.js"></script>
