<div class="max-w-5xl mx-auto px-4 py-8 space-y-8">

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white">Creator Earnings</h1>
      <p class="text-sm text-gray-400 mt-1">Track your income from TTS, marketplace sales, tips and more.</p>
    </div>
    <% if (!stripeOnboarded) { %>
      <form method="POST" action="/dashboard/earnings/stripe/connect">
        <button type="submit" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold transition-colors">
          Set up payouts
        </button>
      </form>
    <% } else { %>
      <span class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-green-600/20 border border-green-600/30 text-green-400 text-sm">
        <span class="w-2 h-2 rounded-full bg-green-400"></span>
        Stripe payouts active
      </span>
    <% } %>
  </div>

  <% if (stripeStatus === 'success') { %>
    <div class="p-4 rounded-lg bg-green-600/15 border border-green-600/30 text-green-300 text-sm">
      Stripe account connected. Verifying...
      <script>fetch('/dashboard/earnings/stripe/verify',{method:'POST',credentials:'include'}).then(r=>r.json()).then(d=>{if(d.onboarded)location.reload()});</script>
    </div>
  <% } %>
  <% if (stripeStatus === 'error') { %>
    <div class="p-4 rounded-lg bg-red-600/15 border border-red-600/30 text-red-300 text-sm">Could not connect Stripe account. Please try again.</div>
  <% } %>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <div class="text-xs text-gray-500 uppercase tracking-widest mb-1">All time</div>
      <div class="text-3xl font-bold text-white">$<%= (totalNetCents/100).toFixed(2) %></div>
      <div class="text-xs text-gray-500 mt-1">net after platform fee</div>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <div class="text-xs text-gray-500 uppercase tracking-widest mb-1">This month</div>
      <div class="text-3xl font-bold text-white">$<%= (monthNetCents/100).toFixed(2) %></div>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <div class="text-xs text-gray-500 uppercase tracking-widest mb-1">Pending payout</div>
      <div class="text-3xl font-bold <%= pendingCents > 0 ? 'text-yellow-400' : 'text-gray-400' %>">$<%= (pendingCents/100).toFixed(2) %></div>
      <% if (!stripeOnboarded && pendingCents > 0) { %><div class="text-xs text-yellow-500 mt-1">Set up payouts to receive funds</div><% } %>
    </div>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-800">
      <h2 class="text-sm font-semibold text-white">Marketplace Listings</h2>
      <a href="/dashboard/overlays" class="text-xs text-indigo-400 hover:text-indigo-300">Publish an overlay →</a>
    </div>
    <% if (!listings || listings.length === 0) { %>
      <div class="px-5 py-8 text-center text-gray-500 text-sm">No marketplace listings yet. <a href="/dashboard/overlays" class="text-indigo-400 hover:text-indigo-300">Publish your first overlay</a></div>
    <% } else { %>
      <table class="w-full text-sm">
        <thead><tr class="text-xs text-gray-500 border-b border-gray-800">
          <th class="px-5 py-3 text-left">Overlay</th><th class="px-5 py-3 text-left">Price</th><th class="px-5 py-3 text-left">Status</th><th class="px-5 py-3 text-left">Published</th>
        </tr></thead>
        <tbody>
          <% listings.forEach(function(l){ %>
            <tr class="border-b border-gray-800/50 hover:bg-gray-800/30">
              <td class="px-5 py-3 text-white"><%= l.title||l.overlay_name %></td>
              <td class="px-5 py-3 text-gray-300"><%= l.price_cents===0?'Free':'$'+(l.price_cents/100).toFixed(2) %></td>
              <td class="px-5 py-3"><span class="px-2 py-0.5 rounded text-xs font-semibold <%= l.status==='published'?'bg-green-600/20 text-green-400':'bg-gray-700 text-gray-400' %>"><%= l.status %></span></td>
              <td class="px-5 py-3 text-gray-400 text-xs"><%= l.published_at?new Date(l.published_at).toLocaleDateString():'—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-800"><h2 class="text-sm font-semibold text-white">Transaction History</h2></div>
    <% if (!transactions||transactions.length===0) { %>
      <div class="px-5 py-8 text-center text-gray-500 text-sm">No transactions yet.</div>
    <% } else { %>
      <table class="w-full text-sm">
        <thead><tr class="text-xs text-gray-500 border-b border-gray-800">
          <th class="px-5 py-3 text-left">Date</th><th class="px-5 py-3 text-left">Source</th><th class="px-5 py-3 text-left">Description</th><th class="px-5 py-3 text-right">Net</th><th class="px-5 py-3 text-left">Status</th>
        </tr></thead>
        <tbody>
          <% transactions.forEach(function(t){ %>
            <tr class="border-b border-gray-800/50 hover:bg-gray-800/30">
              <td class="px-5 py-3 text-gray-400 text-xs"><%= new Date(t.created_at).toLocaleDateString() %></td>
              <td class="px-5 py-3"><span class="px-2 py-0.5 rounded text-xs font-semibold bg-indigo-600/20 text-indigo-300 capitalize"><%= (t.source||'').replace(/_/g,' ') %></span></td>
              <td class="px-5 py-3 text-gray-300 text-xs"><%= t.description||'—' %></td>
              <td class="px-5 py-3 text-right font-mono text-white">$<%= (t.net_cents/100).toFixed(2) %></td>
              <td class="px-5 py-3"><span class="text-xs <%= t.status==='paid'?'text-green-400':t.status==='pending'?'text-yellow-400':'text-red-400' %>"><%= t.status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

</div>
