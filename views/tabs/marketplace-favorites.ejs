<div class="max-w-7xl mx-auto px-4 py-8">

  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-white">My Favorites</h1>
      <p class="text-gray-400 mt-1 text-sm">Overlays you've saved for later.</p>
    </div>
    <a href="/marketplace/" class="px-4 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-semibold transition-colors">
      ← Browse Marketplace
    </a>
  </div>

  <% if (!favorites || favorites.length === 0) { %>
    <div class="text-center py-24 text-gray-500">
      <div class="text-5xl mb-4">♡</div>
      <div class="text-lg font-semibold text-gray-400">No favorites yet</div>
      <p class="text-sm mt-2">Start exploring the marketplace and save overlays you like!</p>
      <a href="/marketplace/" class="mt-4 inline-block px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold">Browse Marketplace</a>
    </div>
  <% } else { %>
    <div class="mb-4 text-sm text-gray-400">
      <%= favorites.length %> <%= favorites.length === 1 ? 'favorite' : 'favorites' %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% favorites.forEach(function(l) { %>
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-gray-700 transition-colors group">
          <!-- Thumbnail -->
          <div class="aspect-video bg-gray-800 relative overflow-hidden">
            <% if (l.thumbnail_path) { %>
              <img src="<%= l.thumbnail_path %>" alt="<%= l.title %>" class="w-full h-full object-cover" />
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="w-12 h-12 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
              </div>
            <% } %>
            <a href="/marketplace/<%= l.id %>"
               class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 text-white text-sm font-semibold">
              View listing ↗
            </a>
            
            <!-- Stats badges -->
            <div class="absolute top-2 right-2 flex flex-col gap-1">
              <button 
                onclick="removeFavorite(<%= l.id %>, this, event)"
                class="px-2 py-1 rounded-lg bg-black/60 backdrop-blur-sm hover:bg-black/80 text-red-400 hover:text-gray-300 text-lg font-semibold transition-colors"
                title="Remove from favorites"
              >
                ♥
              </button>
              <% if (l.average_rating) { %>
                <span class="px-2 py-1 rounded-lg bg-black/60 backdrop-blur-sm text-yellow-400 text-xs font-semibold flex items-center gap-1">
                  ★ <%= Number(l.average_rating).toFixed(1) %>
                </span>
              <% } %>
              <% if (l.acquisition_count > 0) { %>
                <span class="px-2 py-1 rounded-lg bg-black/60 backdrop-blur-sm text-gray-300 text-xs font-semibold">
                  <%= l.acquisition_count %> ↓
                </span>
              <% } %>
            </div>
          </div>

          <div class="p-4">
            <div class="flex items-start justify-between gap-2">
              <div class="flex-1 min-w-0">
                <a href="/marketplace/<%= l.id %>" class="font-semibold text-white text-sm hover:text-indigo-300 transition-colors block truncate"><%= l.title %></a>
                <p class="text-xs text-gray-500 mt-0.5">by <%= l.creator_username %></p>
                <% if (l.category) { %>
                  <span class="inline-block mt-1 px-2 py-0.5 rounded text-xs bg-gray-800 text-gray-400"><%= l.category %></span>
                <% } %>
              </div>
              <span class="text-sm font-bold <%= l.price_cents === 0 ? 'text-green-400' : 'text-white' %> shrink-0">
                <%= l.price_cents === 0 ? 'Free' : '$' + (l.price_cents/100).toFixed(2) %>
              </span>
            </div>

            <% if (l.description) { %>
              <p class="text-xs text-gray-400 mt-2 line-clamp-2"><%= l.description %></p>
            <% } %>

            <div class="mt-4">
              <% if (l.price_cents === 0) { %>
                <button
                  onclick="acquireOverlay(<%= l.id %>, this)"
                  class="w-full py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold transition-colors">
                  Get this free
                </button>
              <% } else { %>
                <button class="w-full py-2 rounded-lg bg-amber-600/20 border border-amber-500/30 text-amber-300 text-xs font-semibold cursor-not-allowed opacity-60">
                  Paid — coming soon
                </button>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</div>

<script>
async function removeFavorite(listingId, btn, event) {
  event.preventDefault();
  event.stopPropagation();
  
  if (!confirm('Remove from favorites?')) return;
  
  btn.disabled = true;
  
  try {
    const r = await fetch('/dashboard/api/marketplace/' + listingId + '/favorite', {
      method: 'POST',
      credentials: 'include'
    });
    const d = await r.json();
    
    if (d.ok) {
      // Remove the card from view
      btn.closest('.group').remove();
      
      // Check if empty
      const grid = document.querySelector('.grid');
      if (grid && grid.children.length === 0) {
        location.reload();
      }
    } else {
      alert('Error: ' + d.error);
      btn.disabled = false;
    }
  } catch (e) {
    alert('Failed to remove favorite');
    btn.disabled = false;
  }
}

async function acquireOverlay(listingId, btn) {
  btn.disabled = true;
  btn.textContent = 'Adding...';
  try {
    const r = await fetch('/dashboard/api/marketplace/acquire/' + listingId, { method: 'POST', credentials: 'include' });
    const d = await r.json();
    if (d.ok) {
      btn.textContent = '✓ Added!';
      btn.className = btn.className.replace('bg-indigo-600', 'bg-green-600');
      setTimeout(() => { window.location.href = d.editUrl; }, 800);
    } else {
      btn.textContent = 'Error: ' + d.error;
      btn.disabled = false;
    }
  } catch(e) {
    btn.textContent = 'Failed';
    btn.disabled = false;
  }
}
</script>
