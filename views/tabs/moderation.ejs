<div class="w-full px-6 py-8">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold font-display tracking-tight">Scrapbot Moderation</h1>
      <p class="pc-text-muted mt-1 text-sm">
        Rules, flood protection, testing — plus Shield Guard for swarm spam.
      </p>
    </div>

    <div class="flex items-center gap-2">
      <label class="text-sm pc-text-muted">Platform</label>
      <select id="m_platform" class="pc-select text-sm" style="width:auto;">
        <option value="kick">Kick</option>
      </select>
    </div>
  </div>

  <!-- SHIELD GUARD -->
  <div class="pc-panel mb-8">
    <div class="pc-panel-hd">
      <div>
        <div class="pc-panel-title flex items-center gap-2">
          <span>🛡 Shield Guard</span>
          <span id="m_shield_status_badge" class="pc-chip">Loading…</span>
        </div>
        <div class="pc-panel-sub">
          Summarizes swarm spam incidents & hot signatures without streaming chat logs.
        </div>
      </div>
      <div>
        <button id="m_shield_refresh" class="pc-btn pc-btn--ghost">
          Refresh
        </button>
      </div>
    </div>

    <div class="pc-panel-bd">
      <!-- Signals row -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="pc-panel">
          <div class="pc-panel-bd">
            <div class="flex items-center justify-between mb-2">
              <div class="font-bold text-white">Recent incidents</div>
              <div class="text-xs text-white/50">Low-volume snapshots</div>
            </div>

            <div id="m_incidents_empty" class="text-sm pc-text-muted hidden">No incidents yet.</div>
            <div id="m_incidents_list" class="space-y-2"></div>
          </div>
        </div>

        <div class="pc-panel">
          <div class="pc-panel-bd">
            <div class="flex items-center justify-between mb-2">
              <div class="font-bold text-white">Hot signatures (global)</div>
              <div class="text-xs text-white/50">Trending spam patterns</div>
            </div>

            <div id="m_hot_empty" class="text-sm pc-text-muted hidden">No hot signatures right now.</div>
            <div id="m_hot_list" class="space-y-2"></div>
          </div>
        </div>

        <div class="lg:col-span-2 text-xs text-white/40" id="m_shield_status_line"></div>
      </div>

      <!-- Intensity -->
      <div class="pc-panel mt-6">
        <div class="pc-panel-bd">
          <div class="flex items-center justify-between">
            <div class="font-semibold">Intensity</div>
            <div class="text-sm">
              <span class="pc-text-muted">Preset:</span>
              <span id="m_guard_intensity_label" class="font-semibold">Balanced</span>
            </div>
          </div>

          <div class="mt-3">
            <input id="m_guard_intensity" type="range" min="0" max="4" step="1" value="1" class="guard-slider w-full">
            <div class="mt-2 relative w-full h-4 text-xs pc-text-muted">
              <span class="absolute top-0 transform -translate-x-1/2 pointer-events-auto cursor-help" style="left: 2%;"
                title="Shield: 8 users, 10 repeats, 12s window. Action: 30s timeout.&#10;Flood: 8 msgs / 10s. Action: 10s timeout.">Lite</span>
              <span class="absolute top-0 transform -translate-x-1/2 pointer-events-auto cursor-help" style="left: 25%;"
                title="Shield: 6 users, 8 repeats, 10s window. Action: Ban.&#10;Flood: 5 msgs / 10s. Action: 30s timeout.">Balanced</span>
              <span class="absolute top-0 transform -translate-x-1/2 pointer-events-auto cursor-help" style="left: 50%;"
                title="Shield: 5 users, 7 repeats, 8s window. Action: Ban.&#10;Flood: 4 msgs / 8s. Action: 60s timeout.">Strong</span>
              <span class="absolute top-0 transform -translate-x-1/2 pointer-events-auto cursor-help" style="left: 75%;"
                title="Shield: 4 users, 6 repeats, 6s window. Action: Ban.&#10;Flood: 3 msgs / 6s. Action: 120s timeout.">Heavy</span>
              <span class="absolute top-0 transform -translate-x-1/2 pointer-events-auto cursor-help" style="left: 98%;"
                title="Shield: 3 users, 5 repeats, 5s window. Action: Ban.&#10;Flood: 2 msgs / 5s. Action: Ban.">Nuclear</span>
            </div>

            <div class="mt-3 text-xs pc-text-muted">
              Automatically tunes Shield Guard + Flood protection. Changes apply instantly and are saved.
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- TABS -->
  <div class="mt-6 border-b border-white/10 flex items-center gap-6">
    <button
      class="py-3 border-b-2 border-transparent data-[active=true]:border-white text-white/70 data-[active=true]:text-white"
      data-tab="rules" data-active="true">Rules</button>
    <button
      class="py-3 border-b-2 border-transparent data-[active=true]:border-white text-white/70 data-[active=true]:text-white"
      data-tab="settings">Settings</button>
    <button
      class="py-3 border-b-2 border-transparent data-[active=true]:border-white text-white/70 data-[active=true]:text-white"
      data-tab="test">Test</button>
    <button
      class="py-3 border-b-2 border-transparent data-[active=true]:border-white text-white/70 data-[active=true]:text-white"
      data-tab="incidents">Incidents</button>
  </div>

  <!-- RULES -->
  <section class="mt-6" data-pane="rules">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl font-bold">Rules</h2>
        <p class="text-sm pc-text-muted mt-1">Use presets. Keep it simple — no SQL vibes.</p>
        <p class="text-xs text-white/40 mt-1">
          Rules run top → bottom. Put <span class="text-white font-semibold">Exception (ignore)</span> rules first.
        </p>
      </div>
      <button id="m_open_add_rule" class="pc-btn pc-btn--primary">
        Add rule
      </button>
    </div>

    <!-- QUICK TOGGLES -->
    <div class="pc-panel mb-6">
      <div class="pc-panel-hd">
        <div>
          <div class="pc-panel-title">Common protections</div>
          <div class="pc-panel-sub">
            One switch = one rule behind the scenes. Keep these on unless you’re deliberately allowing something.
          </div>
        </div>
        <div class="text-xs text-white/40">Rules-backed</div>
      </div>

      <div class="pc-panel-bd">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <label
            class="flex items-center justify-between gap-3 p-4 rounded bg-white/5 border border-white/5 cursor-pointer hover:bg-white/10 transition-colors">
            <div>
              <div class="font-bold text-white">Block links</div>
              <div class="text-xs text-white/50 mt-1">Blocks http/https/www + common obfuscations.</div>
            </div>
            <input id="m_quick_linkblock" type="checkbox" class="pc-toggle h-5 w-5">
          </label>

          <label
            class="flex items-center justify-between gap-3 p-4 rounded bg-white/5 border border-white/5 cursor-pointer hover:bg-white/10 transition-colors">
            <div>
              <div class="font-bold text-white">Caps spam</div>
              <div class="text-xs text-white/50 mt-1">Triggers when caps ratio is high on longer messages.</div>
            </div>
            <input id="m_quick_caps" type="checkbox" class="pc-toggle h-5 w-5">
          </label>
        </div>

        <div class="mt-4 text-xs text-white/40">
          Tip: Use <span class="text-white font-semibold">exception (ignore)</span> rules above punish rules to create
          safe exceptions.
        </div>
      </div>
    </div>

    <div class="mt-5 h-px w-full bg-white/10"></div>

    <div class="pc-panel">
      <div class="pc-panel-bd p-0 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-white/5 border-b border-white/5">
              <tr class="text-white/60">
                <th class="p-3 text-left">On</th>
                <th class="p-3 text-left">Preset</th>
                <th class="p-3 text-left">Match</th>
                <th class="p-3 text-left">
                  <div>Action</div>
                  <div class="text-[11px] text-white/40 font-normal mt-1">“ignore” = exception</div>
                </th>
                <th class="p-3 text-left"></th>
              </tr>
            </thead>
            <tbody id="m_rules_tbody" class="text-white"></tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="mt-4 flex items-center justify-between">
      <button id="m_toggle_advanced"
        class="text-xs pc-text-muted hover:text-white underline decoration-white/20 hover:decoration-white/50">
        Show advanced fields
      </button>

      <a href="#" id="m_jump_incidents"
        class="text-xs pc-text-muted hover:text-white underline decoration-white/20 hover:decoration-white/50">
        View outcomes →
      </a>
    </div>
  </section>

  <!-- SETTINGS -->
  <section class="mt-6 hidden" data-pane="settings">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl font-bold">Protections</h2>
        <p class="text-sm pc-text-muted mt-1">Slider-first controls. Advanced knobs are optional.</p>
      </div>

      <button id="m_save_settings" class="pc-btn pc-btn--primary">
        Save settings
      </button>
    </div>

    <!-- Two-column layout on xl: Shield tuning + Flood -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
      <!-- Shield Guard tuning -->
      <div class="pc-panel">
        <div class="pc-panel-hd">
          <div>
            <div class="pc-panel-title">🛡 Shield Guard tuning</div>
            <div class="pc-panel-sub">
              Detect “same message from many users” and react fast. Incidents are snapshots, not chat logs.
            </div>
          </div>

          <label class="flex items-center gap-2 text-sm text-white">
            <input id="m_swarm_enabled" type="checkbox" checked class="pc-toggle">
            Enabled
          </label>
        </div>

        <div class="pc-panel-bd space-y-5">
          <div>
            <div class="flex items-center justify-between">
              <label class="text-sm pc-text-muted">Window</label>
              <div class="text-xs pc-text-muted"><span id="m_swarm_window_seconds_label">10</span>s</div>
            </div>
            <input id="m_swarm_window_seconds" type="range" min="3" max="60" step="1" value="10" class="w-full mt-2">
            <div class="text-xs pc-text-muted mt-1">How far back we look when grouping matching messages.</div>
          </div>

          <div>
            <div class="flex items-center justify-between">
              <label class="text-sm pc-text-muted">Min unique users</label>
              <div class="text-xs pc-text-muted"><span id="m_swarm_min_unique_users_label">6</span></div>
            </div>
            <input id="m_swarm_min_unique_users" type="range" min="3" max="30" step="1" value="6" class="w-full mt-2">
            <div class="text-xs pc-text-muted mt-1">How many different accounts must post the same thing.</div>
          </div>

          <div>
            <div class="flex items-center justify-between">
              <label class="text-sm pc-text-muted">Min repeats per signature</label>
              <div class="text-xs pc-text-muted"><span id="m_swarm_min_repeats_label">8</span></div>
            </div>
            <input id="m_swarm_min_repeats" type="range" min="3" max="60" step="1" value="8" class="w-full mt-2">
            <div class="text-xs pc-text-muted mt-1">Total number of matching messages required to trigger.</div>
          </div>

          <div>
            <div class="flex items-center justify-between">
              <label class="text-sm pc-text-muted">Cooldown</label>
              <div class="text-xs pc-text-muted"><span id="m_swarm_cooldown_seconds_label">120</span>s</div>
            </div>
            <input id="m_swarm_cooldown_seconds" type="range" min="0" max="1800" step="30" value="120"
              class="w-full mt-2">
            <div class="text-xs pc-text-muted mt-1">Prevents repeated triggers on the same signature.</div>
          </div>

          <div>
            <label class="text-sm pc-text-muted">Default action</label>
            <select id="m_swarm_action" class="pc-select mt-2 w-full text-sm">
              <option value="ban">ban</option>
              <option value="timeout">timeout</option>
              <option value="none">none</option>
            </select>
            <div class="text-xs pc-text-muted mt-1">Recommended for bot swarms: ban.</div>
          </div>

          <div>

            <!-- Advanced shield knobs toggled below -->
            <button id="m_toggle_shield_advanced" class="text-xs pc-text-muted hover:text-white underline">
              Show advanced Shield knobs
            </button>

            <div id="m_shield_advanced_wrap" class="hidden p-4 rounded bg-white/5 border border-white/5">
              <div class="font-semibold">Advanced knobs</div>
              <div class="text-xs pc-text-muted mt-1">These increase detection quality. Defaults are safe.</div>

              <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="pc-panel">
                  <div class="pc-panel-bd">
                    <div class="font-semibold text-sm">Signature normalization</div>
                    <div class="text-xs pc-text-muted mt-1">Helps catch CAPs / punctuation variants without regex.</div>

                    <label class="mt-3 flex items-center gap-2 text-sm pc-text-muted">
                      <input id="m_sig_lowercase" type="checkbox" checked class="pc-toggle">
                      Lowercase
                    </label>
                    <label class="mt-2 flex items-center gap-2 text-sm pc-text-muted">
                      <input id="m_sig_strip_punct" type="checkbox" checked class="pc-toggle">
                      Strip punctuation
                    </label>
                    <label class="mt-2 flex items-center gap-2 text-sm pc-text-muted">
                      <input id="m_sig_collapse_ws" type="checkbox" checked class="pc-toggle">
                      Collapse whitespace
                    </label>
                    <label class="mt-2 flex items-center gap-2 text-sm pc-text-muted">
                      <input id="m_sig_strip_emojis" type="checkbox" class="pc-toggle">
                      Strip emojis
                    </label>
                  </div>
                </div>

                <div class="pc-panel">
                  <div class="pc-panel-bd">
                    <div class="font-semibold text-sm">Escalation</div>
                    <div class="text-xs pc-text-muted mt-1">If the same signature keeps coming back, go harder.</div>

                    <label class="mt-3 flex items-center gap-2 text-sm pc-text-muted">
                      <input id="m_swarm_escalate" type="checkbox" checked class="pc-toggle">
                      Escalate repeat offenders
                    </label>

                    <div class="mt-3">
                      <div class="flex items-center justify-between">
                        <label class="text-sm pc-text-muted">Repeat threshold</label>
                        <div class="text-xs pc-text-muted"><span id="m_swarm_escalate_repeat_threshold_label">2</span>
                        </div>
                      </div>
                      <input id="m_swarm_escalate_repeat_threshold" type="range" min="1" max="10" step="1" value="2"
                        class="w-full mt-2">
                      <div class="text-xs pc-text-muted mt-1">Number of incidents before escalating.</div>
                    </div>

                    <div class="mt-3">
                      <label class="text-sm pc-text-muted">Escalate action</label>
                      <select id="m_swarm_escalate_action" class="pc-select mt-2 w-full text-sm">
                        <option value="ban">ban</option>
                        <option value="timeout">timeout</option>
                        <option value="none">none</option>
                      </select>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="text-xs pc-text-muted" id="m_settings_status"></div>
          </div>
        </div>
      </div>

      <!-- Flood protection -->
      <div class="pc-panel mt-6">
        <div class="pc-panel-hd">
          <div>
            <div class="pc-panel-title">Flood protection (single user)</div>
            <div class="pc-panel-sub">Stops one user spamming many messages fast.</div>
          </div>
        </div>

        <div class="pc-panel-bd">
          <div class="text-xs text-white/40 mb-4">These controls generate internal rules automatically.</div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <label class="flex items-center gap-2 text-sm text-white">
              <input id="m_flood_enabled" type="checkbox" checked class="pc-toggle">
              Enable flood protection
            </label>
            <div></div>

            <div>
              <label class="text-sm pc-text-muted">Window (seconds)</label>
              <input id="m_flood_window_seconds" type="number" min="1" class="pc-input mt-1 w-full text-sm" value="10">
            </div>

            <div>
              <label class="text-sm pc-text-muted">Max messages (per user)</label>
              <input id="m_flood_max_messages" type="number" min="1" class="pc-input mt-1 w-full text-sm" value="5">
            </div>

            <div>
              <label class="text-sm pc-text-muted">Action</label>
              <select id="m_flood_action" class="pc-select mt-1 w-full text-sm">
                <option value="timeout">timeout</option>
                <option value="ban">ban</option>
                <option value="delete">delete</option>
                <option value="ignore">ignore</option>
                <option value="none">none</option>
              </select>
            </div>

            <div>
              <label class="text-sm pc-text-muted">Duration (seconds)</label>
              <input id="m_flood_duration_seconds" type="number" min="0" class="pc-input mt-1 w-full text-sm"
                value="30">
            </div>

            <label class="flex items-center gap-2 text-sm pc-text-muted">
              <input id="m_flood_escalate" type="checkbox" checked class="pc-toggle">
              Escalate on repeat spam
            </label>

            <div>
              <label class="text-sm pc-text-muted">Escalate multiplier</label>
              <input id="m_flood_escalate_multiplier" type="number" min="1" class="pc-input mt-1 w-full text-sm"
                value="2">
            </div>

            <div>
              <label class="text-sm pc-text-muted">Max duration (seconds)</label>
              <input id="m_flood_max_duration_seconds" type="number" min="0" class="pc-input mt-1 w-full text-sm"
                value="600">
            </div>

            <div>
              <label class="text-sm text-white">Cooldown (seconds)</label>
              <input id="m_flood_cooldown_seconds" type="number" min="0" class="pc-input mt-1 w-full text-sm"
                value="120">
            </div>
          </div>
        </div>
      </div>
  </section>

  <!-- TEST -->
  <section class="mt-6 hidden" data-pane="test">
    <h2 class="text-xl font-bold">Test</h2>

    <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="md:col-span-2">
        <label class="text-sm pc-text-muted">Message text</label>
        <textarea id="m_test_text" class="pc-input w-full mt-1 text-sm" rows="6"
          placeholder="Paste a message here...">TEST TEST TEST</textarea>
      </div>

      <div>
        <label class="text-sm pc-text-muted">Role</label>
        <select id="m_test_role" class="pc-select w-full mt-1 text-sm">
          <option value="everyone">everyone</option>
          <option value="mod">mod</option>
          <option value="broadcaster">broadcaster</option>
        </select>

        <div class="mt-3">
          <input id="m_test_sender" class="pc-input w-full text-sm" value="Tester">
        </div>

        <button id="m_run_test" class="pc-btn pc-btn--primary mt-4 w-full">
          Run test
        </button>
      </div>
    </div>

    <div class="mt-4">
      <label class="text-sm pc-text-muted">Result</label>
      <pre id="m_test_out" class="mt-2 pc-panel pc-panel-bd text-xs overflow-auto"></pre>
    </div>
  </section>

  <!-- INCIDENTS -->
  <section class="mt-6 hidden" data-pane="incidents">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl font-bold">Incidents</h2>
        <p class="text-sm pc-text-muted mt-1">Outcome snapshots. Raw logs are advanced/manual.</p>
      </div>

      <button id="m_refresh_incidents" class="pc-btn pc-btn--ghost">
        Refresh
      </button>
    </div>

    <div class="pc-panel mb-4">
      <div class="pc-panel-bd p-0 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-white/5 border-b border-white/5">
              <tr class="text-white/60">
                <th class="p-3 text-left">Time</th>
                <th class="p-3 text-left">Signature</th>
                <th class="p-3 text-left">Users</th>
                <th class="p-3 text-left">Window</th>
                <th class="p-3 text-left">
                  <div>Action</div>
                  <div class="text-[11px] text-white/40 font-normal mt-1">“ignore” = exception</div>
                </th>
                <th class="p-3 text-left"></th>
              </tr>
            </thead>
            <tbody id="m_incidents_tbody" class="text-white"></tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="mt-4 flex items-center justify-between">
      <div class="text-xs pc-text-muted" id="m_incidents_status"></div>

      <button id="m_toggle_activity_advanced"
        class="text-xs pc-text-muted hover:text-white underline decoration-white/20 hover:decoration-white/50">
        Show advanced raw activity
      </button>
    </div>

    <div id="m_activity_advanced_wrap" class="mt-4 hidden pc-panel">
      <div class="pc-panel-bd">
        <div class="flex items-center justify-between">
          <div>
            <div class="font-semibold">Advanced: Raw activity</div>
            <div class="text-xs pc-text-muted mt-1">Manual load. Not intended for day-to-day use.</div>
          </div>

          <div class="flex items-center gap-3 text-sm">
            <label class="flex items-center gap-2 pc-text-muted">
              <input type="checkbox" id="m_only_matched" class="pc-toggle">
              Only matches
            </label>
            <button id="m_refresh_activity" class="pc-btn pc-btn--ghost">
              Load activity
            </button>
          </div>
        </div>

        <div class="mt-3 pc-panel">
          <div class="pc-panel-bd p-0 overflow-hidden">
            <table class="w-full text-sm">
              <thead class="bg-white/5 border-b border-white/10">
                <tr class="text-white/60">
                  <th class="p-3 text-left">Time</th>
                  <th class="p-3 text-left">Sender</th>
                  <th class="p-3 text-left">Role</th>
                  <th class="p-3 text-left">Text</th>
                  <th class="p-3 text-left">Match</th>
                  <th class="p-3 text-left">
                    <div>Action</div>
                    <div class="text-[11px] text-white/40 font-normal mt-1">“ignore” = exception</div>
                  </th>
                </tr>
              </thead>
              <tbody id="m_activity_tbody" class="text-white"></tbody>
            </table>
          </div>
        </div>

        <div class="text-xs pc-text-muted mt-3" id="m_activity_status"></div>
      </div>
    </div>
  </section>
</div>

<!-- ADD RULE MODAL -->
<div id="m_add_rule_modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/60 p-4">
  <div class="w-full max-w-xl pc-panel shadow-2xl">
    <div class="pc-panel-hd">
      <div>
        <div class="pc-panel-title">Add rule</div>
        <div class="pc-panel-sub">Pick a preset. Keep it simple.</div>
      </div>
      <button id="m_close_add_rule" class="text-white/50 hover:text-white" type="button">✕</button>
    </div>

    <div class="pc-panel-bd space-y-4">
      <div>
        <label class="text-sm pc-text-muted">Preset</label>
        <select id="m_new_rule_preset" class="pc-select mt-1 w-full text-sm">
          <option value="contains">Block phrase</option>
          <option value="blacklist_word">Block word</option>
          <option value="link_posting">Block links</option>
