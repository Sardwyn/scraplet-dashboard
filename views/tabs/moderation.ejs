<!-- Fallback binder -->
<script>
  (() => {
    const openBtn = document.getElementById("m_open_add_rule");
    const modal = document.getElementById("m_add_rule_modal");
    const closeBtn = document.getElementById("m_close_add_rule");

    if (!openBtn || !modal) return;

    const open = () => {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
    };

    if (!openBtn.dataset.bound) {
      openBtn.addEventListener("click", (e) => { e.preventDefault(); open(); });
      openBtn.dataset.bound = "1";
    }

    if (closeBtn && !closeBtn.dataset.bound) {
      closeBtn.addEventListener("click", (e) => { e.preventDefault(); close(); });
      closeBtn.dataset.bound = "1";
    }

    modal.addEventListener("click", (e) => {
      if (e.target === modal) close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
    });
  })();
</script>

<script>
  (() => {
    // --- Modal guardrails ---
    const actionSel = document.getElementById("m_new_rule_action");
    const durInput = document.getElementById("m_new_rule_duration");
    const createBtn = document.getElementById("m_create_rule");
    const ignoreHint = document.getElementById("m_ignore_hint");

    const syncModalUI = () => {
      if (!actionSel) return;
      const action = (actionSel.value || "").toLowerCase();

      const durationRelevant = (action === "timeout");
      if (durInput) {
        durInput.disabled = !durationRelevant;
        durInput.classList.toggle("opacity-50", !durationRelevant);
        durInput.classList.toggle("cursor-not-allowed", !durationRelevant);
      }

      if (ignoreHint) {
        ignoreHint.classList.toggle("hidden", action !== "ignore");
      }

      if (createBtn) {
        const base = createBtn.getAttribute("data-default-text") || "Create rule";
        if (action === "ignore") createBtn.textContent = "Create exception rule";
        else if (action === "timeout") createBtn.textContent = "Create timeout rule";
        else if (action === "ban") createBtn.textContent = "Create ban rule";
        else if (action === "delete") createBtn.textContent = "Create delete rule";
        else if (action === "none") createBtn.textContent = "Create “none” rule";
        else createBtn.textContent = base;
      }
    };

    if (actionSel && !actionSel.dataset.boundPolish) {
      actionSel.addEventListener("change", syncModalUI);
      actionSel.dataset.boundPolish = "1";
      syncModalUI();
    }

    // --- Action badge styling ---
    const badgeFor = (actionText) => {
      const a = (actionText || "").trim().toLowerCase();
      const span = document.createElement("span");
      span.className = "m-badge";
      span.textContent = a;

      if (a === "ignore") { span.classList.add("m-badge--ignore"); span.textContent = "exception"; }
      else if (a === "timeout") span.classList.add("m-badge--timeout");
      else if (a === "ban") span.classList.add("m-badge--ban");
      else if (a === "delete") span.classList.add("m-badge--delete");
      else if (a === "none") span.classList.add("m-badge--none");

      return span;
    };

    const wrapActionCells = (tbodyId) => {
      const tb = document.getElementById(tbodyId);
      if (!tb) return;

      const apply = () => {
        const rows = tb.querySelectorAll("tr");
        rows.forEach((tr) => {
          const tds = Array.from(tr.querySelectorAll("td"));
          tds.forEach((td) => {
            if (td.dataset.badged) return;
            const raw = (td.textContent || "").trim().toLowerCase();
            if (!raw) return;

            const isAction = ["ignore", "timeout", "ban", "delete", "none"].includes(raw);
            if (!isAction) return;

            td.textContent = "";
            td.appendChild(badgeFor(raw));
            td.dataset.badged = "1";
          });
        });
      };

      apply();
      const mo = new MutationObserver(() => apply());
      mo.observe(tb, { childList: true, subtree: true });
    };

    wrapActionCells("m_rules_tbody");
    wrapActionCells("m_incidents_tbody");
    wrapActionCells("m_activity_tbody");
  })();
</script>