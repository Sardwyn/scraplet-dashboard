<!DOCTYPE html>
<html>
<head>
  <title>Unsubscribe Link Invalid</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body {
      font-family: system-ui, sans-serif;
      margin: 40px auto;
      max-width: 480px;
      padding: 0 20px;
      line-height: 1.5;
      color: #111;
    }
    .card {
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      padding: 24px;
    }
    h1 {
      margin-top: 0;
      color: #b30000;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>Link Invalid</h1>
    <p><%= reason %></p>
    <p>If you reached this in error, try unsubscribing again from the original email you received.</p>
  </div>
</body>
</html>
