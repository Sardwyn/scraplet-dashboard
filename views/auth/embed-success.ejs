<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Signing you in…</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      html,body{height:100%;margin:0}
      body{
        display:flex;
        align-items:center;
        justify-content:center;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        background:#0b0f14;
        color:rgba(255,255,255,.9)
      }
      .box{
        width:min(420px,92vw);
        padding:18px 16px;
        border:1px solid rgba(255,255,255,.12);
        background:rgba(255,255,255,.04);
        border-radius:12px;
      }
      .muted{
        color:rgba(255,255,255,.65);
        font-size:13px;
        margin-top:8px
      }
      a{color:#7dd3fc}
    </style>
  </head>

  <body>
    <div class="box">
      <div><strong>Signed in.</strong> Sending you to your dashboard…</div>
      <div class="muted">
        If nothing happens,
        <a href="/dashboard" target="_top" rel="noopener">continue</a>.
      </div>
    </div>

    <script>
      (function () {
        // 🔒 Only allow same-origin paths
        var raw = "<%= typeof redirect === 'string' ? redirect : '' %>";
        var target = "/dashboard";

        if (
          raw &&
          raw.startsWith("/") &&
          !raw.startsWith("//") &&
          !raw.includes("://") &&
          !raw.toLowerCase().startsWith("javascript:")
        ) {
          target = raw;
        }

        // Notify parent (best-effort, same-origin only)
        try {
          window.parent.postMessage(
            { type: "scraplet:auth:success", redirect: target },
            window.location.origin
          );
        } catch (e) {}

        // Hard escape to top-level
        setTimeout(function () {
          try {
            window.top.location.assign(target);
          } catch (e) {}
        }, 150);
      })();
    </script>
  </body>
</html>
