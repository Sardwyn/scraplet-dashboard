<div class="w-full">

  <!-- Top -->
  <div class="flex items-start justify-between gap-6 mb-8">
    <div class="min-w-0">
      <div class="inline-flex items-center gap-2 mb-2">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-indigo-400"></span>
        <span class="text-xs tracking-[0.28em] text-gray-500">OVERVIEW</span>
      </div>

      <h1 class="text-4xl font-bold text-gray-100 truncate">
        Welcome, <%= user.username %>
      </h1>
      <p class="text-gray-400 mt-2">
        Your creator mission-control.
      </p>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <% if (kick?.connected) { %>
          <span class="pc-chip">
            <span class="inline-block w-2 h-2 rounded-full bg-emerald-400"></span>
            Kick: <span class="font-mono text-emerald-200 ml-1">CONNECTED</span>
            <% if (kick.username) { %><span class="text-gray-500 ml-2">(@<%= kick.username %>)</span><% } %>
          </span>
        <% } else { %>
          <span class="pc-chip">
            <span class="inline-block w-2 h-2 rounded-full bg-yellow-400"></span>
            Kick: <span class="font-mono text-yellow-200 ml-1">NOT CONNECTED</span>
          </span>
        <% } %>

        <% if (typeof youtube !== 'undefined' && youtube?.connected) { %>
          <span class="pc-chip">
            <span class="inline-block w-2 h-2 rounded-full bg-emerald-400"></span>
            YouTube: <span class="font-mono text-emerald-200 ml-1">CONNECTED</span>
            <% if (youtube.username) { %><span class="text-gray-500 ml-2">(<%= youtube.username %>)</span><% } %>
          </span>
        <% } %>

        <% if (typeof tiktok !== 'undefined' && tiktok?.connected) { %>
          <span class="pc-chip">
            <span class="inline-block w-2 h-2 rounded-full bg-emerald-400"></span>
            TikTok: <span class="font-mono text-emerald-200 ml-1">CONNECTED</span>
            <% if (tiktok.username || tiktok.unique_id) { %><span class="text-gray-500 ml-2">(@<%= tiktok.username || tiktok.unique_id %>)</span><% } %>
          </span>
        <% } %>

        <% if (typeof discord !== 'undefined' && discord?.connected) { %>
          <span class="pc-chip">
            <span class="inline-block w-2 h-2 rounded-full bg-emerald-400"></span>
            Discord: <span class="font-mono text-emerald-200 ml-1">CONNECTED</span>
            <% if (discord.guild_name) { %><span class="text-gray-500 ml-2">(<%= discord.guild_name %>)</span><% } %>
          </span>
        <% } %>

        <span class="pc-chip">
          Tier: <span class="font-mono text-gray-100 ml-1"><%= isPro ? 'PRO' : 'CREATOR' %></span>
        </span>

        <% if (!user?.has_onboarded) { %>
          <span class="pc-chip">
            <span class="inline-block w-2 h-2 rounded-full bg-yellow-400"></span>
            <span class="font-mono text-yellow-200 ml-1">PROFILE SETUP NEEDED</span>
          </span>
        <% } %>
      </div>
    </div>


  </div>

  <% const widgetsUnlocked = widgets.filter(w => w.status === 'unlocked').length;
     const widgetsLocked = widgets.filter(w => w.status === 'locked').length;
     const overlaysInstalled = overlays.filter(o => o.status === 'installed').length;
     const onboarded = !!user?.has_onboarded;
  %>

  <!-- Quick Status (replaces the noisy 4-module summary grid) -->
  <div class="pc-panel mb-10">
    <div class="pc-panel-hd flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-xs tracking-[0.28em] text-gray-500">SYSTEM</span>
        <span class="text-xs text-gray-300 font-semibold">QUICK STATUS</span>
      </div>

      <div class="flex items-center gap-2">
        <a href="/dashboard/widgets" class="pc-btn pc-btn--ghost text-xs">Widgets →</a>
        <a href="/dashboard/overlays" class="pc-btn pc-btn--ghost text-xs">Overlays →</a>
        <a href="/profile/editor" class="pc-btn pc-btn--ghost text-xs">Profile →</a>
      </div>
    </div>

    <div class="pc-panel-bd">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Widgets -->
        <!-- Overlays — real DB data with element type breakdown -->
        <div class="pc-oled pc-readout">
          <div class="text-xs tracking-[0.28em] text-gray-500 mb-2">OVERLAYS</div>
          <div class="flex items-end justify-between gap-3 mb-3">
            <div>
              <div class="text-2xl font-mono pc-text-main">
                <%= overlayStats?.total || 0 %>
              </div>
              <div class="text-xs text-gray-500 mt-1">Created</div>
            </div>
            <a href="/dashboard/overlays" class="pc-chip text-xs">Manage →</a>
          </div>
          <% if ((overlayStats?.total || 0) > 0) { %>
          <div class="grid grid-cols-2 gap-x-4 gap-y-1 mt-2 border-t border-white/5 pt-2">
            <% if (overlayStats?.lowerThirds > 0) { %>
            <div class="flex justify-between text-[10px]">
              <span class="text-gray-500">Lower Thirds</span>
              <span class="font-mono text-gray-300"><%= overlayStats.lowerThirds %></span>
            </div>
            <% } %>
            <% if (overlayStats?.widgets > 0) { %>
            <div class="flex justify-between text-[10px]">
              <span class="text-gray-500">Widgets</span>
              <span class="font-mono text-gray-300"><%= overlayStats.widgets %></span>
            </div>
            <% } %>
            <% if (overlayStats?.text > 0) { %>
            <div class="flex justify-between text-[10px]">
              <span class="text-gray-500">Text</span>
              <span class="font-mono text-gray-300"><%= overlayStats.text %></span>
            </div>
            <% } %>
            <% if (overlayStats?.shapes > 0) { %>
            <div class="flex justify-between text-[10px]">
              <span class="text-gray-500">Shapes</span>
              <span class="font-mono text-gray-300"><%= overlayStats.shapes %></span>
            </div>
            <% } %>
            <% if (overlayStats?.images > 0) { %>
            <div class="flex justify-between text-[10px]">
              <span class="text-gray-500">Images</span>
              <span class="font-mono text-gray-300"><%= overlayStats.images %></span>
            </div>
            <% } %>
          </div>
          <% } %>
        </div>

        <!-- Profile -->
        <div class="pc-oled pc-readout">
          <div class="text-xs tracking-[0.28em] text-gray-500 mb-2">PROFILE</div>
          <% const pct = profileCompleteness?.pct || 0; %>
          <div class="flex items-end justify-between gap-3 mb-3">
            <div>
              <div class="text-2xl font-mono <%= pct === 100 ? 'text-emerald-200' : pct >= 60 ? 'text-indigo-300' : 'text-yellow-200' %>">
                <%= pct %>%
              </div>
              <div class="text-xs text-gray-500 mt-1">Complete</div>
            </div>
          </div>
          <!-- Progress bar -->
          <div class="w-full h-1.5 rounded-full bg-white/5 mb-3">
            <div class="h-1.5 rounded-full transition-all duration-500 <%= pct === 100 ? 'bg-emerald-400' : pct >= 60 ? 'bg-indigo-400' : 'bg-yellow-400' %>"
                 style="width: <%= pct %>%"></div>
          </div>
          <!-- Public URL — click to open -->
          <a href="<%= profileUrl %>" target="_blank" rel="noopener"
             class="pc-btn pc-btn--ghost text-xs w-full mb-3 truncate block text-center">
            <%= profileUrl.replace('https://', '') %>
          </a>
          <!-- QR code — lazy loaded, same pattern as working profile card -->
          <div id="profile-qr-wrap" class="hidden mt-2 mb-1">
            <div class="pc-mini-oled p-3 flex items-center gap-3">
              <div class="flex-1 text-xs text-gray-400">
                <div class="font-semibold mb-1">Share your profile</div>
                <div>Scan to visit your public profile page</div>
              </div>
              <div class="flex flex-col items-center gap-2">
                <img id="profile-qr-img" alt="Profile QR" class="w-[100px] h-[100px] rounded bg-white" />
                <button onclick="downloadProfileQR()" class="pc-btn pc-btn--ghost text-[9px] px-2 py-1">Download</button>
              </div>
            </div>
          </div>
          <!-- Action links -->
          <div class="flex items-center justify-between gap-1 mt-1">
            <a href="/profile/editor" class="pc-btn pc-btn--ghost text-[10px] flex-1 text-center">Edit</a>
            <button onclick="toggleProfileQR()" class="pc-btn pc-btn--ghost text-[10px] flex-1 text-center">QR</button>
            <a href="/dashboard/email" class="pc-btn pc-btn--ghost text-[10px] flex-1 text-center">Leads</a>
          </div>
        </div>
        <!-- Earnings -->
        <div class="pc-oled pc-readout">
          <div class="text-xs tracking-[0.28em] text-gray-500 mb-2">EARNINGS</div>
          <div class="flex items-end justify-between gap-3">
            <div>
              <% const pendingDisplay = ((earningsSummary?.pendingCents || 0) / 100).toFixed(2); %>
              <div class="text-2xl font-mono pc-text-main">
                $<%= pendingDisplay %>
              </div>
              <div class="text-xs pc-text-muted mt-1">Pending payout</div>
            </div>
            <% if (!earningsSummary?.stripeOnboarded) { %>
              <a href="/dashboard/earnings" class="pc-btn pc-btn--primary text-xs">Set up payouts</a>
            <% } else { %>
              <a href="/dashboard/earnings" class="pc-chip text-xs">
                <span class="inline-block w-2 h-2 rounded-full bg-emerald-400"></span>
                <span class="font-mono ml-1 text-emerald-200">STRIPE ACTIVE</span>
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%
    /* Derive integration states — multiline JS only (no // comments on same line as code) */

    const kickObj    = (typeof kick    !== 'undefined' && kick)    ? kick    : {};
    const youtubeObj = (typeof youtube !== 'undefined' && youtube) ? youtube : {};
    const discordObj = (typeof discord !== 'undefined' && discord) ? discord : {};
    const tiktokObj  = (typeof tiktok  !== 'undefined' && tiktok)  ? tiktok  : {};

    const kickState = kickObj.connected
      ? (kickObj.needsReauth ? 'reauth' : 'ok')
      : 'disconnected';

    const youtubeState = youtubeObj.connected
      ? (youtubeObj.needsReauth ? 'reauth' : 'ok')
      : (youtubeObj.username ? 'reauth' : 'not_linked');

    const discordState = discordObj.connected
      ? 'ok'
      : (discordObj.needsReauth ? 'reauth' : 'not_linked');

    const tiktokState = tiktokObj.connected
      ? (tiktokObj.needsReauth ? 'reauth' : 'ok')
      : (tiktokObj.username ? 'reauth' : 'not_linked');

    const integrations = [
      {
        key: 'kick',
        name: 'Kick',
        icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-label="Kick"><path d="M4 3h3.5v7.5L13 3h4l-6.5 8.5L17 21h-4l-5.5-7V21H4z"/></svg>`,
        state: kickState,
        connectedAs: kickObj.username || null,
        sub: kickObj.connected
          ? `Connected as @${kickObj.username || '—'}`
          : (kickObj.needsReauth
            ? 'Token expired — reconnect required'
            : 'Connect to unlock widgets + analytics'),
        primaryHref: kickObj.connected ? null : '/auth/kick/start',
        primaryLabel: kickObj.needsReauth ? 'Reconnect' : 'Connect',
        secondaryFormAction: '/api/integrations/kick/disconnect',
        secondaryLabel: 'Disconnect',
        showSecondary: true
      },

      {
        key: 'twitch',
        name: 'Twitch',
        icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-label="Twitch"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>`,
        state: 'not_linked',
        sub: 'Not linked yet.',
        primaryHref: null,
        primaryLabel: 'Soon',
        showSecondary: false
      },

      {
        key: 'tiktok',
        name: 'TikTok',
        icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-label="TikTok"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/></svg>`,
        state: tiktokState,
        connectedAs: tiktokObj.username || tiktokObj.unique_id || null,
        sub: tiktokObj.connected
          ? `Connected as @${tiktokObj.username || tiktokObj.unique_id || 'TikTok'}`
          : ((tiktokObj.username || tiktokObj.unique_id)
            ? `Reconnect @${tiktokObj.username || tiktokObj.unique_id}`
            : 'Not linked yet.'),
        primaryHref: tiktokObj.connected ? null : '/integrations/tiktok/connect',
        primaryLabel: tiktokObj.connected
          ? 'Connected'
          : ((tiktokObj.username || tiktokObj.unique_id) ? 'Reconnect' : 'Connect'),
        badge: tiktokObj.liveBadge || null,
        showSecondary: false
      },

      {
        key: 'youtube',
        name: 'YouTube',
        icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-label="YouTube"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
        state: youtubeState,
        connectedAs: youtubeObj.username || null,
        sub: youtubeObj.connected
          ? `Connected as ${youtubeObj.username || 'YouTube'}`
          : (youtubeObj.username
            ? `Reconnect ${youtubeObj.username || 'YouTube'}`
            : 'Not linked yet.'),
        primaryHref: '/integrations/youtube/connect',
        primaryLabel: youtubeObj.connected
          ? 'Connected'
          : (youtubeObj.username ? 'Reconnect' : 'Connect'),
        badge: youtubeObj.liveBadge || null,
        showSecondary: false
      },

      {
        key: 'rumble',
        name: 'Rumble',
        icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-label="Rumble"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm4.5 13.5l-6 3.5V7l6 3.5v3z"/></svg>`,
        state: 'not_linked',
        sub: 'Not linked yet.',
        primaryHref: null,
        primaryLabel: 'Soon',
        showSecondary: false
      },

      {
        key: 'discord',
        name: 'Discord',
        icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-label="Discord"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>`,
        state: discordState,
        connectedAs: discordObj.guild_name || discordObj.guild_id || null,
        sub: discordObj.connected
          ? `Connected: ${discordObj.guild_name || discordObj.guild_id || 'Server'}`
          : (discordObj.needsReauth
            ? 'Token expired — reconnect required'
            : 'Connect to enable producer channels + controls'),
        primaryHref: discordObj.connected
          ? '/dashboard/scrapbot/discord'
          : '/integrations/discord/connect',
        primaryLabel: discordObj.connected
          ? 'Manage'
          : (discordObj.needsReauth ? 'Reconnect' : 'Connect'),
        showSecondary: false
      }
    ];

    const brokenCount = integrations.filter(i => i.state === 'reauth' || i.state === 'disconnected').length;
    const notLinkedCount = integrations.filter(i => i.state === 'not_linked').length;
    const actionRequiredCount = brokenCount + notLinkedCount;
  %>

  <div class="pc-panel pc-bay mb-10 <%= actionRequiredCount > 0 ? 'pc-bay--alert' : '' %>">
    <div class="pc-panel-hd flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-xs tracking-[0.28em] pc-text-muted">SYSTEM</span>
        <span class="text-xs pc-text-dim font-semibold">INTEGRATIONS</span>

        <% if (brokenCount > 0) { %>
          <span class="pc-chip pc-bay-alert">
            <span class="pc-bay-alert-dot"></span>
            <span class="font-mono pc-text-warn">ACTION REQUIRED:</span>
            <span class="font-mono pc-text-main"><%= brokenCount %></span>
          </span>
        <% } else if (notLinkedCount > 0) { %>
          <span class="pc-chip pc-bay-alert">
            <span class="pc-bay-alert-dot"></span>
            <span class="font-mono pc-text-warn">INCOMPLETE:</span>
            <span class="font-mono pc-text-main"><%= notLinkedCount %></span>
          </span>
        <% } else { %>
          <span class="pc-chip">
            <span class="inline-block w-2 h-2 rounded-full bg-emerald-400"></span>
            <span class="font-mono ml-1 pc-text-accent">ALL GREEN</span>
          </span>
        <% } %>
      </div>

      <div class="flex items-center gap-2">
        <% if (brokenCount > 0) { %>
          <span class="pc-chip">
            <span class="inline-block w-2 h-2 rounded-full bg-yellow-400"></span>
            <span class="font-mono pc-text-warn ml-1">Operator:</span>
            <span class="pc-text-muted">fix broken links</span>
          </span>
        <% } else if (notLinkedCount > 0) { %>
          <span class="pc-chip">
            <span class="inline-block w-2 h-2 rounded-full bg-yellow-400"></span>
            <span class="font-mono pc-text-warn ml-1">Operator:</span>
            <span class="pc-text-muted">link remaining platforms</span>
          </span>
        <% } %>

        <a href="/dashboard/integrations" class="pc-btn pc-btn--ghost text-xs">
          Manage all →
        </a>
      </div>
    </div>

    <div class="pc-panel-bd">
      <div class="pc-bay-grid grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
        <% integrations.forEach(i => {
          let cls = 'pc-int';
          let stateText = 'SOON';
          let urgent = false;

          if (i.state === 'ok') { cls += ' pc-int--ok'; stateText = 'CONNECTED'; }
          else if (i.state === 'reauth') { cls += ' pc-int--warn pc-int--urgent'; stateText = 'REAUTH'; urgent = true; }
          else if (i.state === 'disconnected') { cls += ' pc-int--bad pc-int--urgent'; stateText = 'DISCONNECTED'; urgent = true; }
          else if (i.state === 'not_linked') { cls += ' pc-int--link'; stateText = 'NOT LINKED'; }
          else if (i.state === 'soon') { stateText = 'SOON'; }
        %>

          <div class="<%= cls %> min-w-0">
            <div class="pc-int-inner">
              <div class="pc-int-ico pc-int-ico--<%= i.state %>">
                <%- i.icon %>
              </div>

              <div class="pc-int-meta">
                <div class="pc-int-name pc-text-main"><%= i.name %></div>

                <% if (i.state === 'ok' && i.connectedAs) { %>
                  <div class="pc-int-sub pc-text-muted">
                    Connected as <span class="font-mono pc-text-accent">@<%= i.connectedAs %></span>
                  </div>
                <% } else { %>
                  <div class="pc-int-sub pc-text-muted"><%= i.sub %></div>
                <% } %>

                <div class="pc-int-row">
                  <div class="pc-int-state">
                    <span class="pc-int-dot <%= urgent ? 'bg-yellow-400' : (i.state === 'ok' ? 'bg-emerald-400' : 'bg-gray-500') %>"></span>
                    <span class="font-mono
                      <%= urgent
                        ? 'pc-text-warn'
                        : (i.state === 'ok'
                          ? 'pc-text-accent'
                          : (i.state === 'not_linked'
                            ? 'pc-text-warn'
                            : 'pc-text-muted'))
                      %>">
                      <%= stateText %>
                    </span>
                  </div>

                  <% if (i.state === 'ok' && i.badge && i.badge.text) { %>
                    <div class="pc-int-badge">
                      <span class="font-mono text-xs
                        <%= i.badge.tone === 'good'
                          ? 'pc-text-accent'
                          : (i.badge.tone === 'warn'
                            ? 'pc-text-warn'
                            : 'pc-text-muted')
                        %>">
                        <%= i.badge.text %>
                      </span>
                    </div>
                  <% } %>
                </div>
              </div>

              <%
                const isOn      = i.state === 'ok';
                const canToggle = i.state !== 'soon';
                const switchFormAction = (isOn && i.showSecondary && i.secondaryFormAction) ? i.secondaryFormAction : null;
                const switchHref = isOn
                  ? (i.primaryHref || null)
                  : (i.primaryHref || null);
              %>
              <div class="pc-rocker-wrap ml-auto flex-shrink-0">
                <% if (canToggle && switchFormAction) { %>
                  <form method="POST" action="<%= switchFormAction %>" class="pc-rocker-form">
                    <button type="submit" class="pc-rocker pc-rocker--on" aria-label="Disconnect <%= i.name %>">
                      <span class="pc-rocker-paddle"></span>
                    </button>
                  </form>
                <% } else if (canToggle && switchHref) { %>
                  <a href="<%= switchHref %>" class="pc-rocker pc-rocker--<%= isOn ? 'on' : 'off' %>" aria-label="<%= isOn ? 'Manage' : 'Connect' %> <%= i.name %>">
                    <span class="pc-rocker-paddle"></span>
                  </a>
                <% } else { %>
                  <div class="pc-rocker pc-rocker--<%= isOn ? 'on' : 'off' %> pc-rocker--disabled">
                    <span class="pc-rocker-paddle"></span>
                  </div>
                <% } %>
              </div>

            </div>
          </div>

        <% }) %>
      </div>
    </div>
  </div>

  <!-- Studio / Scrapbot / Public Profile -->
