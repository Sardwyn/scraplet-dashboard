<script>
function toggleProfileQR() {
  var wrap = document.getElementById('profile-qr-wrap');
  var img = document.getElementById('profile-qr-img');
  if (!wrap || !img) return;
  wrap.classList.toggle('hidden');
  if (!img.src || img.src === window.location.href) {
    img.src = 'https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=' + encodeURIComponent(document.getElementById('profileUrl')?.value || window.location.origin + '/u/<%= user.username %>');
  }
}

function downloadProfileQR() {
  var img = document.getElementById('profile-qr-img');
  if (!img || !img.src) return;
  
  // Create canvas to download QR at higher resolution
  var canvas = document.createElement('canvas');
  var ctx = canvas.getContext('2d');
  canvas.width = 200;
  canvas.height = 200;
  
  var tempImg = new Image();
  tempImg.crossOrigin = 'anonymous';
  tempImg.onload = function() {
    ctx.fillStyle = 'white';
    ctx.fillRect(0, 0, 200, 200);
    ctx.drawImage(tempImg, 0, 0, 200, 200);
    
    canvas.toBlob(function(blob) {
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'profile-qr-code.png';
      a.click();
      URL.revokeObjectURL(url);
    });
  };
  tempImg.src = img.src.replace('size=100x100', 'size=200x200');
}
</script>

