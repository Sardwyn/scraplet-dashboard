<section style="margin-bottom:60px; font-family:'Inter',sans-serif;">
  <h2
    style="
      font-size:22px;
      margin-bottom:12px;
      color:<%= theme.primary %>;
      border-bottom:2px solid <%= theme.accent %>;
      display:inline-block;
      padding-bottom:4px;
    "
  >
    📈 Audience Growth (7-day)
  </h2>

  <% const WT = Array.isArray(weeklyTrends) ? weeklyTrends : []; %>
  <% if (!WT.length) { %>
    <p style="color:#9ca3af;font-style:italic;margin-top:8px;">
      Not enough history yet to compute 7-day growth. Once a few snapshots accumulate, this section will reflect weekly deltas per platform.
    </p>
  <% } else { 
      // compute scaling for tiny bar viz
      const maxAbs = Math.max(1, ...WT.map(t => Math.abs(Number(t.deltaPct || 0))));
      const rowHeight = 18, barHeight = 8, svgWidth = 260, svgHeight = WT.length * rowHeight + 10;
  %>
    <div style="margin-top:12px;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:13.5px;">
        <thead style="background:<%= theme.primary %>;color:#fff;">
          <tr>
            <th style="padding:10px 12px;text-align:left;">Platform</th>
            <th style="padding:10px 12px;text-align:right;">Prev</th>
            <th style="padding:10px 12px;text-align:right;">Current</th>
            <th style="padding:10px 12px;text-align:right;">Δ 7d</th>
            <th style="padding:10px 12px;text-align:left;">Trend</th>
          </tr>
        </thead>
        <tbody>
          <% WT.forEach((t, i) => { 
               const curr = Number(t.current || 0);
               const prev = Number(t.previous || 0);
               const delta = Number((t.deltaPct || 0).toFixed(1));
               const up = delta >= 0;
               const fill = up ? theme.accent : '#DC2626';
               const w = Math.round(Math.min(svgWidth, (Math.abs(delta) / maxAbs) * svgWidth));
          %>
          <tr style="background:<%= i % 2 === 0 ? '#FAFAFA' : '#F3F4F6' %>;color:#111827;">
            <td style="padding:8px 12px;font-weight:600;text-transform:capitalize;"><%= t.platform %></td>
            <td style="padding:8px 12px;text-align:right;"><%= prev.toLocaleString() %></td>
            <td style="padding:8px 12px;text-align:right;"><%= curr.toLocaleString() %></td>
            <td style="padding:8px 12px;text-align:right;color:<%= up ? theme.accent : '#DC2626' %>;">
              <%= up ? '+' : '' %><%= delta.toFixed(1) %>%
            </td>
            <td style="padding:8px 12px;">
              <svg width="<%= svgWidth %>" height="<%= rowHeight %>" xmlns="http://www.w3.org/2000/svg">
                <!-- zero axis -->
                <rect x="0" y="<%= (rowHeight - 1) / 2 %>" width="<%= svgWidth %>" height="1" fill="#E5E7EB"/>
                <% if (delta !== 0) { %>
                  <% if (up) { %>
                    <rect x="<%= svgWidth/2 %>" y="<%= (rowHeight - barHeight)/2 %>" width="<%= w/2 %>" height="<%= barHeight %>" fill="<%= fill %>" rx="3"/>
                  <% } else { %>
                    <rect x="<%= svgWidth/2 - w/2 %>" y="<%= (rowHeight - barHeight)/2 %>" width="<%= w/2 %>" height="<%= barHeight %>" fill="<%= fill %>" rx="3"/>
                  <% } %>
                <% } %>
              </svg>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% 
      // quick narrative: strongest riser
      const top = WT.slice().sort((a,b) => Number(b.deltaPct||0) - Number(a.deltaPct||0))[0];
    %>
    <p
      style="
        margin-top:14px;
        font-size:14px;
        color:#1f2937;
        background:linear-gradient(90deg,<%= theme.primary %>10,<%= theme.accent %>10);
        padding:12px 16px;
        border-left:4px solid <%= theme.primary %>;
        border-radius:6px;
        line-height:1.5;
      "
    >
      <strong style="text-transform:capitalize;"><%= top.platform %></strong> is your fastest-growing platform this week at
      <strong><%= (Number(top.deltaPct)||0) >= 0 ? '+' : '' %><%= Number(top.deltaPct||0).toFixed(1) %>%</strong>.
    </p>
  <% } %>
</section>
