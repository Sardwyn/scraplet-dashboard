<section>
  <h2>Marketability Grade</h2>
  <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem;background:#f3f4f6;border-radius:8px;">
    <div>
      <p style="margin:0;font-size:1rem;">Based on combined audience size, engagement levels, and consistency.</p>
      <small style="color:#6b7280;">Higher grades indicate strong brand alignment and growth potential.</small>
    </div>
    <div style="font-size:3rem;font-weight:bold;color:<%= theme.primary %>;"><%= grade %></div>
  </div>
</section>
