<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    body { font-family: Arial, sans-serif; color: #222; margin: 0; padding: 2rem; }
    h1 { color: #4338ca; }
    .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .stat { background: #f3f4f6; padding: 1rem; border-radius: 6px; }
    footer { font-size: 0.8rem; color: #888; text-align: center; margin-top: 2rem; }
  </style>
</head>
<body>
  <h1><%= user.username %> — Media Kit</h1>
  <p>Generated on <%= date %> via Scraplet Dashboard</p>

  <h2>Overview</h2>
  <div class="stat-grid">
    <% for (const platform in stats.followers || {}) { %>
      <div class="stat">
        <strong><%= platform %></strong><br>
        Followers: <%= stats.followers[platform] %><br>
        Engagement: <%= stats.engagement?.[platform] ?? 'N/A' %>
      </div>
    <% } %>
  </div>

  <h2>Marketability Grade</h2>
  <p style="font-size:2rem;font-weight:bold;color:#2563eb"><%= grade %></p>

  <footer>
    Powered by Scraplet — scraplet.store
  </footer>
</body>
</html>
