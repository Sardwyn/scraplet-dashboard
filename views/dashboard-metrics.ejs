                class="w-full bg-gray-950/60 border border-gray-700 rounded-lg text-xs text-gray-200 p-2 resize-none focus:outline-none focus:border-blue-600"
                placeholder="Alert message?">?? Manual ops alert from Scraplet Dashboard</textarea>
              <div class="flex items-center gap-3 mt-2">
