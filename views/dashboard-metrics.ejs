<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Scrapbot Metrics</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-950 text-white font-sans">
  <% const formatTimestamp=(ts)=> {
    try {
    if (!ts) return "—";
    const d = new Date(ts);
    return isNaN(d.getTime()) ? "—" : d.toISOString().replace("T"," ").replace("Z","");
    } catch { return "—"; }
    };

    const formatCount = (n) => {
    const x = Number(n || 0);
    if (!isFinite(x)) return "0";
    return x.toLocaleString();
    };

    // Safe getter for older Node versions (avoids optional chaining / nullish coalescing)
    const get = (obj, path, fallback) => {
    try {
    if (!obj) return fallback;
    const parts = String(path || "").split(".");
    let cur = obj;
    for (const k of parts) {
    if (cur && Object.prototype.hasOwnProperty.call(cur, k)) cur = cur[k];
    else return fallback;
    }
    return (cur === undefined || cur === null) ? fallback : cur;
    } catch (e) {
    return fallback;
    }
    };


    const sbStatus = scrapbotStatus || {};
    const sbMetrics = scrapbotMetrics || {};
    const sbRecent = scrapbotRecent || {};

    // Security telemetry snapshot (server may pass one of these keys)
    const sbSecurity =
    (typeof securityTelemetrySnapshot !== "undefined" && securityTelemetrySnapshot) ||
    (typeof scrapbotSecurity !== "undefined" && scrapbotSecurity) ||
    (typeof securityTelemetry !== "undefined" && securityTelemetry) ||
    {};

    const sbOnline = !!sbStatus.ok;
    const sbDbOk = !!(sbStatus.db && sbStatus.db.ok);

    const counters = sbMetrics.counters || {};
    const derived = sbMetrics.derived || {};
    const derivedChannels = Array.isArray(derived.channels) ? derived.channels : [];
    const derivedTalkers = Array.isArray(derived.top_talkers) ? derived.top_talkers : [];
    const derivedIncidents = Array.isArray(derived.top_incident_channels) ? derived.top_incident_channels : [];
    const ringWindow = derived.ring_window || {};

    const pulseLatest = Array.isArray(sbMetrics.pulse_latest) ? sbMetrics.pulse_latest : [];
    const recentItems = Array.isArray(sbRecent.items) ? sbRecent.items : [];

    const c = (k) => Number(counters[k] || 0) || 0;

    const inboundTotal = c("inbound_total");
    const inboundErrors = c("inbound_errors_total");
    const cmdMatched = c("commands_matched_total");
    const cmdReplies = c("commands_replies_sent_total");
    const floodTripped = c("flood_tripped_total");
    const swarmMatched = c("swarm_matched_total");
    const modMatched = c("moderation_matched_total");

    const uptimeMs = Number(sbMetrics.uptime_ms || 0) || 0;
    const uptimeSec = Math.floor(uptimeMs / 1000);
    const upH = Math.floor(uptimeSec / 3600);
    const upM = Math.floor((uptimeSec % 3600) / 60);
    const upS = uptimeSec % 60;

    const topPulse = pulseLatest[0] || null;
    const topPulseKey = get(topPulse, "key", "—");
    const pulse = get(topPulse, "pulse", null);
    const tripwire = get(topPulse, "tripwire", null);

    // Security derived
    const secOk = !!get(sbSecurity, "ok", false);
    const secRolling1m = get(sbSecurity, "rolling.last_1m", {});
    const secRolling5m = get(sbSecurity, "rolling.last_5m", {});
    const secTop5m = get(sbSecurity, "top_5m", {});
    const secBuffer = get(sbSecurity, "buffer", {});
    %>

    <div class="pc-page">
      <!-- Header -->
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Scrapbot Metrics</h1>
          <p class="text-gray-400 mt-2">
            Signal first. Debug later. This page is built to answer: “is it alive?”, “what channel is hot?”, “which
            guard fired?”, “did we act?”
          </p>
        </div>

        <div class="flex items-center gap-3">
          <a href="/dashboard"
            class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl shadow transition border border-gray-700">
            Back to Dashboard
          </a>

          <button id="btnRefreshNow"
            class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl shadow transition">
            Refresh now
          </button>
        </div>
      </div>

      <!-- =========================================================
         1) OVERVIEW
    ========================================================== -->
      <section class="mt-8">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">1) Overview</h2>
          <div class="text-xs text-gray-400">
            last update: <span id="lastUpdate">
              <%= formatTimestamp(sbMetrics.now || sbStatus.now) %>
            </span>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
          <!-- Health -->
          <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-5 shadow">
            <div class="flex items-start justify-between">
              <div>
                <div class="text-sm text-gray-400">Scrapbot</div>
                <div class="mt-1 text-2xl font-bold">
                  <span id="pillOnline"
  class="inline-flex items-center px-3 py-1 rounded-xl text-sm font-semibold <%= sbOnline ? 'bg-green-700/70 border border-green-600' : 'bg-red-700/70 border border-red-600' %>">
  <%= sbOnline ? "ONLINE" : "OFFLINE" %>
</span>
                </div>
                <div class="mt-2 text-sm text-gray-300">
                  DB:
                  <span id="pillDb"
  class="inline-flex items-center px-2 py-1 rounded-lg text-xs font-semibold <%= sbDbOk ? 'bg-green-700/50 border border-green-700' : 'bg-red-700/50 border border-red-700' %>">
  <%= sbDbOk ? "OK" : "FAIL" %>
</span>
                </div>
              </div>

              <div class="text-xs text-gray-500 text-right">
                uptime<br>
                <span id="uptime" class="text-gray-300 font-mono">
                  <%= `${upH}h ${upM}m ${upS}s` %>
                </span>
              </div>
            </div>

            <div class="mt-4 text-xs text-gray-500">
              top pulse key: <span id="topPulseKey" class="text-gray-300 font-mono">
                <%= topPulseKey %>
              </span>
            </div>
          </div>

          <!-- Totals -->
          <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-5 shadow">
            <div class="text-sm text-gray-400">Traffic</div>
            <div class="mt-3 grid grid-cols-2 gap-3">
              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Inbound</div>
                <div id="kpiInbound" class="text-2xl font-bold">
                  <%= formatCount(inboundTotal) %>
                </div>
              </div>
              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Errors</div>
                <div id="kpiErrors" class="text-2xl font-bold">
                  <%= formatCount(inboundErrors) %>
                </div>
              </div>
              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Commands</div>
                <div id="kpiCmd" class="text-2xl font-bold">
                  <%= formatCount(cmdMatched) %>
                </div>
              </div>
              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Replies</div>
                <div id="kpiReplies" class="text-2xl font-bold">
                  <%= formatCount(cmdReplies) %>
                </div>
              </div>
            </div>
          </div>

          <!-- Guards -->
          <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-5 shadow">
            <div class="text-sm text-gray-400">Guards</div>
            <div class="mt-3 grid grid-cols-3 gap-3">
              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Flood</div>
                <div id="kpiFlood" class="text-2xl font-bold">
                  <%= formatCount(floodTripped) %>
                </div>
              </div>
              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Swarm</div>
                <div id="kpiSwarm" class="text-2xl font-bold">
                  <%= formatCount(swarmMatched) %>
                </div>
              </div>
              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Moderation</div>
                <div id="kpiMod" class="text-2xl font-bold">
                  <%= formatCount(modMatched) %>
                </div>
              </div>
            </div>

            <div class="mt-4 text-xs text-gray-500">
              pulse active: <span id="pulseActive" class="text-gray-300 font-mono">
                <%= (pulse && pulse.active) ? "true" : "false" %>
              </span>
              <span class="mx-2 text-gray-700">•</span>
              tripwire: <span id="tripwire" class="text-gray-300 font-mono">
                <%= tripwire ? "set" : "null" %>
              </span>
            </div>
          </div>

          <!-- Security telemetry -->
          <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-5 shadow">
            <div class="flex items-center justify-between">
              <div class="text-sm text-gray-400">Security Telemetry</div>
              <!-- pillSec -->
<span id="pillSec"
  class="inline-flex items-center px-2 py-1 rounded-lg text-xs font-semibold <%= secOk ? 'bg-green-700/50 border border-green-700' : 'bg-gray-800 border border-gray-700' %>">
  <%= secOk ? "LIVE" : "—" %>
</span>
            </div>

            <div class="mt-3 grid grid-cols-2 gap-3">
              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Probes (1m)</div>
                <div id="kpiProbes1m" class="text-2xl font-bold">
                  <%= formatCount(secRolling1m.probes || 0) %>
                </div>
                <div class="mt-1 text-xs text-gray-500">
                  blocked <span id="kpiBlocked1m" class="text-gray-300 font-mono">
                    <%= formatCount(secRolling1m.blocked || 0) %>
                  </span>
                </div>
              </div>

              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Probes (5m)</div>
                <div id="kpiProbes5m" class="text-2xl font-bold">
                  <%= formatCount(secRolling5m.probes || 0) %>
                </div>
                <div class="mt-1 text-xs text-gray-500">
                  blocked <span id="kpiBlocked5m" class="text-gray-300 font-mono">
                    <%= formatCount(secRolling5m.blocked || 0) %>
                  </span>
                </div>
              </div>

              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Req (5m)</div>
                <div id="kpiReq5m" class="text-2xl font-bold">
                  <%= formatCount(secRolling5m.req || 0) %>
                </div>
                <div class="mt-1 text-xs text-gray-500">
                  4xx <span id="kpi4xx5m" class="text-gray-300 font-mono">
                    <%= formatCount(secRolling5m.s4xx || 0) %>
                  </span>
                  <span class="mx-2 text-gray-700">•</span>
                  5xx <span id="kpi5xx5m" class="text-gray-300 font-mono">
                    <%= formatCount(secRolling5m.s5xx || 0) %>
                  </span>
                </div>
              </div>

              <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-3">
                <div class="text-xs text-gray-500">Buffered</div>
                <div id="kpiProbeBuffered" class="text-2xl font-bold">
                  <%= formatCount(secBuffer.probe_events_buffered || 0) %>
                </div>
                <div class="mt-1 text-xs text-gray-500">
                  max <span id="kpiProbeMax" class="text-gray-300 font-mono">
                    <%= formatCount(secBuffer.max_probe_events || 0) %>
                  </span>
                </div>
              </div>
            </div>

            <div class="mt-4 text-xs text-gray-500">
              top vectors shown below in section 3.
            </div>
          </div>
        </div>
      </section>

      <!-- =========================================================
         2) OPERATIONS
    ========================================================== -->
      <section class="mt-10">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">2) Operations</h2>
          <div class="text-xs text-gray-500">
            ring window:
            <span id="ringSize" class="text-gray-300 font-mono">
              <%= ringWindow.size ?? 0 %>
            </span>
            /
            <span class="text-gray-300 font-mono">
              <%= ringWindow.capacity ?? 0 %>
            </span>
          </div>
        </div>

        <!-- Test Controls Panel -->
        <div class="mt-4 bg-gray-900/60 border border-gray-800 rounded-2xl p-6 shadow">
          <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div>
              <h3 class="text-lg font-semibold">Test Controls</h3>
              <p class="text-xs text-gray-500 mt-1">
                Fire synthetic swarms/floods into <span class="font-mono text-gray-300">/api/inbound/kick</span> (uses
                <span class="font-mono text-gray-300">x-scrapbot-secret</span>).
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-2 items-stretch sm:items-center">
              <div class="relative">
                <input id="tc_secret" type="password" placeholder="x-scrapbot-secret"
                  class="bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full sm:w-[320px] pr-28" />
                <div class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-gray-500">
                  <span id="tc_secretHint">not saved</span>
                </div>
              </div>
              <div class="flex gap-2">
                <button id="tc_save"
                  class="px-4 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm">Save</button>
                <button id="tc_clear"
                  class="px-4 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm">Clear</button>
              </div>
            </div>
          </div>

          <div class="mt-5 grid grid-cols-1 lg:grid-cols-3 gap-4">
            <!-- Presets -->
            <div class="bg-gray-950/40 border border-gray-800 rounded-2xl p-4">
              <div class="flex items-center justify-between">
                <div class="text-sm font-semibold text-gray-200">Presets</div>
                <div class="text-xs">
                  <span id="tc_status"
                    class="px-2 py-1 rounded-lg border border-gray-700 bg-gray-800 text-gray-200">idle</span>
                </div>
              </div>

              <div class="mt-3 grid grid-cols-2 gap-2">
                <button class="px-3 py-2 rounded-xl bg-blue-600 hover:bg-blue-700 text-sm font-semibold"
                  id="tc_swarm_200">Swarm 200</button>
                <button class="px-3 py-2 rounded-xl bg-blue-600 hover:bg-blue-700 text-sm font-semibold"
                  id="tc_swarm_500">Swarm 500</button>

                <button class="px-3 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm"
                  id="tc_swarm_cinematic">Cinematic Swarm</button>
                <button class="px-3 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm"
                  id="tc_swarm_linkspam">Link Spam</button>

                <button
                  class="col-span-2 px-3 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm"
                  id="tc_flood_emoji">Emoji Flood</button>
              </div>

              <div class="mt-3 flex gap-2">
                <button class="flex-1 px-3 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm"
                  id="tc_stop">Stop</button>
                <button class="flex-1 px-3 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm"
                  id="tc_log_clear">Clear log</button>
              </div>

              <div class="mt-4">
                <div class="flex items-center justify-between text-xs text-gray-500 mb-2">
                  <span>Progress</span>
                  <span id="tc_progressText" class="text-gray-300 font-mono">0 / 0</span>
                </div>
                <div class="h-2 w-full rounded-full bg-black/30 border border-gray-800 overflow-hidden">
                  <div id="tc_progressBar" class="h-2 w-0 bg-green-600"></div>
                </div>
                <div class="mt-2 text-xs text-gray-500">
                  Tip: for “social proof” swarms, use <span class="font-mono text-gray-300">Cinematic Swarm</span>
                  (staggered joins + variance).
                </div>
              </div>
            </div>

            <!-- Parameters -->
            <div class="bg-gray-950/40 border border-gray-800 rounded-2xl p-4 lg:col-span-2">
              <div class="text-sm font-semibold text-gray-200">Parameters</div>

              <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                  <label class="text-xs text-gray-500">Text</label>
                  <input id="tc_text" type="text" value="free followers"
                    class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                </div>

                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class="text-xs text-gray-500">Channel</label>
                    <input id="tc_channel" type="text" value="scraplet"
                      class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                  </div>
                  <div>
                    <label class="text-xs text-gray-500">Tenant</label>
                    <input id="tc_userId" type="number" value="4"
                      class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                  </div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class="text-xs text-gray-500">Broadcaster ID</label>
                    <input id="tc_broadcasterUserId" type="number" value="1017792"
                      class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                  </div>
                  <div>
                    <label class="text-xs text-gray-500">Concurrency</label>
                    <input id="tc_concurrency" type="number" value="6" min="1" max="80"
                      class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                  </div>
                </div>

                <div class="grid grid-cols-3 gap-3">
                  <div>
                    <label class="text-xs text-gray-500">Users</label>
                    <input id="tc_users" type="number" value="200" min="1" max="8000"
                      class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                  </div>
                  <div>
                    <label class="text-xs text-gray-500">Repeats</label>
                    <input id="tc_repeats" type="number" value="3" min="1" max="500"
                      class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                  </div>
                  <div>
                    <label class="text-xs text-gray-500">Interval (ms)</label>
                    <input id="tc_interval" type="number" value="120" min="0" max="20000"
                      class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                  </div>
                </div>

                <div class="bg-black/20 border border-gray-800 rounded-2xl p-3">
                  <div class="text-xs text-gray-500 mb-2">Link spam options</div>
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <label class="text-xs text-gray-500">Domain</label>
                      <input id="tc_link_domain" type="text" value="discord.gg"
                        class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                    </div>
                    <div>
                      <label class="text-xs text-gray-500">Link rate (%)</label>
                      <input id="tc_link_rate" type="number" value="30" min="0" max="100"
                        class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                    </div>
                  </div>
                </div>

                <div class="bg-black/20 border border-gray-800 rounded-2xl p-3">
                  <div class="text-xs text-gray-500 mb-2">Emoji / cinematic options</div>
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <label class="text-xs text-gray-500">Emoji intensity (1–10)</label>
                      <input id="tc_emoji_intensity" type="number" value="7" min="1" max="10"
                        class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                    </div>
                    <div>
                      <label class="text-xs text-gray-500">Variance (%)</label>
                      <input id="tc_cine_variance" type="number" value="55" min="0" max="100"
                        class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
                    </div>
                  </div>
                </div>
              </div>

              <div class="mt-4">
                <div class="flex items-center justify-between">
                  <div class="text-sm font-semibold text-gray-200">Log</div>
                  <div class="text-xs text-gray-500">latest first</div>
                </div>
                <pre id="tc_log"
                  class="mt-2 max-h-56 overflow-auto text-xs text-gray-300 bg-black/30 border border-gray-800 rounded-2xl p-3 whitespace-pre-wrap"></pre>
              </div>
            </div>
          </div>
        </div>

        <!-- Moderation Runtime + Pipeline Test + Incidents -->
        <div class="mt-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
          <!-- Runtime toggles -->
          <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 shadow">
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-semibold">Moderation runtime</h3>
              <span id="rt_status"
                class="px-2 py-1 rounded-lg border border-gray-700 bg-gray-800 text-gray-200 text-xs">—</span>
            </div>
            <p class="text-xs text-gray-500 mt-1">
              Live toggles on Scrapbot. Useful for bug-smash and safe rollout.
            </p>

            <div class="mt-4 space-y-3">
              <div>
                <label class="text-xs text-gray-500">Enforcement</label>
                <select id="rt_enforcement"
                  class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full">
                  <option value="off">off (log only)</option>
                  <option value="timeout_only">timeout_only</option>
                  <option value="full">full</option>
                </select>
              </div>

              <label class="inline-flex items-center gap-2 text-sm text-gray-300 select-none">
                <input id="rt_usePulseTripwire" type="checkbox" class="rounded" />
                enable pulse tripwire tightening
              </label>

              <div class="flex gap-2">
                <button id="rt_load"
                  class="flex-1 px-3 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm">Load</button>
                <button id="rt_apply"
                  class="flex-1 px-3 py-2 rounded-xl bg-blue-600 hover:bg-blue-700 text-sm font-semibold">Apply</button>
              </div>

              <div class="text-xs text-gray-500">
                Tip: keep <span class="font-mono text-gray-300">off</span> while tuning thresholds; switch to <span
                  class="font-mono text-gray-300">timeout_only</span> once stable.
              </div>
            </div>
          </div>

          <!-- Pipeline test -->
          <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 shadow lg:col-span-2">
            <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
              <div>
                <h3 class="text-lg font-semibold">Pipeline test</h3>
                <p class="text-xs text-gray-500 mt-1">
                  Runs pulse → trust → swarm → flood → rules and returns a structured decision. No bans/timeouts
                  executed.
                </p>
              </div>
              <button id="pt_run" class="px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-700 text-sm font-semibold">
                Run test
              </button>
            </div>

            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
              <div class="md:col-span-2">
                <label class="text-xs text-gray-500">Text</label>
                <input id="pt_text" type="text" value="😂😂😂😂"
                  class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
              </div>

              <div>
                <label class="text-xs text-gray-500">Channel</label>
                <input id="pt_channel" type="text" value="scraplet"
                  class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
              </div>

              <div>
                <label class="text-xs text-gray-500">Tenant</label>
                <input id="pt_userId" type="number" value="4"
                  class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
              </div>

              <div>
                <label class="text-xs text-gray-500">Sender username</label>
                <input id="pt_senderUsername" type="text" value="TestUser"
                  class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
              </div>

              <div>
                <label class="text-xs text-gray-500">Sender user id</label>
                <input id="pt_senderUserId" type="number" value="12345"
                  class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
              </div>

              <div>
                <label class="text-xs text-gray-500">Role</label>
                <select id="pt_userRole"
                  class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full">
                  <option value="everyone">everyone</option>
                  <option value="subscriber">subscriber</option>
                  <option value="moderator">moderator</option>
                  <option value="broadcaster">broadcaster</option>
                </select>
              </div>

              <div>
                <label class="text-xs text-gray-500">Message id</label>
                <input id="pt_messageId" type="text" placeholder="optional"
                  class="mt-1 bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-full" />
              </div>
            </div>

            <div class="mt-4">
              <div class="flex items-center justify-between">
                <div class="text-sm font-semibold text-gray-200">Result</div>
                <div class="text-xs text-gray-500">latest first</div>
              </div>
              <pre id="pt_out"
                class="mt-2 max-h-72 overflow-auto text-xs text-gray-300 bg-black/30 border border-gray-800 rounded-2xl p-3 whitespace-pre-wrap"></pre>
            </div>
          </div>
        </div>

        <!-- Incidents (DB) -->
        <div class="mt-4 bg-gray-900/60 border border-gray-800 rounded-2xl p-6 shadow">
          <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
            <div>
              <h3 class="text-lg font-semibold">Moderation incidents (DB)</h3>
              <p class="text-xs text-gray-500 mt-1">
                Audit trail from decision → action attempt → action result. This comes from <span
                  class="font-mono text-gray-300">intelStore.recordIncident</span>.
              </p>
            </div>
            <div class="flex flex-wrap gap-2 items-center">
              <input id="inc_channel" placeholder="channel (optional)"
                class="bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-40" />
              <input id="inc_userId" type="number" value="4"
                class="bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-24" />
              <select id="inc_limit" class="bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm">
                <option value="25">25</option>
                <option value="50" selected>50</option>
                <option value="100">100</option>
              </select>
              <button id="inc_refresh"
                class="px-3 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 border border-gray-700 text-sm">Refresh</button>
            </div>
          </div>

          <div class="mt-4 overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="text-gray-400">
                <tr class="border-b border-gray-800">
                  <th class="text-left py-2 pr-4">Time</th>
                  <th class="text-left py-2 pr-4">Type</th>
                  <th class="text-left py-2 pr-4">Channel</th>
                  <th class="text-left py-2 pr-4">Tenant</th>
                  <th class="text-left py-2 pr-4">User</th>
                  <th class="text-left py-2 pr-4">Summary</th>
                  <th class="text-left py-2 pr-4">Details</th>
                </tr>
              </thead>
              <tbody id="inc_body"></tbody>
            </table>
          </div>

          <div class="mt-3 text-xs text-gray-500">
            Tip: Use this to answer “what decision led to that timeout?” without tailing PM2.
          </div>
        </div>

        <!-- Per-channel + hot spots -->
        <div class="mt-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
          <!-- Channels -->
          <div class="lg:col-span-2 bg-gray-900/60 border border-gray-800 rounded-2xl p-6 shadow">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-semibold">Per-channel activity</h3>
                <p class="text-xs text-gray-500 mt-1">
                  messages/commands/guard hits/errors from the ring buffer derived view.
                </p>
              </div>
              <div class="text-xs text-gray-400">
                sorted by last seen
              </div>
            </div>

            <div class="mt-4 overflow-x-auto">
              <table class="min-w-full text-sm">
                <thead class="text-gray-400">
                  <tr class="border-b border-gray-800">
                    <th class="text-left py-2 pr-4">Channel</th>
                    <th class="text-left py-2 pr-4">Tenant</th>
                    <th class="text-right py-2 px-2">Msgs</th>
                    <th class="text-right py-2 px-2">Cmd</th>
                    <th class="text-right py-2 px-2">Flood</th>
                    <th class="text-right py-2 px-2">Swarm</th>
                    <th class="text-right py-2 px-2">Mod</th>
                    <th class="text-right py-2 px-2">Err</th>
                    <th class="text-right py-2 pl-2">Last</th>
                  </tr>
                </thead>
                <tbody id="channelTable">
                  <% if (!derivedChannels.length) { %>
                    <tr>
                      <td colspan="9" class="py-4 text-gray-400">No channel data yet.</td>
                    </tr>
                    <% } else { %>
                      <% derivedChannels.slice(0, 20).forEach((ch)=> { %>
                        <tr class="border-t border-gray-900 bg-gray-950/30">
                          <td class="py-2 pr-4 font-semibold text-gray-200">
                            <%= ch.channelSlug %>
                          </td>
                          <td class="py-2 pr-4 text-gray-300">
                            <%= ch.scraplet_user_id %>
                          </td>
                          <td class="py-2 px-2 text-right tabular-nums">
                            <%= formatCount(ch.messages) %>
                          </td>
                          <td class="py-2 px-2 text-right tabular-nums">
                            <%= formatCount(ch.commands) %>
                          </td>
                          <td class="py-2 px-2 text-right tabular-nums">
                            <%= formatCount(ch.flood) %>
                          </td>
                          <td class="py-2 px-2 text-right tabular-nums">
                            <%= formatCount(ch.swarm) %>
                          </td>
                          <td class="py-2 px-2 text-right tabular-nums">
                            <%= formatCount(ch.moderation) %>
                          </td>
                          <td class="py-2 px-2 text-right tabular-nums">
                            <%= formatCount(ch.errors) %>
                          </td>
                          <td class="py-2 pl-2 text-right text-gray-400 tabular-nums">
                            <%= formatTimestamp(ch.last_ts) %>
                          </td>
                        </tr>
                        <% }) %>
                          <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Hot spots -->
          <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 shadow">
            <h3 class="text-lg font-semibold">Hot spots</h3>

            <div class="mt-4">
              <div class="text-xs text-gray-500 mb-2">Top talkers (ring derived)</div>
              <div id="topTalkers" class="space-y-2">
                <% if (!derivedTalkers.length) { %>
                  <div class="text-gray-400 text-sm">No talkers yet.</div>
                  <% } else { %>
                    <% derivedTalkers.slice(0, 8).forEach((t)=> { %>
                      <div class="bg-gray-950/40 border border-gray-800 rounded-xl px-3 py-2">
                        <div class="flex items-center justify-between">
                          <div class="text-sm font-semibold text-gray-200">
                            <%= t.senderUsername || "—" %>
                              <span class="text-xs text-gray-500 font-normal">(<%= t.senderUserId || "no-id" %>)</span>
                          </div>
                          <div class="text-xs text-gray-400">
                            <%= (t.channelSlug || "—" ) %> • tenant <%= t.scraplet_user_id %>
                          </div>
                        </div>
                        <div class="mt-1 text-xs text-gray-500 flex gap-3">
                          <span>msgs <span class="text-gray-300 font-mono">
                              <%= formatCount(t.messages) %>
                            </span></span>
                          <span>incidents <span class="text-gray-300 font-mono">
                              <%= formatCount(t.incidents) %>
                            </span></span>
                          <span>last <span class="text-gray-300 font-mono">
                              <%= formatTimestamp(t.last_ts) %>
                            </span></span>
                        </div>
                      </div>
                      <% }) %>
                        <% } %>
              </div>
            </div>

            <div class="mt-6">
              <div class="text-xs text-gray-500 mb-2">Top incident channels (weighted)</div>
              <div id="incidentChannels" class="space-y-2">
                <% if (!derivedIncidents.length) { %>
                  <div class="text-gray-400 text-sm">No incident channels yet.</div>
                  <% } else { %>
                    <% derivedIncidents.slice(0, 8).forEach((x)=> { %>
                      <div class="bg-gray-950/40 border border-gray-800 rounded-xl px-3 py-2">
                        <div class="flex items-center justify-between">
                          <div class="text-sm font-semibold text-gray-200">
                            <%= x.channelSlug %>
                          </div>
                          <div class="text-xs text-gray-400">tenant <%= x.scraplet_user_id %>
                          </div>
                        </div>
                        <div class="mt-1 text-xs text-gray-500 flex gap-3">
                          <span>score <span class="text-gray-300 font-mono">
                              <%= formatCount(x.score) %>
                            </span></span>
                          <span>flood <span class="text-gray-300 font-mono">
                              <%= formatCount(x.flood) %>
                            </span></span>
                          <span>swarm <span class="text-gray-300 font-mono">
                              <%= formatCount(x.swarm) %>
                            </span></span>
                          <span>mod <span class="text-gray-300 font-mono">
                              <%= formatCount(x.moderation) %>
                            </span></span>
                          <span>err <span class="text-gray-300 font-mono">
                              <%= formatCount(x.errors) %>
                            </span></span>
                        </div>
                      </div>
                      <% }) %>
                        <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- =========================================================
           3) SECURITY VECTORS
      ========================================================== -->
        <div class="mt-6 bg-gray-900/60 border border-gray-800 rounded-2xl p-6 shadow">
          <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
            <div>
              <h3 class="text-lg font-semibold">3) Security vectors (last 5m)</h3>
              <p class="text-xs text-gray-500 mt-1">
                What’s actually hitting your box right now: top paths, IPs, and UA clusters.
              </p>
            </div>
            <div class="text-xs text-gray-400">
              snapshot: <span id="secNow">
                <%= formatTimestamp(get(sbSecurity, "now" , null)) %>
              </span>
            </div>
          </div>

          <div class="mt-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="bg-gray-950/40 border border-gray-800 rounded-2xl p-4">
              <div class="text-sm font-semibold text-gray-200">Top paths</div>
              <div id="secTopPaths" class="mt-3 space-y-2">
                <% const tp=Array.isArray(secTop5m.top_paths) ? secTop5m.top_paths : []; %>
                  <% if (!tp.length) { %>
                    <div class="text-gray-400 text-sm">No probe paths yet.</div>
                    <% } else { %>
                      <% tp.slice(0, 10).forEach((x)=> { %>
                        <div
                          class="flex items-center justify-between bg-black/20 border border-gray-800 rounded-xl px-3 py-2">
                          <div class="text-xs text-gray-300 font-mono truncate pr-3">
                            <%= x.key %>
                          </div>
                          <div class="text-xs text-gray-400 tabular-nums">
                            <%= formatCount(x.count) %>
                          </div>
                        </div>
                        <% }) %>
                          <% } %>
              </div>
            </div>

            <div class="bg-gray-950/40 border border-gray-800 rounded-2xl p-4">
              <div class="text-sm font-semibold text-gray-200">Top IPs</div>
              <div id="secTopIps" class="mt-3 space-y-2">
                <% const ti=Array.isArray(secTop5m.top_ips) ? secTop5m.top_ips : []; %>
                  <% if (!ti.length) { %>
                    <div class="text-gray-400 text-sm">No probe IPs yet.</div>
                    <% } else { %>
                      <% ti.slice(0, 10).forEach((x)=> { %>
                        <div
                          class="flex items-center justify-between bg-black/20 border border-gray-800 rounded-xl px-3 py-2">
                          <div class="text-xs text-gray-300 font-mono truncate pr-3">
                            <%= x.key %>
                          </div>
                          <div class="text-xs text-gray-400 tabular-nums">
                            <%= formatCount(x.count) %>
                          </div>
                        </div>
                        <% }) %>
                          <% } %>
              </div>
            </div>

            <div class="bg-gray-950/40 border border-gray-800 rounded-2xl p-4">
              <div class="text-sm font-semibold text-gray-200">Top UAs</div>
              <div id="secTopUas" class="mt-3 space-y-2">
                <% const tu=Array.isArray(secTop5m.top_uas) ? secTop5m.top_uas : []; %>
                  <% if (!tu.length) { %>
                    <div class="text-gray-400 text-sm">No probe UAs yet.</div>
                    <% } else { %>
                      <% tu.slice(0, 10).forEach((x)=> { %>
                        <div
                          class="flex items-center justify-between bg-black/20 border border-gray-800 rounded-xl px-3 py-2">
                          <div class="text-xs text-gray-300 truncate pr-3">
                            <%= x.key %>
                          </div>
                          <div class="text-xs text-gray-400 tabular-nums">
                            <%= formatCount(x.count) %>
                          </div>
                        </div>
                        <% }) %>
                          <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Guard Events -->
        <div class="mt-6 bg-gray-900/60 border border-gray-800 rounded-2xl p-6 shadow">
          <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div>
              <h3 class="text-lg font-semibold">Guard Events</h3>
              <p class="text-xs text-gray-500 mt-1">
                Built from the Scrapbot ring buffer (no raw message text stored). Shows flood/swarm/mod hits + execution
                hints.
              </p>
            </div>

            <div class="flex flex-wrap gap-2 items-center">
              <select id="filterChannel" class="bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm">
                <option value="">All channels</option>
              </select>

              <select id="filterType" class="bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm">
                <option value="">All guard types</option>
                <option value="flood">Flood</option>
                <option value="swarm">Swarm</option>
                <option value="moderation">Moderation</option>
                <option value="error">Error</option>
              </select>

              <label class="inline-flex items-center gap-2 text-sm text-gray-300 select-none">
                <input id="onlyIncidents" type="checkbox" class="rounded" checked />
                only incidents
              </label>

              <input id="searchUser" placeholder="user / id"
                class="bg-gray-950 border border-gray-800 rounded-xl px-3 py-2 text-sm w-40" />
            </div>
          </div>

          <div class="mt-4 overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="text-gray-400">
                <tr class="border-b border-gray-800">
                  <th class="text-left py-2 pr-4">Time</th>
                  <th class="text-left py-2 pr-4">Channel</th>
                  <th class="text-left py-2 pr-4">Tenant</th>
                  <th class="text-left py-2 pr-4">User</th>
                  <th class="text-left py-2 pr-4">Role</th>
                  <th class="text-left py-2 pr-4">Events</th>
                  <th class="text-left py-2 pr-4">Details</th>
                </tr>
              </thead>
              <tbody id="guardEventsBody"></tbody>
            </table>
          </div>

          <div class="mt-3 text-xs text-gray-500">
            Tip: click “details” rows to expand raw JSON.
          </div>
        </div>

        <!-- Recent inbound -->
        <div class="mt-6 bg-gray-900/60 border border-gray-800 rounded-2xl p-6 shadow">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold">Recent inbound (ring buffer)</h3>
            <div class="text-xs text-gray-400">(No raw message content — safe)</div>
          </div>

          <div id="recentList" class="mt-4">
            <% if (!recentItems.length) { %>
              <div class="text-gray-400 text-sm">No recent items yet.</div>
              <% } else { %>
                <div class="divide-y divide-gray-800 rounded-xl overflow-hidden border border-gray-800">
                  <% recentItems.slice(0, 20).forEach((it)=> { %>
                    <div class="p-4 bg-gray-950/30">
                      <div class="flex items-center justify-between">
                        <div class="text-sm">
                          <span class="text-gray-400">
                            <%= formatTimestamp(it.ts) %>
                          </span>
                          <span class="mx-2 text-gray-700">•</span>
                          <span class="font-semibold">
                            <%= it.platform %>
                          </span>
                          <span class="mx-2 text-gray-700">•</span>
                          <span class="text-gray-200">
                            <%= it.channelSlug %>
                          </span>
                          <span class="mx-2 text-gray-700">•</span>
                          <span class="text-gray-400">tenant</span>
                          <span class="text-gray-200">
                            <%= it.scraplet_user_id %>
                          </span>
                        </div>

                        <div class="text-xs text-gray-400">
                          <span class="px-2 py-1 rounded bg-gray-800">
                            <%= it.userRole || "—" %>
                          </span>
                        </div>
                      </div>

                      <div class="mt-2 text-xs text-gray-400 flex flex-wrap gap-2">
                        <% if (it.commandMatched) { %><span
                            class="px-2 py-1 rounded bg-blue-900/50 border border-blue-800">command</span>
                          <% } %>
                            <% if (it.commandReplySent) { %><span
                                class="px-2 py-1 rounded bg-blue-900/50 border border-blue-800">reply</span>
                              <% } %>
                                <% if (it.flood) { %><span
                                    class="px-2 py-1 rounded bg-red-900/50 border border-red-800">flood</span>
                                  <% } %>
                                    <% if (it.swarm) { %><span
                                        class="px-2 py-1 rounded bg-purple-900/50 border border-purple-800">swarm</span>
                                      <% } %>
                                        <% if (it.moderation) { %><span
                                            class="px-2 py-1 rounded bg-orange-900/50 border border-orange-800">moderation</span>
                                          <% } %>
                                            <% if (it.pulse_active) { %><span
                                                class="px-2 py-1 rounded bg-green-900/50 border border-green-800">pulse</span>
                                              <% } %>
                                                <% if (it.error) { %><span
                                                    class="px-2 py-1 rounded bg-red-900/50 border border-red-800">error</span>
                                                  <% } %>
                      </div>
                    </div>
                    <% }) %>
                </div>
                <% } %>
          </div>
        </div>
      </section>

      <!-- =========================================================
         4) MODERATION TEST LAB
    ========================================================== -->
      <section class="mt-10">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">4) Moderation Test Lab</h2>
          <span
            class="px-2 py-1 rounded-lg text-xs font-semibold bg-yellow-700/50 border border-yellow-700 text-yellow-100">DRY
            RUN ONLY</span>
        </div>
        <p class="text-xs text-gray-500 mt-1">
          Deterministic moderation pipeline tests. All actions are hypothetical &mdash; nothing is ever executed.
        </p>

        <div class="mt-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
          <!-- Left: Test List -->
          <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-5 shadow">
            <div class="flex items-center justify-between">
              <h3 class="text-sm font-semibold text-gray-200">Tests</h3>
              <button id="tl_runAll"
                class="text-xs px-3 py-1.5 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-semibold transition">
                &#9654; Run All
              </button>
            </div>
            <div id="tl_list" class="mt-3 space-y-1 text-sm max-h-[480px] overflow-y-auto">
              <div class="text-gray-400 text-xs py-4">Loading tests&hellip;</div>
            </div>
            <div id="tl_summary" class="mt-3 text-xs text-gray-500"></div>
          </div>

          <!-- Right: Result Viewer -->
          <div class="lg:col-span-2 bg-gray-900/60 border border-gray-800 rounded-2xl p-5 shadow">
            <div class="flex items-center justify-between">
              <h3 id="tl_resultTitle" class="text-sm font-semibold text-gray-200">Select a test to run</h3>
              <span id="tl_resultBadge" class="hidden px-2 py-1 rounded-lg text-xs font-bold"></span>
            </div>
            <div id="tl_assertions" class="mt-3 space-y-1 hidden"></div>
            <div id="tl_actions" class="mt-3 hidden">
              <div class="text-xs text-gray-500 mb-1">Hypothetical Actions (DRY RUN)</div>
              <div id="tl_actionsBody" class="space-y-1"></div>
            </div>
            <details id="tl_rawWrap" class="mt-3 hidden">
              <summary class="text-xs text-gray-500 cursor-pointer hover:text-gray-300">Raw JSON</summary>
              <pre id="tl_raw"
                class="mt-1 text-xs text-gray-400 overflow-x-auto whitespace-pre bg-black/30 p-3 rounded-lg border border-gray-800 max-h-64 overflow-y-auto"></pre>
            </details>
          </div>
        </div>

        <!-- Audit Log -->
        <div class="mt-4 bg-gray-900/60 border border-gray-800 rounded-2xl p-5 shadow">
          <div class="flex items-center justify-between">
            <h3 class="text-sm font-semibold text-gray-200">Audit Log</h3>
            <div class="flex gap-2 items-center">
              <label class="inline-flex items-center gap-2 text-xs text-gray-400 select-none">
                <input id="tl_auditFilterRun" type="checkbox" class="rounded" />
                filter by test run
              </label>
              <button id="tl_auditRefresh"
                class="text-xs px-3 py-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 transition">
                Refresh
              </button>
            </div>
          </div>
          <div class="mt-3 overflow-x-auto">
            <table class="min-w-full text-xs">
