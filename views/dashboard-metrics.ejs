      <script>
        (() => {
          const $ = (id) => document.getElementById(id);

          function fmtTs(ts) {
            try {
              if (!ts) return "?";
              const d = new Date(ts);
              if (isNaN(d.getTime())) return "?";
              const diff = d.getTime() - Date.now();
              const abs = Math.abs(diff);
              const h = Math.floor(abs / 3600000);
              const m = Math.floor((abs % 3600000) / 60000);
              const suffix = diff < 0 ? " ago" : " left";
              const rel = h > 0 ? `${h}h ${m}m${suffix}` : `${m}m${suffix}`;
              return `${d.toISOString().slice(0,16).replace("T"," ")} (${rel})`;
            } catch { return "?"; }
          }

          function setBadge(id, text, tone) {
            const el = $(id);
            if (!el) return;
            el.textContent = text;
            el.className = "inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-bold";
            if (tone === "ok")   el.classList.add("bg-green-700/70", "border", "border-green-600", "text-green-200");
            else if (tone === "warn") el.classList.add("bg-yellow-700/70", "border", "border-yellow-600", "text-yellow-200");
            else if (tone === "bad")  el.classList.add("bg-red-700/70", "border", "border-red-600", "text-red-200");
            else el.classList.add("bg-gray-700", "text-gray-300");
          }

          async function loadBotHealth() {
            try {
              const r = await fetch("/dashboard/metrics/bot-health", { credentials: "same-origin" });
              const j = await r.json().catch(() => null);
              if (!r.ok || !j?.ok) { setBadge("kickHealthBadge", "ERROR", "bad"); return; }

              // Kick
              const h = j.kick.health;
              const toneMap = { ok: "ok", expiring_soon: "warn", expired: "bad", no_tokens: "bad", unknown: "muted" };
              const labelMap = { ok: "HEALTHY", expiring_soon: "EXPIRING", expired: "EXPIRED", no_tokens: "NO TOKENS", unknown: "UNKNOWN" };
              setBadge("kickHealthBadge", labelMap[h] || h.toUpperCase(), toneMap[h] || "muted");
              $("kickExpiry").textContent  = fmtTs(j.kick.expires_at);
              $("kickUpdated").textContent = fmtTs(j.kick.updated_at);
              $("kickScope").textContent   = j.kick.scope || "?";

              // Discord
              setBadge("discordHealthBadge", j.discord.online ? "ONLINE" : "OFFLINE", j.discord.online ? "ok" : "bad");

            } catch (e) {
              setBadge("kickHealthBadge", "ERROR", "bad");
              setBadge("discordHealthBadge", "ERROR", "bad");
            }
          }

          $("btnRefreshBotHealth")?.addEventListener("click", loadBotHealth);

          $("btnSendAlert")?.addEventListener("click", async () => {
            const msg = $("alertMessage")?.value?.trim() || "";
            if (!msg) { $("alertStatus").textContent = "Enter a message first."; return; }
            $("alertStatus").textContent = "Sending?";
            try {
              const r = await fetch("/dashboard/metrics/bot-health/alert", {
                method: "POST",
                headers: { "content-type": "application/json" },
                credentials: "same-origin",
                body: JSON.stringify({ message: msg }),
              });
              const j = await r.json().catch(() => null);
              if (!r.ok || !j?.ok) {
                $("alertStatus").textContent = j?.error || "Failed.";
                $("alertStatus").style.color = "rgb(248,113,113)";
              } else {
                $("alertStatus").textContent = "? Sent.";
                $("alertStatus").style.color = "rgb(52,211,153)";
              }
            } catch {
              $("alertStatus").textContent = "Request failed.";
              $("alertStatus").style.color = "rgb(248,113,113)";
            }
          });

          loadBotHealth();
        })();
      </script>

</body>

