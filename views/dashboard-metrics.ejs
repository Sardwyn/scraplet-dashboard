        <script>const $ = (id) => document.getElementById(id);

          function safeNum(v) {
            const n = Number(v);
            return Number.isFinite(n) ? n : 0;
          }

          function fmt(n) {
            try {
              return safeNum(n).toLocaleString();
            }

            catch {
              return String(n ?? 0);
            }
          }

          function fmtTs(ts) {
            try {
              if (!ts) return "—";
              const d = new Date(ts);
              if (Number.isNaN(d.getTime())) return "—";
              return d.toISOString().replace("T", " ").replace("Z", "");
            }

            catch {
              return "—";
            }
          }

          function setPill(el, on, onText, offText) {
            if (!el) return;
            el.textContent = on ? onText : offText;
            el.classList.remove("bg-green-700/70", "border-green-600", "bg-red-700/70", "border-red-600");
            el.classList.add(on ? "bg-green-700/70" : "bg-red-700/70");
            el.classList.add(on ? "border-green-600" : "border-red-600");
          }

          function setPillNeutral(el, on, onText, offText) {
            if (!el) return;
            el.textContent = on ? onText : offText;
            el.classList.remove("bg-green-700/50", "border-green-700", "bg-gray-800", "border-gray-700");
            el.classList.add(on ? "bg-green-700/50" : "bg-gray-800");
            el.classList.add(on ? "border-green-700" : "border-gray-700");
          }

          function uniq(arr) {
            return Array.from(new Set((arr || []).filter(Boolean)));
          }

          function escapeHtml(s) {
            return String(s ?? "").replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll('"', "&quot;").replaceAll("'", "&#039;");
          }

          function pill(label, kind) {
            const cls = kind === "flood" ? "bg-red-900/50 border-red-800" :
              kind === "swarm" ? "bg-purple-900/50 border-purple-800" : kind === "moderation" ? "bg-orange-900/50 border-orange-800" : kind === "error" ? "bg-red-900/50 border-red-800" : "bg-gray-800 border-gray-700";

            return `<span class="px-2 py-1 rounded border ${cls} text-xs">${
            escapeHtml(label)
          }

          </span>`;
          }

          function rowDetails(it) {
            const parts = [];

            if (it.flood) {
              const a = it.flood.action || "action";

              const d = it.flood.duration_seconds != null ? `${
              it.flood.duration_seconds
            }

            s` : "";

              parts.push(`${
                pill("flood", "flood")
              }

              <span class="text-gray-300" >${
                escapeHtml(a)
              }

              ${
                escapeHtml(d)
              }

              </span>`);
            }

            if (it.swarm) {
              const acts = Array.isArray(it.swarm.actions) ? it.swarm.actions.join(", ") : "";

              parts.push(`${
                pill("swarm", "swarm")
              }

              <span class="text-gray-300" >${
                escapeHtml(acts || "actions")
              }

              </span>`);
            }

            if (it.moderation) {
              const a = it.moderation.action || "action";

              parts.push(`${
                pill("moderation", "moderation")
              }

              <span class="text-gray-300" >${
                escapeHtml(a)
              }

              </span>`);
            }

            if (it.error) {
              parts.push(`${
                pill("error", "error")
              }

              <span class="text-gray-300" >${
                escapeHtml(String(it.error).slice(0, 200))
              }

              </span>`);
            }

            if (!parts.length) return `<span class="text-gray-500">—</span>`;

            return `<div class="flex flex-wrap gap-2">${
            parts.join("")
          }

          </div>`;
          }

          function isIncident(it) {
            return ! !(it?.flood || it?.swarm || it?.moderation || it?.error);
          }

          function matchesType(it, type) {
            if (!type) return true;
            if (type === "flood") return ! !it.flood;
            if (type === "swarm") return ! !it.swarm;
            if (type === "moderation") return ! !it.moderation;
            if (type === "error") return ! !it.error;
            return true;
          }

          function matchesUser(it, q) {
            if (!q) return true;
            const needle = String(q).toLowerCase().trim();
            if (!needle) return true;
            const u = String(it.senderUsername || "").toLowerCase();
            const id = String(it.senderUserId || "").toLowerCase();
            return u.includes(needle) || id.includes(needle);
          }

          function itemKey(it) {
            const mid = String(it?.message_id || "").trim();

            if (mid) return `m:${
            mid
          }

          `;

            const ts = String(it?.ts || "");
            const ch = String(it?.channelSlug || "");
            const tenant = String(it?.scraplet_user_id ?? "");
            const uid = String(it?.senderUserId || it?.senderUsername || "");
            const ev = String(it?.eventType || "");

            return `x:${
            ts
          }

          |${
            tenant
          }

          |${
            ch
          }

          |${
            uid
          }

          |${
            ev
          }

          `;
          }

          const expanded = new Set();

          function setExpanded(key, isOpen) {
            if (!key) return;
            if (isOpen) expanded.add(key);
            else expanded.delete(key);
          }

          function isExpanded(key) {
            return expanded.has(key);
          }

          let lastSnapshot = {
            scrapbotStatus: null,
            scrapbotMetrics: null,
            recentItems: [],
            securityTelemetrySnapshot: null,
            fetchedAt: 0,
          }

            ;

          function buildChannelOptions(items) {
            const channels = uniq((items || []).map(it => it.channelSlug).filter(Boolean)).sort();
            const sel = $("filterChannel");
            if (!sel) return;

            const current = sel.value;

            const opts = ['<option value="">All channels</option>'].concat(channels.map(ch => `<option value="${escapeHtml(ch)}" >${
                escapeHtml(ch)
              }

              </option>`));

            sel.innerHTML = opts.join("");

            if (current && channels.includes(current)) sel.value = current;
          }

          function renderChannelTable(channels, ringWindow) {
            const host = $("channelTable");
            if (!host) return;

            if ($("ringSize")) $("ringSize").textContent = ringWindow?.size ?? 0;

            if (!Array.isArray(channels) || !channels.length) {
              host.innerHTML = '<tr><td colspan="9" class="py-4 text-gray-400">No channel data yet.</td></tr>';
              return;
            }

            host.innerHTML = channels.slice(0, 20).map((ch) => ` <tr class="border-t border-gray-900 bg-gray-950/30" > <td class="py-2 pr-4 font-semibold text-gray-200" >${
              escapeHtml(ch.channelSlug || "?")
            }

            </td> <td class="py-2 pr-4 text-gray-300" >${
              escapeHtml(String(ch.scraplet_user_id ?? 0))
            }

            </td> <td class="py-2 px-2 text-right tabular-nums" >${
              fmt(ch.messages)
            }

            </td> <td class="py-2 px-2 text-right tabular-nums" >${
              fmt(ch.commands)
            }

            </td> <td class="py-2 px-2 text-right tabular-nums" >${
              fmt(ch.flood)
            }

            </td> <td class="py-2 px-2 text-right tabular-nums" >${
              fmt(ch.swarm)
            }

            </td> <td class="py-2 px-2 text-right tabular-nums" >${
              fmt(ch.moderation)
            }

            </td> <td class="py-2 px-2 text-right tabular-nums" >${
              fmt(ch.errors)
            }

            </td> <td class="py-2 pl-2 text-right text-gray-400 tabular-nums" >${
              fmtTs(ch.last_ts)
            }

            </td> </tr> `).join("");
          }

          function renderTopList(hostId, items) {
            const host = $(hostId);
            if (!host) return;

            const arr = Array.isArray(items) ? items : [];

            if (!arr.length) {
              host.innerHTML = `<div class="text-gray-400 text-sm">No data yet.</div>`;
              return;
            }

            host.innerHTML = arr.slice(0, 10).map((x) => ` <div class="flex items-center justify-between bg-black/20 border border-gray-800 rounded-xl px-3 py-2" > <div class="text-xs text-gray-300 ${hostId === " secTopUas" ? " " : " font-mono"} truncate pr-3" >${
              escapeHtml(x.key || "")
            }

            </div> <div class="text-xs text-gray-400 tabular-nums" >${
              fmt(x.count)
            }

            </div> </div> `).join("");
          }

          function updateKpis(sbStatus, sbMetrics, secSnap) {
            const counters = sbMetrics?.counters || {}

              ;
            const statusOk = ! !sbStatus?.ok;
            const dbOk = ! !(sbStatus?.db && sbStatus?.db?.ok);

            setPill($("pillOnline"), statusOk, "ONLINE", "OFFLINE");
            setPill($("pillDb"), dbOk, "OK", "FAIL");

            if ($("kpiInbound")) $("kpiInbound").textContent = fmt(counters["inbound_total"]);
            if ($("kpiErrors")) $("kpiErrors").textContent = fmt(counters["inbound_errors_total"]);
            if ($("kpiCmd")) $("kpiCmd").textContent = fmt(counters["commands_matched_total"]);
            if ($("kpiReplies")) $("kpiReplies").textContent = fmt(counters["commands_replies_sent_total"]);

            if ($("kpiFlood")) $("kpiFlood").textContent = fmt(counters["flood_tripped_total"]);
            if ($("kpiSwarm")) $("kpiSwarm").textContent = fmt(counters["swarm_matched_total"]);
            if ($("kpiMod")) $("kpiMod").textContent = fmt(counters["moderation_matched_total"]);

            if ($("lastUpdate")) $("lastUpdate").textContent = fmtTs(sbMetrics?.now || sbStatus?.now);

            const upMs = safeNum(sbMetrics?.uptime_ms);
            const upSec = Math.floor(upMs / 1000);
            const h = Math.floor(upSec / 3600);
            const m = Math.floor((upSec % 3600) / 60);
            const s = upSec % 60;

            if ($("uptime")) $("uptime").textContent = `${
            h
          }

          h ${
            m
          }

          m ${
            s
          }

          s`;

            const pulseLatest = Array.isArray(sbMetrics?.pulse_latest) ? sbMetrics.pulse_latest : [];
            const top = pulseLatest[0] || null;
            if ($("topPulseKey")) $("topPulseKey").textContent = top?.key || "—";
            if ($("pulseActive")) $("pulseActive").textContent = top?.pulse?.active ? "true" : "false";
            if ($("tripwire")) $("tripwire").textContent = top?.tripwire ? "set" : "null";

            // SECURITY
            const ok = ! !secSnap?.ok;
            setPillNeutral($("pillSec"), ok, "LIVE", "—");

            const r1 = secSnap?.rolling?.last_1m || {}

              ;

            const r5 = secSnap?.rolling?.last_5m || {}

              ;

            const buf = secSnap?.buffer || {}

              ;

            const top5 = secSnap?.top_5m || {}

              ;

            if ($("secNow")) $("secNow").textContent = fmtTs(secSnap?.now);

            if ($("kpiProbes1m")) $("kpiProbes1m").textContent = fmt(r1.probes);
            if ($("kpiBlocked1m")) $("kpiBlocked1m").textContent = fmt(r1.blocked);

            if ($("kpiProbes5m")) $("kpiProbes5m").textContent = fmt(r5.probes);
            if ($("kpiBlocked5m")) $("kpiBlocked5m").textContent = fmt(r5.blocked);

            if ($("kpiReq5m")) $("kpiReq5m").textContent = fmt(r5.req);
            if ($("kpi4xx5m")) $("kpi4xx5m").textContent = fmt(r5.s4xx);
            if ($("kpi5xx5m")) $("kpi5xx5m").textContent = fmt(r5.s5xx);

            if ($("kpiProbeBuffered")) $("kpiProbeBuffered").textContent = fmt(buf.probe_events_buffered);
            if ($("kpiProbeMax")) $("kpiProbeMax").textContent = fmt(buf.max_probe_events);

            renderTopList("secTopPaths", top5.top_paths);
            renderTopList("secTopIps", top5.top_ips);
            renderTopList("secTopUas", top5.top_uas);
          }

          function renderGuardEvents(items) {
            const body = $("guardEventsBody");
            if (!body) return;

            const chan = $("filterChannel")?.value || "";
            const type = $("filterType")?.value || "";
            const onlyInc = $("onlyIncidents")?.checked !== false;
            const q = $("searchUser")?.value || "";

            const filtered = (items || []).filter(it => it && (!onlyInc || isIncident(it))).filter(it => !chan || String(it.channelSlug || "") === chan).filter(it => matchesType(it, type)).filter(it => matchesUser(it, q)).slice(0, 50);

            if (!filtered.length) {
              body.innerHTML = `<tr><td colspan="7" class="py-4 text-gray-400">No matching guard events.</td></tr>`;
              return;
            }

            const rows = filtered.map((it) => {
              const key = itemKey(it);
              const ts = fmtTs(it.ts);
              const channel = it.channelSlug || "—";
              const tenant = it.scraplet_user_id ?? 0;
              const user = it.senderUsername || "—";

              const userId = it.senderUserId ? ` (${
                  it.senderUserId
                })` : "";
              const role = it.userRole || "—";

              const has = [];
              if (it.flood) has.push(pill("flood", "flood"));
              if (it.swarm) has.push(pill("swarm", "swarm"));
              if (it.moderation) has.push(pill("moderation", "moderation"));
              if (it.error) has.push(pill("error", "error"));
              if (it.commandMatched) has.push(pill("cmd", "other"));
              if (it.commandReplySent) has.push(pill("reply", "other"));
              if (it.pulse_active) has.push(pill("pulse", "other"));
              if (it.tripwire) has.push(pill("tripwire", "other"));

              const summary = has.length ? `<div class="flex flex-wrap gap-2" >${
                has.join("")
              }

              </div>` : `<span class="text-gray-500" >—</span>`;
              const raw = escapeHtml(JSON.stringify(it, null, 2));

              const detailId = `detail_${
                key.replaceAll(":", "_").replaceAll("|", "_")
              }

              `;
              const open = isExpanded(key);

              return ` <tr class="border-t border-gray-900 bg-gray-950/30" > <td class="py-2 pr-4 text-gray-300 tabular-nums" >${
                ts
              }

              </td> <td class="py-2 pr-4 text-gray-200 font-semibold" >${
                escapeHtml(channel)
              }

              </td> <td class="py-2 pr-4 text-gray-300 tabular-nums" >${
                escapeHtml(String(tenant))
              }

              </td> <td class="py-2 pr-4 text-gray-200" >${
                escapeHtml(user)
              }

              <span class="text-gray-500" >${
                escapeHtml(userId)
              }

              </span></td> <td class="py-2 pr-4 text-gray-300" >${
                escapeHtml(role)
              }

              </td> <td class="py-2 pr-4" >${
                summary
              }

              </td> <td class="py-2 pr-4" > <button data-toggle="${escapeHtml(detailId)}"
              data-key="${escapeHtml(key)}"
              class="text-xs px-3 py-1 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700"

              >details</button> </td> </tr> <tr id="${escapeHtml(detailId)}" class="${open ? " " : " hidden"} border-t border-gray-900" > <td colspan="7" class="py-3" > <div class="bg-gray-950/60 border border-gray-800 rounded-xl p-3" > <div class="text-xs text-gray-500 mb-2" >Summary</div> ${
                rowDetails(it)
              }

              <div class="mt-3 text-xs text-gray-500 mb-2" >Raw</div> <pre class="text-xs text-gray-300 overflow-x-auto whitespace-pre bg-black/30 p-3 rounded-lg border border-gray-800" >${
                raw
              }

              </pre> </div> </td> </tr> `;
            }).join("");

            body.innerHTML = rows;

            body.querySelectorAll("button[data-toggle]").forEach(btn => {
              btn.addEventListener("click", () => {
                const id = btn.getAttribute("data-toggle");
                const key = btn.getAttribute("data-key");
                const row = document.getElementById(id);
                if (!row || !key) return;
                const willOpen = row.classList.contains("hidden");
                row.classList.toggle("hidden");
                setExpanded(key, willOpen);
              });
            });
          }

          function renderFromCache() {
            const sbStatus = lastSnapshot.scrapbotStatus || {}

              ;

            const sbMetrics = lastSnapshot.scrapbotMetrics || {}

              ;
            const items = Array.isArray(lastSnapshot.recentItems) ? lastSnapshot.recentItems : [];

            const sec = lastSnapshot.securityTelemetrySnapshot || {}

              ;

            updateKpis(sbStatus, sbMetrics, sec);

            const derived = sbMetrics.derived || {}

              ;

            renderChannelTable(Array.isArray(derived.channels) ? derived.channels : [], derived.ring_window || {});
            buildChannelOptions(items);
            renderGuardEvents(items);
          }

          async function fetchLatest() {
            try {
              const resp = await fetch("/dashboard/metrics/data", {
                cache: "no-store"
              });
              const data = await resp.json().catch(() => null);
              if (!data || !data.ok) return;

              lastSnapshot = {
                scrapbotStatus: data.scrapbotStatus || {}

                ,
                scrapbotMetrics: data.scrapbotMetrics || {}

                ,
                recentItems: Array.isArray(data.scrapbotRecent?.items) ? data.scrapbotRecent.items : [],
                securityTelemetrySnapshot: data.securityTelemetrySnapshot || data.securityTelemetry || data.scrapbotSecurity || null,
                fetchedAt: Date.now(),
              }

                ;

              renderFromCache();
            }

            catch (e) {
              // keep last render
            }
          }

          function bindFilters() {

            ["filterChannel",
              "filterType",
              "onlyIncidents",
              "searchUser"].forEach((id) => {
                const el = $(id);
                if (!el) return;
                el.addEventListener("input", renderFromCache);
                el.addEventListener("change", renderFromCache);
              });
          }

          let timer = null;

          function start() {
            bindFilters();
            bindModerationExtras();
            fetchLatest();
            if (timer) clearInterval(timer);
            timer = setInterval(fetchLatest, 2500);
          }

          $("btnRefreshNow")?.addEventListener("click", fetchLatest);

          // =========================================================
          // Moderation runtime + pipeline test + incidents (DB)
          // =========================================================
          async function rtLoad() {
            try {
              const r = await fetch("/api/moderation/runtime", {
                cache: "no-store"
              });
              const j = await r.json().catch(() => null);
              if (!j || !j.ok) throw new Error(j?.error || "failed");
              if ($("rt_enforcement")) $("rt_enforcement").value = j.runtime?.enforcement || "off";
              if ($("rt_usePulseTripwire")) $("rt_usePulseTripwire").checked = ! !j.runtime?.usePulseTripwire;
              if ($("rt_status")) $("rt_status").textContent = "loaded";
            }

            catch (e) {
              if ($("rt_status")) $("rt_status").textContent = "load failed";
            }
          }

          async function rtApply() {
            try {
              const body = {
                enforcement: $(
                  "rt_enforcement")?.value || "off",
                usePulseTripwire: ! !$(
                  "rt_usePulseTripwire")?.checked,
              }

                ;

              const r = await fetch("/api/moderation/runtime", {

                method: "POST",
                headers: {
                  "content-type": "application/json"
                }

                ,
                body: JSON.stringify(body),
              }
              );
              const j = await r.json().catch(() => null);
              if (!j || !j.ok) throw new Error(j?.error || "failed");
              if ($("rt_status")) $("rt_status").textContent = "applied";
            }

            catch (e) {
              if ($("rt_status")) $("rt_status").textContent = "apply failed";
            }
          }

          function ptUuid() {
            if (typeof crypto !== "undefined" && crypto.randomUUID) return crypto.randomUUID();
            return "pt_" + Math.random().toString(16).slice(2) + "_" + Date.now();
          }

          async function ptRun() {
            const out = $("pt_out");

            if (out) out.textContent = `[${
            new Date().toISOString()
          }

          ] running…\n`+ (out.textContent || "");

            const payload = {
              platform: "kick",
              scraplet_user_id: Number($(
                "pt_userId")?.value || 0) || 0,
              channelSlug: ($(
                "pt_channel")?.value || "").trim(),
              text: ($(
                "pt_text")?.value || "").toString(),
              senderUsername: ($(
                "pt_senderUsername")?.value || "").trim(),
              senderUserId: Number($(
                "pt_senderUserId")?.value || 0) || 0,
              userRole: ($(
                "pt_userRole")?.value || "everyone").trim(),
              message_id: ($(
                "pt_messageId")?.value || "").trim() || ptUuid(),
            }

              ;

            try {
              const r = await fetch("/api/moderation/pipeline_test", {

                method: "POST",
                headers: {
                  "content-type": "application/json"
                }

                ,
                body: JSON.stringify(payload),
              }
              );
              const j = await r.json().catch(() => null);
              const txt = JSON.stringify(j, null, 2);
              if (out) out.textContent = txt + "\n\n" + (out.textContent || "");
            }

            catch (e) {
              if (out) out.textContent = `ERROR: ${
            String(e?.message || e)
          }

          \n\n`+ (out.textContent || "");
            }
          }

          const incExpanded = new Set();

          function incKey(x) {
            return String(x?.id || x?.ts || "") + "|" + String(x?.type || "");
          }

          function renderIncidents(items) {
            const body = $("inc_body");
            if (!body) return;

            const arr = Array.isArray(items) ? items : [];

            if (!arr.length) {
              body.innerHTML = `<tr><td colspan="7" class="py-4 text-gray-400">No incidents yet.</td></tr>`;
              return;
            }

            body.innerHTML = arr.slice(0, 80).map((x) => {
              const key = incKey(x);
              const open = incExpanded.has(key);
              const id = "inc_" + key.replaceAll(/[^a-zA-Z0-9_]/g, "_");

              const ts = fmtTs(x.ts || x.created_at || x.occurred_at);
              const type = x.type || x.incident_type || "—";
              const ch = x.channel_slug || x.channelSlug || "—";
              const tenant = x.scraplet_user_id ?? x.tenant_id ?? "—";
              const user = x.sender_username || x.senderUsername || x.target_username || x.user || "—";
              const summary = x.summary || x.action || x.reason || (x.meta && (x.meta.action || x.meta.reason)) || "";

              const raw = escapeHtml(JSON.stringify(x, null, 2));

              return ` <tr class="border-t border-gray-900 bg-gray-950/30" > <td class="py-2 pr-4 text-gray-300 tabular-nums" >${
                escapeHtml(ts)
              }

              </td> <td class="py-2 pr-4 text-gray-200 font-semibold" >${
                escapeHtml(type)
              }

              </td> <td class="py-2 pr-4 text-gray-200" >${
                escapeHtml(ch)
              }

              </td> <td class="py-2 pr-4 text-gray-300 tabular-nums" >${
                escapeHtml(String(tenant))
              }

              </td> <td class="py-2 pr-4 text-gray-200" >${
                escapeHtml(user)
              }

              </td> <td class="py-2 pr-4 text-gray-300" >${
                escapeHtml(String(summary).slice(0, 120))
              }

              </td> <td class="py-2 pr-4" > <button data-inc-toggle="${escapeHtml(id)}" data-inc-key="${escapeHtml(key)}"

              class="text-xs px-3 py-1 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700" >details</button> </td> </tr> <tr id="${escapeHtml(id)}" class="${open ? " " : " hidden"} border-t border-gray-900" > <td colspan="7" class="py-3" > <div class="bg-gray-950/60 border border-gray-800 rounded-xl p-3" > <pre class="text-xs text-gray-300 overflow-x-auto whitespace-pre bg-black/30 p-3 rounded-lg border border-gray-800" >${
                raw
              }

              </pre> </div> </td> </tr> `;
            }).join("");

            body.querySelectorAll("button[data-inc-toggle]").forEach(btn => {
              btn.addEventListener("click", () => {
                const id = btn.getAttribute("data-inc-toggle");
                const key = btn.getAttribute("data-inc-key");
                const row = document.getElementById(id);
                if (!row || !key) return;
                const willOpen = row.classList.contains("hidden");
                row.classList.toggle("hidden");
                if (willOpen) incExpanded.add(key);
                else incExpanded.delete(key);
              });
            });
          }

          async function fetchIncidents() {
            const tenant = Number($("inc_userId")?.value || 0) || 0;
            const channel = ($("inc_channel")?.value || "").trim();
            const limit = Number($("inc_limit")?.value || 50) || 50;

            if (!tenant) return;

            const qs = new URLSearchParams();
            qs.set("scraplet_user_id", String(tenant));
            qs.set("platform", "kick");
            if (channel) qs.set("channel_slug", channel);
            qs.set("limit", String(limit));

            try {
              const r = await fetch("/api/moderation/incidents?" + qs.toString(), {
                cache: "no-store"
              });
              const j = await r.json().catch(() => null);
              const items = j?.items || j?.incidents || j?.data || [];
              renderIncidents(items);
            }

            catch (e) {
              renderIncidents([]);
            }
          }

          let incTimer = null;

          function bindModerationExtras() {
            $("rt_load")?.addEventListener("click", rtLoad);
            $("rt_apply")?.addEventListener("click", rtApply);
            $("pt_run")?.addEventListener("click", ptRun);
            $("inc_refresh")?.addEventListener("click", fetchIncidents);

            // initial pulls
            rtLoad();
            fetchIncidents();

            if (incTimer) clearInterval(incTimer);
            incTimer = setInterval(fetchIncidents, 5000);
          }

          start();

        </script>
        <!--=========================================================Test Controls runner (in-browser load
          generator)==========================================================-->
          <script>(function () {
              const LS_KEY = "scrapbot_test_secret";

              const $ = (id) => document.getElementById(id);
              const logEl = $("tc_log");

              let running = false;
              let stopRequested = false;

              function setStatus(text, kind) {
                const el = $("tc_status");
                if (!el) return;
                el.textContent = text;

                el.classList.remove("bg-gray-800", "border-gray-700", "text-gray-200");
                el.classList.remove("bg-green-700/50", "border-green-700", "text-green-100");
                el.classList.remove("bg-red-700/50", "border-red-700", "text-red-100");
                el.classList.remove("bg-blue-700/50", "border-blue-700", "text-blue-100");

                if (kind === "ok") el.classList.add("bg-green-700/50", "border", "border-green-700", "text-green-100");
                else if (kind === "error") el.classList.add("bg-red-700/50", "border", "border-red-700", "text-red-100");
                else if (kind === "running") el.classList.add("bg-blue-700/50", "border", "border-blue-700", "text-blue-100");
                else el.classList.add("bg-gray-800", "border", "border-gray-700", "text-gray-200");
              }

              function setProgress(done, total) {
                const bar = $("tc_progressBar");
                const txt = $("tc_progressText");

                if (txt) txt.textContent = `${
                done
              }

              / ${
                total
              }

              `;
                if (!bar) return;

                if (!total) {
                  bar.style.width = "0%"; return;
                }

                bar.style.width = `${
                Math.max(0, Math.min(100, Math.round((done / total) * 100)))
              }

              %`;
              }

              function disableControls(disabled) {
                ["tc_swarm_200", "tc_swarm_500", "tc_swarm_cinematic", "tc_swarm_linkspam", "tc_flood_emoji",
                  "tc_stop", "tc_save", "tc_clear", "tc_log_clear",
                  "tc_text", "tc_channel", "tc_userId", "tc_broadcasterUserId",
                  "tc_users", "tc_repeats", "tc_interval", "tc_concurrency",
                  "tc_link_domain", "tc_link_rate", "tc_emoji_intensity", "tc_cine_variance"

                ].forEach(id => {
                  const el = $(id);
                  if (el) el.disabled = ! !disabled;
                });
              }

              function log(msg) {
                if (!logEl) return;

                const line = `[${
                new Date().toISOString()
              }

              ] ${
                msg
              }

              `;
                logEl.textContent = (line + "\n" + logEl.textContent).slice(0, 14000);
              }

              function getSecret() {
                return ($("tc_secret")?.value || localStorage.getItem(LS_KEY) || "").trim();
              }

              function updateSecretHint() {
                const hint = $("tc_secretHint");
                if (!hint) return;
                const saved = localStorage.getItem(LS_KEY);
                hint.textContent = saved ? "secret saved locally" : "not saved";
              }

              function saveSecret() {
                const s = ($("tc_secret")?.value || "").trim();

                if (!s) {
                  log("No secret entered."); setStatus("missing secret", "error"); return;
                }

                localStorage.setItem(LS_KEY, s);
                updateSecretHint();
                log("Secret saved to localStorage.");
                setStatus("secret saved", "ok");
              }

              function clearSecret() {
                localStorage.removeItem(LS_KEY);
                if ($("tc_secret")) $("tc_secret").value = "";
                updateSecretHint();
                log("Secret cleared.");
                setStatus("idle", "idle");
              }

              async function postInbound(payload, secret) {
                const r = await fetch("/api/inbound/kick", {

                  method: "POST",
                  headers: {
                    "content-type": "application/json",
                    "x-scrapbot-secret": secret,
                  }

                  ,
                  body: JSON.stringify(payload),
                });

                const text = await r.text();

                if (!r.ok) throw new Error(`HTTP ${
                r.status
              }

              : ${
                text
              }

              `);
                return text;
              }

              function uuid() {
                if (typeof crypto !== "undefined" && crypto.randomUUID) return crypto.randomUUID();
                return "m_" + Math.random().toString(16).slice(2) + "_" + Date.now();
              }

              const sleep = (ms) => new Promise(res => setTimeout(res, ms));

              function clamp(n, lo, hi) {
                n = Number(n);
                if (!Number.isFinite(n)) n = lo;
                return Math.max(lo, Math.min(hi, n));
              }

              function pick(arr) {
                return arr[Math.floor(Math.random() * arr.length)];
              }

              function maybe(pct) {
                return Math.random() * 100 < pct;
              }

              function obfuscateUrl(url) {
                const variants = [url,
                  url.replace("https://", "http://"),
                  url.replace("https://", "hxxps://"),
                  url.replace("https://", "h t t p s : / / "),
                  url.replace("://", " :// "),
                  url.replace(/\./g, " dot "),
                  url.replace(/\./g, "[dot]"),
                  url.replace(/\//g, " / "),
                  url.replace("discord.gg", "discord . gg"),
                  url.replace("discord.gg", "d i s c o r d . g g"),
                ];
                return pick(variants);
              }

              function buildLinkSpamText(baseText, domain) {
                const url = `https: //${domain}/` + Math.random().toString(16).slice(2, 8);
                const leadIns = ["join fast",
                  "free nitro",
                  "mods asleep",
                  "limited offer",
                  "best community",
                  "claim here",
                  "100% legit",
                  "new drop",
                ];
                const tail = pick(["", "!!!", " 🔥", " ✅", " (real)", " (working)", " rn"]);

                return `${
            pick(leadIns)
          }

          ${
            obfuscateUrl(url)
          }

          ${
            baseText
          }

          ${
            tail
          }

          `.trim();
              }

              function buildEmojiFloodText(baseText, intensity) {
                const emojis = ["🔥", "😂", "💀", "✅", "🚀", "💎", "🎯", "🧠", "👀", "😈", "😳", "✨", "⚡", "🟢", "🎉", "🙌"];
                const count = clamp(intensity, 1, 10) * 3 + Math.floor(Math.random() * 6);
                let blob = "";
                for (let i = 0; i < count; i++) blob += pick(emojis);

                if (maybe(35)) return `${
            blob
          }

          ${
            baseText
          }

          ${
            blob
          }

          `.trim();
                return blob;
              }

              function buildCinematicText(baseText, variancePct) {

                const variants = [baseText,
                  baseText.toUpperCase(),
                  baseText.replace(/\bfree\b/i, "FREE"),
                  baseText.replace(/\bfollowers\b/i, "followers rn"),
                  `yo ${
            baseText
          }

          `,
                  `${
            baseText
          }

          (no cap)`,
                  `${
            baseText
          }

          ✅`,
                  `${
            baseText
          }

          right now`,
                  `${
            baseText
          }

          legit`,
                  `${
            baseText
          }

          check bio`,
                ];

                let t = maybe(variancePct) ? pick(variants) : baseText;

                if (maybe(variancePct * 0.5)) t += pick(["!", "!!", "!!!", " 🔥", " 👀", " ✅", " 💀"]);
                if (maybe(variancePct * 0.25)) t = pick(["bro", "nah", "yo", "okay"]) + " " + t;

                return t.trim();
              }

              async function runScenario({

                label,
                users,
                repeats,
                intervalMs,
                concurrency,
                senderPrefix = "SwarmUser",
                textBuilder,
                staggerMs = 0,
              }) {
                if (running) {
                  log("Already running."); return;
                }

                const secret = getSecret();

                if (!secret) {
                  log("Missing secret. Paste it and hit Save."); setStatus("missing secret", "error"); return;
                }

                const channelSlug = ($("tc_channel")?.value || "scraplet").trim() || "scraplet";
                const scraplet_user_id = parseInt($("tc_userId")?.value, 10) || 4;
                const broadcasterUserId = parseInt($("tc_broadcasterUserId")?.value, 10) || 1017792;

                users = clamp(users, 1, 8000);
                repeats = clamp(repeats, 1, 500);
                intervalMs = clamp(intervalMs, 0, 20000);
                concurrency = clamp(concurrency, 1, 80);
                staggerMs = clamp(staggerMs, 0, 2000);

                stopRequested = false;
                running = true;
                disableControls(true);
                setStatus("running", "running");

                const total = users * repeats;
                let done = 0;
                setProgress(0, total);

                log(`${
              label
            }

            starting: users=${
              users
            }

            repeats=${
              repeats
            }

            interval=${
              intervalMs
            }

            ms concurrency=${
              concurrency
            }

            stagger=${
              staggerMs
            }

            ms`);

                try {
                  for (let rep = 0; rep < repeats; rep++) {
                    if (stopRequested) break;

                    const jobs = [];

                    for (let i = 0; i < users; i++) {
                      const senderUsername = `${
                  senderPrefix
                }

                ${
                  String(i + 1).padStart(3, "0")
                }

                `;
                      const senderUserId = 9000000 + i + (rep * users);

                      const payload = {
                        platform: "kick",
                        scraplet_user_id,
                        channelSlug,
                        broadcasterUserId,
                        senderUsername,
                        senderUserId,
                        userRole: "everyone",
                        text: textBuilder ? textBuilder(i, rep) : ($("tc_text")?.value || "free followers"),
                        eventType: "chat.message.sent",
                        message_id: uuid(),
                      }

                        ;

                      jobs.push({
                        payload, delay: staggerMs ? Math.floor(Math.random() * staggerMs) : 0
                      });
                    }

                    let idx = 0;

                    async function worker() {
                      while (idx < jobs.length && !stopRequested) {
                        const mine = jobs[idx++];
                        if (mine.delay) await sleep(mine.delay);
                        await postInbound(mine.payload, secret);
                        done++;
                        if (done % 10 === 0 || done === total) setProgress(done, total);
                      }
                    }

                    await Promise.all(Array.from({
                      length: concurrency
                    }

                      , () => worker()));

                    log(`${
              label
            }

            rep ${
              rep + 1
            }

            /${
              repeats
            }

            done`);
                    if (stopRequested) break;
                    if (intervalMs > 0) await sleep(intervalMs);
                  }

                  if (stopRequested) {
                    log(`${
              label
            }

            stopped.`);
                    setStatus("stopped", "error");
                  }

                  else {
                    log(`${
              label
            }

            complete.`);
                    setStatus("done", "ok");
                  }
                }

                catch (e) {
                  log(`${
              label
            }

            FAILED: ${
              e.message || e
            }

            `);
                  setStatus("failed", "error");
                }

                finally {
                  running = false;
                  disableControls(false);
                }
              }

              function runBasicSwarm(users, repeats, intervalMs, concurrencyOverride) {
                const text = ($("tc_text")?.value || "free followers").trim() || "free followers";
                const concurrency = concurrencyOverride ?? (parseInt($("tc_concurrency")?.value, 10) || 6);

                return runScenario({
                  label: `Swarm ${
              users
            }

            `,
                  users,
                  repeats,
                  intervalMs,
                  concurrency,
                  senderPrefix: "SwarmUser",
                  textBuilder: () => text,
                  staggerMs: 0,
                });
              }

              function runCinematicSwarm() {
                const base = ($("tc_text")?.value || "free followers").trim() || "free followers";
                const variance = clamp(parseInt($("tc_cine_variance")?.value, 10) || 55, 0, 100);

                return runScenario({
                  label: "Cinematic Swarm",
                  users: parseInt($("tc_users")?.value, 10) || 200,
                  repeats: parseInt($("tc_repeats")?.value, 10) || 3,
                  intervalMs: parseInt($("tc_interval")?.value, 10) || 120,
                  concurrency: parseInt($("tc_concurrency")?.value, 10) || 6,
                  senderPrefix: "CineUser",
                  staggerMs: 180,
                  textBuilder: () => buildCinematicText(base, variance),
                });
              }

              function runLinkSpam() {
                const base = ($("tc_text")?.value || "free followers").trim() || "free followers";
                const domain = ($("tc_link_domain")?.value || "discord.gg").trim() || "discord.gg";
                const linkRate = clamp(parseInt($("tc_link_rate")?.value, 10) || 30, 0, 100);

                return runScenario({

                  label: "Link Spam",
                  users: parseInt($("tc_users")?.value, 10) || 200,
                  repeats: parseInt($("tc_repeats")?.value, 10) || 3,
                  intervalMs: parseInt($("tc_interval")?.value, 10) || 120,
                  concurrency: parseInt($("tc_concurrency")?.value, 10) || 6,
                  senderPrefix: "LinkUser",
                  staggerMs: 60,
                  textBuilder: () => {
                    if (maybe(linkRate)) return buildLinkSpamText(base, domain);
                    return buildCinematicText(base, 35);
                  }

                  ,
                });
              }

              function runEmojiFlood() {
                const base = ($("tc_text")?.value || "free followers").trim() || "free followers";
                const intensity = clamp(parseInt($("tc_emoji_intensity")?.value, 10) || 7, 1, 10);

                return runScenario({
                  label: "Emoji Flood",
                  users: clamp(parseInt($("tc_users")?.value, 10) || 40, 1, 500),
                  repeats: clamp(parseInt($("tc_repeats")?.value, 10) || 8, 1, 200),
                  intervalMs: clamp(parseInt($("tc_interval")?.value, 10) || 20, 0, 2000),
                  concurrency: clamp(parseInt($("tc_concurrency")?.value, 10) || 10, 1, 50),
                  senderPrefix: "EmojiUser",
                  staggerMs: 10,
                  textBuilder: () => buildEmojiFloodText(base, intensity),
                });
              }

              function wire() {
                $("tc_save")?.addEventListener("click", saveSecret);
                $("tc_clear")?.addEventListener("click", clearSecret);

                $("tc_swarm_200")?.addEventListener("click", () => runBasicSwarm(200, 3, 120));
                $("tc_swarm_500")?.addEventListener("click", () => runBasicSwarm(500, 2, 140));

                $("tc_swarm_cinematic")?.addEventListener("click", runCinematicSwarm);
                $("tc_swarm_linkspam")?.addEventListener("click", runLinkSpam);
                $("tc_flood_emoji")?.addEventListener("click", runEmojiFlood);

                $("tc_stop")?.addEventListener("click", () => {
                  if (!running) {
                    log("Not running."); return;
                  }

                  stopRequested = true;
                  log("Stop requested…");
                  setStatus("stopping…", "running");
                });

                $("tc_log_clear")?.addEventListener("click", () => {
                  if (logEl) logEl.textContent = "";
                  setProgress(0, 0);
                  setStatus("idle", "idle");
                });

                const saved = localStorage.getItem(LS_KEY);
                if (saved && $("tc_secret")) $("tc_secret").value = saved;

                updateSecretHint();
                log("Test Controls ready.");
              }

              wire();
            })();
          </script>

