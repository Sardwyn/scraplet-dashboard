          _$('cl_runnerForm').onsubmit = async (e) => {
            e.preventDefault();
            const container = _$('cl_traceResult');
            if (container) container.innerHTML = '<div class="h-full flex items-center justify-center text-gray-500 text-sm">Running...</div>';

            const body = {
              messageText: _$('cl_messageText').value,
              userRole: _$('cl_userRole').value,
              userName: _$('cl_userName').value
            }

              ;
            const result = await clApi('/dashboard/metrics/tests/commands/run', 'POST', body);
            renderCommandTrace(result);
          }

            ;

          function renderCommandTrace(data) {
            const container = _$('cl_traceResult');
            const badgeContainer = _$('cl_statusBadge');
            if (!container) return;

            if (!data?.ok) {
              container.innerHTML = `<div class="p-4 text-red-400 text-xs bg-red-900/20 border border-red-900 rounded-lg">Error: ${escH(data?.error || 'Unknown error')}</div>`;
              return;
            }

            const trace = data.trace;
            const matched = trace.command.matched;

            let badgeHtml = matched ? '<span class="px-2 py-0.5 rounded text-[10px] font-bold bg-green-700/50 border border-green-700 text-green-100">MATCHED</span>'
              : '<span class="px-2 py-0.5 rounded text-[10px] font-bold bg-gray-700/50 border border-gray-700 text-gray-100">NO MATCH</span>';

            if (trace.command.denied) {
              badgeHtml = '<span class="px-2 py-0.5 rounded text-[10px] font-bold bg-red-700/50 border border-red-700 text-red-100">DENIED</span>';
            }

            if (badgeContainer) badgeContainer.innerHTML = badgeHtml;

            const actionsHtml = trace.actions_results.length > 0 ? trace.actions_results.map(a => ` <div class="mt-2 p-3 bg-indigo-900/20 border border-dashed border-indigo-500/50 rounded-lg text-xs"><div class="text-indigo-400 font-semibold mb-1">Dispatch Chat:</div><div class="text-gray-200">${escH(a.text)}</div></div> `).join('') : '<div class="text-gray-500 text-xs italic mt-2">No actions dispatched</div>';

            container.innerHTML = `<div class="mb-6"><div class="text-sm font-semibold text-gray-200">Command: <span class="text-indigo-400">${escH(trace.command.name || 'None')}</span></div>

                  ${data.assertions?.length > 0 ? `<div class="mt-2 flex gap-2">${data.passed ? '<span class="text-[10px] px-1.5 py-0.5 bg-green-900/30 text-green-400 border border-green-800 rounded">Assertions Passed</span>' : '<span class="text-[10px] px-1.5 py-0.5 bg-red-900/30 text-red-400 border border-red-800 rounded">Assertions Failed</span>'}</div>` : ''}

            </div><div class="cl-timeline-item"><div class="text-xs font-bold text-gray-300">1. Normalization</div><div class="text-[11px] text-gray-500 mt-0.5 font-mono bg-black/20 p-1.5 rounded border border-gray-800">Input: "${escH(trace.input.messageText)}"</div></div><div class="cl-timeline-item"><div class="text-xs font-bold text-gray-300">2. Argument Extraction</div><div class="mt-1 flex flex-wrap gap-1">${trace.command.args && trace.command.args.length > 0 ? trace.command.args.map(a => `<span class="px-1.5 py-0.5 bg-gray-800 border border-gray-700 rounded text-[10px] font-mono text-indigo-300">${escH(a)
              }

                </span>`).join('') : '<span class="text-gray-600 text-[10px] italic">None</span>'
              }

            </div> </div> <div class="cl-timeline-item"><div class="text-xs font-bold text-gray-300">3. Match Result</div><div class="text-[11px] mt-1"> Status: ${matched ? '<span class="text-green-400">MATCHED</span>' : '<span class="text-gray-500">NO MATCH</span>'
              }

                ${trace.command.denied ? `<div class="text-red-400 mt-0.5 italic">Denied: ${escH(trace.command.reason || 'Role Restricted')}</div>` : ''}

            </div> </div> <div class="cl-timeline-item mb-0"><div class="text-xs font-bold text-gray-300">4. Actions Preview</div>${actionsHtml}

                <pre class="text-[10px] text-gray-400 bg-black/40 border border-gray-800 p-3 rounded-lg overflow-x-auto h-64">${escH(JSON.stringify(data, null, 2))}</pre>

                </div></details> `;
          }

          loadCommandTests();
        })();

      </script>
      <!--=========================================================Live updater (poll /dashboard/metrics/data)==========================================================-->
      <script>(function () {
          const _$ = (id) => document.getElementById(id);
          let allTests = [];

          let testResults = {}

            ;
          let lastRunId = null;
          let auditTimer = null;

          function escH(s) {
            return String(s ?? "").replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll('"', "&quot;");
          }

          function fmtTsS(ts) {
            try {
              if (!ts) return "\u2014"; const d = new Date(ts); return isNaN(d.getTime()) ? "\u2014" : d.toISOString().slice(11, 19);
            }

            catch (e) {
              return "\u2014";
            }
          }

          async function loadTests() {
            try {
              const r = await fetch("/dashboard/metrics/tests", {
                cache: "no-store"
              });
              const j = await r.json().catch(() => null);
              if (!j?.ok || !Array.isArray(j.tests)) throw new Error(j?.error || "bad response");
              allTests = j.tests;
              renderTestList();
            }

            catch (e) {
              const el = _$("tl_list");
              if (el) el.innerHTML = '<div class="text-red-400 text-xs py-2">Failed to load: ' + escH(e.message) + '</div>';
            }
          }

          function renderTestList() {
            const host = _$("tl_list");
            if (!host) return;

            const cats = {}

              ;

            allTests.forEach(t => {
              (cats[t.category] = cats[t.category] || []).push(t);
            });
            let html = "";

            for (const [cat, tests] of Object.entries(cats)) {
              html += '<div class="text-xs text-gray-500 uppercase tracking-wider mt-2 mb-1">' + escH(cat) + '</div>';

              for (const t of tests) {
                const r = testResults[t.id];
                const badge = r ? r.pass ? '<span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-green-700/50 border border-green-700 text-green-100">PASS</span>'
                  : '<span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-700/50 border border-red-700 text-red-100">FAIL</span>'
                  : "";
                html += '<div class="flex items-center justify-between px-2 py-1.5 rounded-lg hover:bg-gray-800/60 cursor-pointer group" data-test-id="' + escH(t.id) + '">'
                  + '<div class="flex items-center gap-2 min-w-0">' + badge + '<span class="text-gray-200 truncate">' + escH(t.name) + '</span></div>'
                  + '<button class="tl-run-btn opacity-0 group-hover:opacity-100 text-xs px-2 py-1 rounded bg-gray-800 hover:bg-gray-700 border border-gray-700 transition" data-run="' + escH(t.id) + '">Run</button>'
                  + '</div>';
              }
            }

            host.innerHTML = html;

            host.querySelectorAll("button.tl-run-btn").forEach(btn => {
              btn.addEventListener("click", e => {
                e.stopPropagation(); runTest(btn.getAttribute("data-run"));
              });
            });

            host.querySelectorAll("[data-test-id]").forEach(row => {
              row.addEventListener("click", () => {
                const id = row.getAttribute("data-test-id");
                const r = testResults[id];
                if (r) showResult(id, r); else runTest(id);
              });
            });
            renderSummary();
          }

          function renderSummary() {
            const el = _$("tl_summary");
            if (!el) return;
            const total = allTests.length, ran = Object.keys(testResults).length;
            const passed = Object.values(testResults).filter(r => r.pass).length;

            if (!ran) {
              el.textContent = total + " tests available"; return;
            }

            el.innerHTML = '<span class="text-green-400">' + passed + ' passed</span> \u00b7 <span class="text-red-400">' + (ran - passed) + ' failed</span> \u00b7 ' + (total - ran) + ' pending';
          }

          async function runTest(testId) {
            const title = _$("tl_resultTitle"), badge = _$("tl_resultBadge");
            if (title) title.textContent = "Running\u2026";
            if (badge) badge.classList.add("hidden");

            try {
              const r = await fetch("/dashboard/metrics/tests/run", {
                method: "POST", headers: {
                  "content-type": "application/json"
                }

                ,
                body: JSON.stringify({
                  test_id: testId
                }),
              });
              const j = await r.json().catch(() => null);
              if (!j) throw new Error("Empty response");
              const pass = j.pass ?? (Array.isArray(j.assertions) ? j.assertions.every(a => a.pass) : false);
              lastRunId = j.test_run_id || null;

              testResults[testId] = {
                pass, result: j, assertions: j.assertions || []
              }

                ;
              renderTestList();
              showResult(testId, testResults[testId]);
              refreshAudit();
            }

            catch (e) {
              if (title) title.textContent = "Error: " + e.message;
            }
          }

          async function runAll() {
            const btn = _$("tl_runAll");

            if (btn) {
              btn.disabled = true; btn.textContent = "Running\u2026";
            }

            for (const t of allTests) await runTest(t.id);

            if (btn) {
              btn.disabled = false; btn.textContent = "\u25b6 Run All";
            }
          }

          function showResult(testId, {
            pass, result, assertions

          }) {
            const test = allTests.find(t => t.id === testId);
            const title = _$("tl_resultTitle"), badge = _$("tl_resultBadge");
            const assertEl = _$("tl_assertions"), actWrap = _$("tl_actions"), actBody = _$("tl_actionsBody");
            const rawWrap = _$("tl_rawWrap"), rawEl = _$("tl_raw");

            if (title) title.textContent = test?.name || testId;

            if (badge) {
              badge.classList.remove("hidden", "bg-green-700/50", "border-green-700", "text-green-100", "bg-red-700/50", "border-red-700", "text-red-100");
              badge.textContent = pass ? "PASS" : "FAIL";
              badge.classList.add(pass ? "bg-green-700/50" : "bg-red-700/50", "border", pass ? "border-green-700" : "border-red-700", pass ? "text-green-100" : "text-red-100");
            }

            if (assertEl && assertions.length) {
              assertEl.classList.remove("hidden");
              assertEl.innerHTML = '<div class="text-xs text-gray-500 mb-1">Assertions</div>'

                + assertions.map(a => {
                  const icon = a.pass ? "\u2713" : "\u2717", cls = a.pass ? "text-green-400" : "text-red-400";
                  return '<div class="flex items-start gap-2 text-xs px-2 py-1 rounded bg-black/20 border border-gray-800">'
                    + '<span class="' + cls + ' font-bold">' + icon + '</span>'
                    + '<span class="text-gray-300"><code>' + escH(a.path) + '</code></span>'
                    + '<span class="text-gray-500">' + escH(a.reason || "") + '</span></div>';
                }).join("");
            }

            else if (assertEl) assertEl.classList.add("hidden");

            const actions = result?.pipeline?.last?.actions_results || result?.last?.actions_results || [];

            if (actWrap && actBody && actions.length) {
              actWrap.classList.remove("hidden");

              actBody.innerHTML = actions.map(a => {
                const w = a.would || {}

                  ;
                return '<div class="text-xs px-2 py-1 rounded bg-yellow-900/20 border border-yellow-800/50 text-yellow-200">'
                  + '<span class="font-semibold">' + escH(a.label) + '</span>'
                  + ' \u2192 <span class="text-yellow-300">' + escH(w.action || "") + '</span>'
                  + (w.target ? ' target: ' + escH(w.target) : "") + (w.duration_seconds ? ' (' + w.duration_seconds + 's)' : "") + (w.reason ? ' \u2014 ' + escH(w.reason) : "") + '</div>';
              }).join("");
            }

            else if (actWrap) actWrap.classList.add("hidden");

            if (rawWrap && rawEl) {
              rawWrap.classList.remove("hidden"); rawEl.textContent = JSON.stringify(result, null, 2);
            }
          }

          async function refreshAudit() {
            try {
              const r = await fetch("/dashboard/metrics/audit?limit=40", {
                cache: "no-store"
              });
              const j = await r.json().catch(() => null);
              renderAudit(Array.isArray(j?.items) ? j.items : []);
            }

            catch {
              renderAudit([]);
            }
          }

          function renderAudit(items) {
            const body = _$("tl_auditBody"), empty = _$("tl_auditEmpty");
            if (!body) return;
            const filterByRun = _$("tl_auditFilterRun")?.checked && lastRunId;
            const filtered = filterByRun ? items.filter(x => x.test_run_id === lastRunId) : items;

            if (!filtered.length) {
              body.innerHTML = ""; if (empty) empty.classList.remove("hidden"); return;
            }

            if (empty) empty.classList.add("hidden");

            body.innerHTML = filtered.slice(0, 30).map(x => {
              const hits = [];
              if (x.flood?.matched) hits.push('<span class="px-1 py-0.5 rounded bg-red-900/50 border border-red-800 text-red-200">flood</span>');
              if (x.swarm?.matched) hits.push('<span class="px-1 py-0.5 rounded bg-purple-900/50 border border-purple-800 text-purple-200">swarm</span>');
              if (x.moderation?.matched) hits.push('<span class="px-1 py-0.5 rounded bg-orange-900/50 border border-orange-800 text-orange-200">mod</span>');
              if (x.trust?.hostile) hits.push('<span class="px-1 py-0.5 rounded bg-red-900/50 border border-red-800 text-red-200">trust</span>');
              return '<tr class="border-t border-gray-900 bg-gray-950/30">'
                + '<td class="py-1.5 pr-3 text-gray-400 tabular-nums">' + fmtTsS(x.ts) + '</td>'
                + '<td class="py-1.5 pr-3 text-gray-200">' + escH(x.senderUsername || "\u2014") + '</td>'
                + '<td class="py-1.5 pr-3 text-gray-300">' + escH(x.channelSlug || "\u2014") + '</td>'
                + '<td class="py-1.5 pr-3 text-gray-400">' + escH(x.userRole || "\u2014") + '</td>'
                + '<td class="py-1.5 pr-3"><div class="flex gap-1">' + (hits.join("") || '<span class="text-gray-600">\u2014</span>') + '</div></td>'
                + '<td class="py-1.5 pr-3 text-gray-500 truncate max-w-[200px]">' + escH(x.text_preview || "") + '</td></tr>';
            }).join("");
          }

          _$("tl_runAll")?.addEventListener("click", runAll);
          _$("tl_auditRefresh")?.addEventListener("click", refreshAudit);
          _$("tl_auditFilterRun")?.addEventListener("change", refreshAudit);
          loadTests();
          refreshAudit();
          auditTimer = setInterval(refreshAudit, 3000);
        })();
      </script>
