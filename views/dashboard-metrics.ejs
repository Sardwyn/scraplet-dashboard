          }

          async function clApi(path, method = 'GET', body = null) {
            const options = {

              method,
              headers: {
                'Content-Type': 'application/json'
              }
            }

              ;
            if (body) options.body = JSON.stringify(body);

            try {
              const resp = await fetch(path, options);
              return await resp.json();
            }

            catch (e) {
              return {
                ok: false, error: String(e)
              }

                ;
            }
          }

          async function loadCommandTests() {
            const data = await clApi('/dashboard/metrics/tests/commands');
            const container = _$('cl_testSuite');
            if (!container) return;

            if (!data?.ok || !Array.isArray(data.tests)) {
              container.innerHTML = '<div class="text-red-400 text-xs py-2">Failed to load tests</div>';
              return;
            }

            container.innerHTML = data.tests.map(test => ` <button class="cl-test-btn text-left text-xs px-3 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-300 transition truncate"

                data-id="${escH(test.id)}">${escH(test.name)}</button> `).join('');

            container.querySelectorAll('.cl-test-btn').forEach(btn => {
              btn.addEventListener('click', () => runCommandTest(btn.getAttribute('data-id')));
            });
          }

          async function runCommandTest(testId) {
            const container = _$('cl_traceResult');
            if (container) container.innerHTML = '<div class="h-full flex items-center justify-center text-gray-500 text-sm">Running...</div>';

            const result = await clApi('/dashboard/metrics/tests/commands/run', 'POST', {
              test_id: testId
