<div class="max-w-6xl mx-auto px-4 py-8">

  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-white">Overlay Marketplace</h1>
      <p class="text-gray-400 mt-1 text-sm">Browse and download stream overlays created by the community.</p>
    </div>
    <% if (user) { %>
      <a href="/dashboard/overlays" class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold transition-colors">
        + Publish Your Overlay
      </a>
    <% } else { %>
      <a href="/auth/login" class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold transition-colors">
        Sign in to download
      </a>
    <% } %>
  </div>

  <% if (!listings || listings.length === 0) { %>
    <div class="text-center py-24 text-gray-500">
      <div class="text-5xl mb-4">🎨</div>
      <div class="text-lg font-semibold text-gray-400">No overlays yet</div>
      <p class="text-sm mt-2">Be the first to publish an overlay to the marketplace.</p>
      <% if (user) { %>
        <a href="/dashboard/overlays" class="mt-4 inline-block px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold">Publish an overlay</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% listings.forEach(function(l) { %>
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-gray-700 transition-colors group">
          <!-- Preview placeholder -->
          <div class="aspect-video bg-gray-800 flex items-center justify-center relative overflow-hidden">
            <a href="/o/<%= l.overlay_public_id %>" target="_blank" rel="noopener"
               class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 text-white text-sm font-semibold">
              Preview ↗
            </a>
            <svg class="w-12 h-12 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>

          <div class="p-4">
            <div class="flex items-start justify-between gap-2">
              <div>
                <h3 class="font-semibold text-white text-sm"><%= l.title %></h3>
                <p class="text-xs text-gray-500 mt-0.5">by <%= l.creator_username %></p>
              </div>
              <span class="text-sm font-bold <%= l.price_cents === 0 ? 'text-green-400' : 'text-white' %> shrink-0">
                <%= l.price_cents === 0 ? 'Free' : '$' + (l.price_cents/100).toFixed(2) %>
              </span>
            </div>

            <% if (l.description) { %>
              <p class="text-xs text-gray-400 mt-2 line-clamp-2"><%= l.description %></p>
            <% } %>

            <div class="mt-4">
              <% if (!user) { %>
                <a href="/auth/login" class="block w-full text-center py-2 rounded-lg bg-indigo-600/20 border border-indigo-500/30 text-indigo-300 text-xs font-semibold hover:bg-indigo-600/30 transition-colors">
                  Sign in to get this
                </a>
              <% } else if (l.price_cents === 0) { %>
                <button
                  onclick="acquireOverlay(<%= l.id %>, this)"
                  class="w-full py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold transition-colors">
                  Get this free
                </button>
              <% } else { %>
                <button class="w-full py-2 rounded-lg bg-amber-600/20 border border-amber-500/30 text-amber-300 text-xs font-semibold cursor-not-allowed opacity-60">
                  Paid — coming soon
                </button>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</div>

<script>
async function acquireOverlay(listingId, btn) {
  btn.disabled = true;
  btn.textContent = 'Adding...';
  try {
    const r = await fetch('/dashboard/api/marketplace/acquire/' + listingId, { method: 'POST', credentials: 'include' });
    const d = await r.json();
    if (d.ok) {
      btn.textContent = '✓ Added!';
      btn.className = btn.className.replace('bg-indigo-600', 'bg-green-600');
      setTimeout(() => { window.location.href = d.editUrl; }, 800);
    } else {
      btn.textContent = 'Error: ' + d.error;
      btn.disabled = false;
    }
  } catch(e) {
    btn.textContent = 'Failed';
    btn.disabled = false;
  }
}
</script>
